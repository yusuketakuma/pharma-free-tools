# codex/rules/default.rules
# Guardrails for danger-full-access + approval_policy=never.
# Goal: keep speed, block catastrophic commands that would be unrecoverable or hang non-interactive runs.

# 1) sudo: non-interactive runs will hang on password prompts; also too much privilege escalation.
prefix_rule(
    pattern = ["sudo"],
    decision = "forbidden",
    justification = "sudoは禁止（非対話でパスワード待ちになり停止する＆権限事故防止）。必要なら人間が手動で実行。",
    match = ["sudo ls", "sudo rm -rf /"],
)

# 2) rm -rf / : catastrophic
prefix_rule(
    pattern = ["rm", ["-rf", "-fr", "-r"], "/"],
    decision = "forbidden",
    justification = "ルート削除は禁止。",
    match = ["rm -rf /"],
    not_match = ["rm -rf node_modules", "rm -rf ./dist"],
)

# 3) Force push: protects repo history from silent destruction
prefix_rule(
    pattern = ["git", "push", ["-f", "--force", "--force-with-lease"]],
    decision = "forbidden",
    justification = "force pushは禁止（履歴破壊リスク）。必要なら手動で実行し、意図をレビューした上で行う。",
    match = ["git push -f", "git push --force-with-lease"],
)

# 4) Destructive disk operations (basic tripwires)
prefix_rule(
    pattern = ["dd"],
    decision = "forbidden",
    justification = "ddは禁止（誤用で即死）。必要なら手動で実行。",
    match = ["dd if=/dev/zero of=/dev/disk1"],
)

prefix_rule(
    pattern = [["mkfs", "mkfs.ext4", "newfs"]],
    decision = "forbidden",
    justification = "ファイルシステム作成系は禁止（破壊的）。",
    match = ["mkfs.ext4 /dev/sda1"],
)
