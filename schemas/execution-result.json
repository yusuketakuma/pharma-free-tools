{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "openclaw://schemas/execution-result.json",
  "title": "OpenClaw Execution Result",
  "description": "Claude Code execution plane → OpenClaw control plane への実行結果契約",
  "type": "object",
  "required": ["requestId", "status", "summary"],
  "properties": {
    "requestId": {
      "type": "string",
      "format": "uuid",
      "description": "対応するexecution-requestのID"
    },
    "status": {
      "type": "string",
      "enum": ["success", "partial", "failed", "timeout", "blocked", "approval-needed"],
      "description": "実行結果ステータス"
    },
    "summary": {
      "type": "string",
      "maxLength": 1000,
      "description": "実行結果の要約"
    },
    "changes": {
      "type": "object",
      "properties": {
        "filesModified": {
          "type": "array",
          "items": { "type": "string" },
          "description": "変更したファイルパス"
        },
        "filesCreated": {
          "type": "array",
          "items": { "type": "string" },
          "description": "新規作成したファイルパス"
        },
        "filesDeleted": {
          "type": "array",
          "items": { "type": "string" },
          "description": "削除したファイルパス"
        },
        "commitSha": {
          "type": "string",
          "description": "コミットSHA（コミットした場合）"
        },
        "branch": {
          "type": "string",
          "description": "作業ブランチ"
        },
        "diffSummary": {
          "type": "string",
          "description": "変更差分の要約"
        }
      }
    },
    "verification": {
      "type": "object",
      "properties": {
        "testsRun": {
          "type": "boolean",
          "default": false
        },
        "testsPassed": {
          "type": "boolean"
        },
        "testSummary": {
          "type": "string"
        },
        "lintPassed": {
          "type": "boolean"
        },
        "typecheckPassed": {
          "type": "boolean"
        },
        "coverageDelta": {
          "type": "string",
          "description": "カバレッジ変化（例: +2.1%）"
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "durationSeconds": {
          "type": "integer"
        },
        "tokensUsed": {
          "type": "object",
          "properties": {
            "input": { "type": "integer" },
            "output": { "type": "integer" },
            "cacheRead": { "type": "integer" }
          }
        },
        "costUsd": {
          "type": "number"
        },
        "subagentsSpawned": {
          "type": "integer"
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["dependency", "permission", "approval", "environment", "unclear-spec"]
          },
          "description": { "type": "string" },
          "suggestedAction": { "type": "string" }
        }
      },
      "description": "ブロッカーリスト（status=blocked/partial時）"
    },
    "nextActions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "推奨次アクション"
    },
    "completedAt": {
      "type": "string",
      "format": "date-time"
    },
    "executedBy": {
      "type": "string",
      "description": "実行エージェントID"
    },
    "runtime": {
      "type": "string",
      "enum": ["acp_compat", "cli", "cli_backend_safety_net"],
      "description": "使用したランタイム"
    }
  },
  "additionalProperties": false
}
