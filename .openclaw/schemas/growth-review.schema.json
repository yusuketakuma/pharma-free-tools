{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GrowthReview",
  "type": "object",
  "required": [
    "proposal_id",
    "reviewed_at",
    "decision",
    "reviewer",
    "reason",
    "apply_mode",
    "approved_paths",
    "blocked_paths"
  ],
  "properties": {
    "proposal_id": {
      "type": "string"
    },
    "reviewed_at": {
      "type": "string"
    },
    "decision": {
      "type": "string",
      "enum": [
        "approve",
        "reject",
        "revise"
      ]
    },
    "reviewer": {
      "type": "string"
    },
    "reason": {
      "type": "string"
    },
    "apply_mode": {
      "type": "string",
      "enum": [
        "manual",
        "assisted"
      ]
    },
    "approved_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "proposal_path": {
      "type": "string"
    },
    "status_before": {
      "type": "string"
    },
    "status_after": {
      "type": "string"
    },
    "notes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "review_id": {
      "type": "string"
    }
  },
  "additionalProperties": true
}
