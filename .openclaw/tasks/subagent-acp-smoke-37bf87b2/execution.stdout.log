runtime import (  # noqa: E402\n    21→    atomic_write_json,\n    22→    atomic_write_text,\n    23→    ensure_schema_valid,\n    24→    load_claude_code_config,\n    25→    load_json,\n    26→    resolve_claude_code_bin,\n    27→)\n    28→\n    29→EXIT_SUCCESS = 0\n    30→EXIT_POLICY_BLOCKED = 10\n    31→EXIT_TIMEOUT = 20\n    32→EXIT_RUNTIME_ERROR = 30\n    33→EXIT_INVALID_REQUEST = 40\n    34→EXIT_INVALID_RESULT = 50\n    35→STRUCTURED_SCHEMA_PATH = ROOT / \"schemas\" / \"claude-structured-output.schema.json\"\n    36→\n    37→\n    38→def now_iso() -> str:\n    39→    return datetime.now(timezone.utc).astimezone().isoformat(timespec=\"seconds\")\n    40→\n    41→\n    42→def parse_args() -> argparse.Namespace:\n    43→    parser = argparse.ArgumentParser(description=\"Contract-preserving ACP adapter for Claude Code\")\n    44→    parser.add_argument(\"--request\", required=True)\n    45→    parser.add_argument(\"--result\", required=True)\n    46→    parser.add_argument(\"--stdout-log\", required=True)\n    47→    parser.add_argument(\"--stderr-log\", required=True)\n    48→    parser.add_argument(\"--dry-run\", action=\"store_true\")\n    49→    return parser.parse_args()\n    50→\n    51→\n    52→def build_result(\n    53→    request: dict,\n    54→    *,\n    55→    status: str,\n    56→    exit_code: int,\n    57→    summary: str,\n    58→    changed_files: list[str] | None = None,\n    59→    verification_results: list[str] | None = None,\n    60→    remaining_risks: list[str] | None = None,\n    61→    meta: dict | None = None,\n    62→) -> dict:\n    63→    payload = {\n    64→        \"task_id\": request.get(\"task_id\", \"unknown\"),\n    65→        \"status\": status,\n    66→        \"executor\": \"claude-code\",\n    67→        \"summary\": summary,\n    68→        \"changed_files\": changed_files or [],\n    69→        \"verification_results\": verification_results or [],\n    70→        \"remaining_risks\": remaining_risks or [],\n    71→        \"exit_code\": exit_code,\n    72→        \"started_at\": request.get(\"started_at\") or now_iso(),\n    73→        \"finished_at\": now_iso(),\n    74→        \"dispatch_id\": request.get(\"dispatch_id\"),\n    75→        \"raw_response_path\": str(Path(request.get(\"raw_response_path\") or (Path(request.get(\"context_pack_path\") or \".\").parent / \"claude-raw.json\"))),\n    76→        \"rendered_prompt_path\": str(request.get(\"rendered_prompt_path\") or \"\"),\n    77→    }\n    78→    if meta:\n    79→        payload[\"_meta\"] = meta\n    80→    return payload\n    81→\n    82→\n    83→def ensure_parent(path: Path) -> Path:\n    84→    path.parent.mkdir(parents=True, exist_ok=True)\n    85→    return path\n    86→\n    87→\n    88→def resolve_workspace_path(value: str | None, fallback: Path) -> Path:\n    89→    if not value:\n    90→        return fallback\n    91→    path = Path(value)\n    92→    if not path.is_absolute():\n    93→        path = WORKSPACE / path\n    94→    return path\n    95→\n    96→\n    97→def append_log(path: Path, message: str) -> None:\n    98→    with path.open(\"a\", encoding=\"utf-8\") as fh:\n    99→        fh.write(message)\n   100→        if not message.endswith(\"\\n\"):\n   101→            fh.write(\"\\n\")\n   102→\n   103→\n   104→def build_prompt(request: dict, prompt_path: Path) -> str:\n   105→    if prompt_path.exists():\n   106→        return prompt_path.read_text(encoding=\"utf-8\")\n   107→    context_text = \"\"\n   108→    context_path = resolve_workspace_path(request.get(\"context_pack_path\"), prompt_path.parent / \"context-pack.md\")\n   109→    if context_path.exists():\n   110→        context_text = context_path.read_text(encoding=\"utf-8\").strip()\n   111→    lines = [\n   112→        f\"Task ID: {request.get('task_id', 'unknown')}\",\n   113→        f\"Dispatch ID: {request.get('dispatch_id', '(none)')}\",\n   114→        \"Execution lane: acp\",\n   115→        \"\",\n   116→        \"Return structured output that matches the provided JSON schema exactly.\",\n   117→        \"Do not wrap the response in markdown fences.\",\n   118→        \"\",\n   119→        \"Task Summary:\",\n   120→        request.get(\"task_summary\", \"\"),\n   121→        \"\",\n   122→        \"Constraints:\",\n   123→    ]\n   124→    constraints = request.get(\"constraints\") or [\"(none)\"]\n   125→    lines.extend([f\"- {item}\" for item in constraints])\n   126→    lines.extend([\"\", \"Target Paths:\"])\n   127→    targets = request.get(\"target_paths\") or [\"(none)\"]\n   128→    lines.extend([f\"- {item}\" for item in targets])\n   129→    lines.extend([\"\", \"Verification Commands:\"])\n   130→    commands = request.get(\"verification_commands\") or [\"(none)\"]\n   131→    lines.extend([f\"- {item}\" for item in commands])\n   132→    lines.extend([\"\", \"Review Focus:\"])\n   133→    focus = request.get(\"review_focus\") or [\"(none)\"]\n   134→    lines.extend([f\"- {item}\" for item in focus])\n   135→    if context_text:\n   136→        lines.extend([\"\", \"Context Pack:\", context_text])\n   137→    prompt = \"\\n\".join(lines).rstrip() + \"\\n\"\n   138→    atomic_write_text(prompt_path, prompt)\n   139→    return prompt\n   140→\n   141→\n   142→def detect_native_acp_support(claude_bin: str) -> tuple[bool, str | None]:\n   143→    try:\n   144→        help_run = subprocess.run([claude_bin, \"--help\"], check=False, capture_output=True, text=True, timeout=15)\n   145→    except Exception as exc:  # noqa: BLE001\n   146→        return False, f\"help probe failed: {exc}\"\n   147→    combined = f\"{help_run.stdout}\\n{help_run.stderr}\".lower()\n   148→    commands_block = combined.split(\"commands:\", 1)[1] if \"commands:\" in combined else combined\n   149→    if re.search(r\"(?m)^\\s*acp\\b\", commands_block):\n   150→        return True, None\n   151→    return False, \"claude CLI does not expose a native acp subcommand in this environment\"\n   152→\n   153→\n   154→def auth_preflight(claude_bin: str, auth_status_path: Path, auth_log_path: Path) -> dict[str, Any]:\n   155→    started_at = now_iso()\n   156→    command = [claude_bin, \"auth\", \"status\", \"--json\"]\n   157→    completed = subprocess.run(command, check=False, capture_output=True, text=True)\n   158→    parsed = None\n   159→    parse_error = None\n   160→    try:\n   161→        parsed = json.loads(completed.stdout) if completed.stdout.strip() else None\n   162→    except Exception as exc:  # noqa: BLE001\n   163→        parse_error = str(exc)\n   164→    logged_in = False\n   165→    auth_method = None\n   166→    user_email = None\n   167→    if isinstance(parsed, dict):\n   168→        logged_in = bool(parsed.get(\"loggedIn\") or parsed.get(\"authenticated\") or parsed.get(\"ok\"))\n   169→        auth_method = parsed.get(\"authMethod\") or parsed.get(\"method\")\n   170→        user_email = parsed.get(\"email\") or parsed.get(\"userEmail\")\n   171→    log_lines = [\n   172→        f\"[{started_at}] command={' '.join(command)}\",\n   173→        f\"exit_code={completed.returncode}\",\n   174→        \"--- stdout ---\",\n   175→        completed.stdout.rstrip(),\n   176→        \"--- stderr ---\",\n   177→        completed.stderr.rstrip(),\n   178→    ]\n   179→    atomic_write_text(auth_log_path, \"\\n\".join(log_lines).rstrip() + \"\\n\")\n   180→    payload = {\n   181→        \"checked_at\": now_iso(),\n   182→        \"ok\": completed.returncode == 0 and logged_in,\n   183→        \"cli\": claude_bin,\n   184→        \"command\": command,\n   185→        \"exit_code\": completed.returncode,\n   186→        \"logged_in\": logged_in,\n   187→        \"auth_method\": auth_method,\n   188→        \"user_email\": user_email,\n   189→        \"stderr\": completed.stderr,\n   190→    }\n   191→    if isinstance(parsed, dict):\n   192→        payload[\"stdout\"] = parsed\n   193→    if parse_error:\n   194→        payload[\"message\"] = f\"stdout JSON parse failed: {parse_error}\"\n   195→    atomic_write_json(auth_status_path, payload)\n   196→    runtime_cache_path = ROOT / \"runtime\" / \"auth\" / \"latest-status.json\"\n   197→    ensure_parent(runtime_cache_path)\n   198→    atomic_write_json(runtime_cache_path, payload)\n   199→    return payload\n   200→\n   201→\n   202→def extract_events(payload: Any) -> tuple[dict[str, Any] | None, dict[str, Any] | None]:\n   203→    init_event = None\n   204→    result_event = None\n   205→    if isinstance(payload, list):\n   206→        for item in payload:\n   207→            if isinstance(item, dict) and item.get(\"type\") == \"system\" and item.get(\"subtype\") == \"init\":\n   208→                init_event = item\n   209→        for item in reversed(payload):\n   210→            if isinstance(item, dict) and item.get(\"type\") == \"result\":\n   211→                result_event = item\n   212→                break\n   213→    elif isinstance(payload, dict) and payload.get(\"type\") == \"result\":\n   214→        result_event = payload\n   215→    return init_event, result_event\n   216→\n   217→\n   218→def load_raw_json(raw_path: Path) -> tuple[Any, str]:\n   219→    raw_text = raw_path.read_text(encoding=\"utf-8\") if raw_path.exists() else \"\"\n   220→    if not raw_text.strip():\n   221→        return None, raw_text\n   222→    try:\n   223→        return json.loads(raw_text), raw_text\n   224→    except Exception:\n   225→        return None, raw_text\n   226→\n   227→\n   228→def build_meta(\n   229→    *,\n   230→    init_event: dict[str, Any] | None,\n   231→    result_event: dict[str, Any] | None,\n   232→    session_id: str | None,\n   233→    transport_kind: str,\n   234→    native_acp_available: bool,\n   235→    normalization_source: str,\n   236→    fallback_used: bool,\n   237→    raw_text: str,\n   238→    retry_count: int = 0,\n   239→    degraded_contract: str | None = None,\n   240→) -> dict[str, Any]:\n   241→    meta: dict[str, Any] = {\n   242→        \"lane\": \"acp\",\n   243→        \"transport_kind\": transport_kind,\n   244→        \"native_acp_available\": native_acp_available,\n   245→        \"session_id\": session_id,\n   246→        \"normalization_source\": normalization_source,\n   247→        \"fallback_used\": fallback_used,\n   248→        \"retry_count\": retry_count,\n   249→        \"raw_sha256\": hashlib.sha256(raw_text.encode(\"utf-8\")).hexdigest(),\n   250→        \"publishable\": True,\n   251→    }\n   252→    if degraded_contract:\n   253→        meta[\"degraded_contract\"] = degraded_contract\n   254→    if isinstance(result_event, dict):\n   255→        for key in (\"modelUsage\", \"total_cost_usd\", \"duration_ms\", \"duration_api_ms\", \"num_turns\", \"stop_reason\", \"permission_denials\", \"is_error\"):\n   256→            if key in result_event:\n   257→                meta[key] = result_event.get(key)\n   258→    if isinstance(init_event, dict):\n   259→        meta[\"cli_version\"] = init_event.get(\"claude_code_version\")\n   260→        meta[\"init\"] = {\n   261→            key: init_event.get(key)\n   262→            for key in (\"session_id\", \"model\", \"permissionMode\", \"tools\", \"claude_code_version\")\n   263→            if key in init_event\n   264→        }\n   265→    else:\n   266→        meta[\"cli_version\"] = None\n   267→    return {key: value for key, value in meta.items() if value is not None}\n   268→\n   269→\n   270→def coerce_structured_output(candidate: Any) -> tuple[dict[str, Any] | None, bool, str | None]:\n   271→    if isinstance(candidate, dict):\n   272→        required = {\"result\", \"changed_files\", \"verification_results\", \"remaining_risks\"}\n   273→        if required.issubset(candidate.keys()):\n   274→            return candidate, False, None\n   275→        compat = dict(candidate)\n   276→        changed = False\n   277→        if \"result\" not in compat and isinstance(compat.get(\"summary\"), str):\n   278→            compat[\"result\"] = compat[\"summary\"]\n   279→            changed = True\n   280→        if \"changed_files\" not in compat:\n   281→            compat[\"changed_files\"] = []\n   282→            changed = True\n   283→        if \"verification_results\" not in compat:\n   284→            compat[\"verification_results\"] = []\n   285→            changed = True\n   286→        if \"remaining_risks\" not in compat:\n   287→            compat[\"remaining_risks\"] = []\n   288→            changed = True\n   289→        if required.issubset(compat.keys()):\n   290→            return compat, changed, \"compatibility normalization filled missing structured output fields\" if changed else None\n   291→    return None, False, None\n   292→\n   293→\n   294→def normalize_success_result(\n   295→    request: dict,\n   296→    raw_path: Path,\n   297→    *,\n   298→    session_id: str | None,\n   299→    transport_kind: str,\n   300→    native_acp_available: bool,\n   301→) -> dict:\n   302→    raw_payload, raw_text = load_raw_json(raw_path)\n   303→    init_event, result_event = extract_events(raw_payload)\n   304→    if not isinstance(result_event, dict):\n   305→        return build_result(\n   306→            request,\n   307→            status=\"invalid_result\",\n   308→            exit_code=EXIT_INVALID_RESULT,\n   309→            summary=\"ACP adapter could not locate result envelope\",\n   310→            verification_results=[\"result envelope missing\"],\n   311→            remaining_risks=[\"inspect claude-raw.json for output drift\"],\n   312→            meta={\n   313→                \"lane\": \"acp\",\n   314→                \"transport_kind\": transport_kind,\n   315→                \"native_acp_available\": native_acp_available,\n   316→                \"session_id\": session_id,\n   317→                \"publishable\": False,\n   318→            },\n   319→        )\n   320→\n   321→    structured_output = result_event.get(\"structured_output\")\n   322→    candidate, compat_changed, degraded_contract = coerce_structured_output(structured_output)\n   323→    normalization_source = \"structured_output\"\n   324→    fallback_used = False\n   325→    if candidate is None and isinstance(result_event.get(\"result\"), str):\n   326→        raw_result = result_event.get(\"result\")\n   327→        try:\n   328→            candidate_json = json.loads(raw_result)\n   329→        except Exception:\n   330→            fenced = re.findall(r\"```json\\s*(\\{.*?\\})\\s*```\", raw_result, flags=re.IGNORECASE | re.DOTALL)\n   331→            candidate_json = None\n   332→            if len(fenced) == 1:\n   333→                try:\n   334→                    candidate_json = json.loads(fenced[0])\n   335→                except Exception:\n   336→                    candidate_json = None\n   337→        candidate, compat_changed, degraded_contract = coerce_structured_output(candidate_json)\n   338→        if candidate is not None:\n   339→            normalization_source = \"result_json_fallback\"\n   340→            fallback_used = True\n   341→            degraded_contract = degraded_contract or \"structured_output missing; decoded JSON string from result\"\n   342→\n   343→    if candidate is None:\n   344→        return build_result(\n   345→            request,\n   346→            status=\"invalid_result\",\n   347→            exit_code=EXIT_INVALID_RESULT,\n   348→            summary=\"ACP adapter could not normalize Claude output to the structured contract\",\n   349→            verification_results=[\"structured output normalization failed\"],\n   350→            remaining_risks=[\"inspect claude-raw.json for schema drift\"],\n   351→            meta={\n   352→                \"lane\": \"acp\",\n   353→                \"transport_kind\": transport_kind,\n   354→                \"native_acp_available\": native_acp_available,\n   355→                \"session_id\": session_id,\n   356→                \"publishable\": False,\n   357→    