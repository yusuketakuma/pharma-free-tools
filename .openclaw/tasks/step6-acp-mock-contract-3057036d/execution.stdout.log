\n    16→ROOT = Path(__file__).resolve().parents[1]\n    17→WORKSPACE = ROOT.parent\n    18→sys.path.insert(0, str(ROOT / \"scripts\"))\n    19→\n    20→from task_runtime import (  # noqa: E402\n    21→    atomic_write_json,\n    22→    atomic_write_text,\n    23→    ensure_schema_valid,\n    24→    load_claude_code_config,\n    25→    load_json,\n    26→    resolve_claude_code_bin,\n    27→)\n    28→\n    29→EXIT_SUCCESS = 0\n    30→EXIT_POLICY_BLOCKED = 10\n    31→EXIT_TIMEOUT = 20\n    32→EXIT_RUNTIME_ERROR = 30\n    33→EXIT_INVALID_REQUEST = 40\n    34→EXIT_INVALID_RESULT = 50\n    35→STRUCTURED_SCHEMA_PATH = ROOT / \"schemas\" / \"claude-structured-output.schema.json\"\n    36→\n    37→\n    38→def now_iso() -> str:\n    39→    return datetime.now(timezone.utc).astimezone().isoformat(timespec=\"seconds\")\n    40→\n    41→\n    42→def parse_args() -> argparse.Namespace:\n    43→    parser = argparse.ArgumentParser(description=\"Contract-preserving ACP adapter for Claude Code\")\n    44→    parser.add_argument(\"--request\", required=True)\n    45→    parser.add_argument(\"--result\", required=True)\n    46→    parser.add_argument(\"--stdout-log\", required=True)\n    47→    parser.add_argument(\"--stderr-log\", required=True)\n    48→    parser.add_argument(\"--dry-run\", action=\"store_true\")\n    49→    return parser.parse_args()\n    50→\n    51→\n    52→def build_result(\n    53→    request: dict,\n    54→    *,\n    55→    status: str,\n    56→    exit_code: int,\n    57→    summary: str,\n    58→    changed_files: list[str] | None = None,\n    59→    verification_results: list[str] | None = None,\n    60→    remaining_risks: list[str] | None = None,\n    61→    meta: dict | None = None,\n    62→) -> dict:\n    63→    payload = {\n    64→        \"task_id\": request.get(\"task_id\", \"unknown\"),\n    65→        \"status\": status,\n    66→        \"executor\": \"claude-code\",\n    67→        \"summary\": summary,\n    68→        \"changed_files\": changed_files or [],\n    69→        \"verification_results\": verification_results or [],\n    70→        \"remaining_risks\": remaining_risks or [],\n    71→        \"exit_code\": exit_code,\n    72→        \"started_at\": request.get(\"started_at\") or now_iso(),\n    73→        \"finished_at\": now_iso(),\n    74→        \"dispatch_id\": request.get(\"dispatch_id\"),\n    75→        \"raw_response_path\": str(Path(request.get(\"raw_response_path\") or (Path(request.get(\"context_pack_path\") or \".\").parent / \"claude-raw.json\"))),\n    76→        \"rendered_prompt_path\": str(request.get(\"rendered_prompt_path\") or \"\"),\n    77→    }\n    78→    if meta:\n    79→        payload[\"_meta\"] = meta\n    80→    return payload\n    81→\n    82→\n    83→def ensure_parent(path: Path) -> Path:\n    84→    path.parent.mkdir(parents=True, exist_ok=True)\n    85→    return path\n    86→\n    87→\n    88→def resolve_workspace_path(value: str | None, fallback: Path) -> Path:\n    89→    if not value:\n    90→        return fallback\n    91→    path = Path(value)\n    92→    if not path.is_absolute():\n    93→        path = WORKSPACE / path\n    94→    return path\n    95→\n    96→\n    97→def append_log(path: Path, message: str) -> None:\n    98→    with path.open(\"a\", encoding=\"utf-8\") as fh:\n    99→        fh.write(message)\n   100→        if not message.endswith(\"\\n\"):\n   101→            fh.write(\"\\n\")\n   102→\n   103→\n   104→def build_prompt(request: dict, prompt_path: Path) -> str:\n   105→    if prompt_path.exists():\n   106→        return prompt_path.read_text(encoding=\"utf-8\")\n   107→    context_text = \"\"\n   108→    context_path = resolve_workspace_path(request.get(\"context_pack_path\"), prompt_path.parent / \"context-pack.md\")\n   109→    if context_path.exists():\n   110→        context_text = context_path.read_text(encoding=\"utf-8\").strip()\n   111→    lines = [\n   112→        f\"Task ID: {request.get('task_id', 'unknown')}\",\n   113→        f\"Dispatch ID: {request.get('dispatch_id', '(none)')}\",\n   114→        \"Execution lane: acp\",\n   115→        \"\",\n   116→        \"Return structured output that matches the provided JSON schema exactly.\",\n   117→        \"Do not wrap the response in markdown fences.\",\n   118→        \"\",\n   119→        \"Task Summary:\",\n   120→        request.get(\"task_summary\", \"\"),\n   121→        \"\",\n   122→        \"Constraints:\",\n   123→    ]\n   124→    constraints = request.get(\"constraints\") or [\"(none)\"]\n   125→    lines.extend([f\"- {item}\" for item in constraints])\n   126→    lines.extend([\"\", \"Target Paths:\"])\n   127→    targets = request.get(\"target_paths\") or [\"(none)\"]\n   128→    lines.extend([f\"- {item}\" for item in targets])\n   129→    lines.extend([\"\", \"Verification Commands:\"])\n   130→    commands = request.get(\"verification_commands\") or [\"(none)\"]\n   131→    lines.extend([f\"- {item}\" for item in commands])\n   132→    lines.extend([\"\", \"Review Focus:\"])\n   133→    focus = request.get(\"review_focus\") or [\"(none)\"]\n   134→    lines.extend([f\"- {item}\" for item in focus])\n   135→    if context_text:\n   136→        lines.extend([\"\", \"Context Pack:\", context_text])\n   137→    prompt = \"\\n\".join(lines).rstrip() + \"\\n\"\n   138→    atomic_write_text(prompt_path, prompt)\n   139→    return prompt\n   140→\n   141→\n   142→def detect_native_acp_support(claude_bin: str) -> tuple[bool, str | None]:\n   143→    try:\n   144→        help_run = subprocess.run([claude_bin, \"--help\"], check=False, capture_output=True, text=True, timeout=15)\n   145→    except Exception as exc:  # noqa: BLE001\n   146→        return False, f\"help probe failed: {exc}\"\n   147→    combined = f\"{help_run.stdout}\\n{help_run.stderr}\".lower()\n   148→    commands_block = combined.split(\"commands:\", 1)[1] if \"commands:\" in combined else combined\n   149→    if re.search(r\"(?m)^\\s*acp\\b\", commands_block):\n   150→        return True, None\n   151→    return False, \"claude CLI does not expose a native acp subcommand in this environment\"\n   152→\n   153→\n   154→def auth_preflight(claude_bin: str, auth_status_path: Path, auth_log_path: Path) -> dict[str, Any]:\n   155→    started_at = now_iso()\n   156→    command = [claude_bin, \"auth\", \"status\", \"--json\"]\n   157→    completed = subprocess.run(command, check=False, capture_output=True, text=True)\n   158→    parsed = None\n   159→    parse_error = None\n   160→    try:\n   161→        parsed = json.loads(completed.stdout) if completed.stdout.strip() else None\n   162→    except Exception as exc:  # noqa: BLE001\n   163→        parse_error = str(exc)\n   164→    logged_in = False\n   165→    auth_method = None\n   166→    user_email = None\n   167→    if isinstance(parsed, dict):\n   168→        logged_in = bool(parsed.get(\"loggedIn\") or parsed.get(\"authenticated\") or parsed.get(\"ok\"))\n   169→        auth_method = parsed.get(\"authMethod\") or parsed.get(\"method\")\n   170→        user_email = parsed.get(\"email\") or parsed.get(\"userEmail\")\n   171→    log_lines = [\n   172→        f\"[{started_at}] command={' '.join(command)}\",\n   173→        f\"exit_code={completed.returncode}\",\n   174→        \"--- stdout ---\",\n   175→        completed.stdout.rstrip(),\n   176→        \"--- stderr ---\",\n   177→        completed.stderr.rstrip(),\n   178→    ]\n   179→    atomic_write_text(auth_log_path, \"\\n\".join(log_lines).rstrip() + \"\\n\")\n   180→    payload = {\n   181→        \"checked_at\": now_iso(),\n   182→        \"ok\": completed.returncode == 0 and logged_in,\n   183→        \"cli\": claude_bin,\n   184→        \"command\": command,\n   185→        \"exit_code\": completed.returncode,\n   186→        \"logged_in\": logged_in,\n   187→        \"auth_method\": auth_method,\n   188→        \"user_email\": user_email,\n   189→        \"stderr\": completed.stderr,\n   190→    }\n   191→    if isinstance(parsed, dict):\n   192→        payload[\"stdout\"] = parsed\n   193→    if parse_error:\n   194→        payload[\"message\"] = f\"stdout JSON parse failed: {parse_error}\"\n   195→    atomic_write_json(auth_status_path, payload)\n   196→    runtime_cache_path = ROOT / \"runtime\" / \"auth\" / \"latest-status.json\"\n   197→    ensure_parent(runtime_cache_path)\n   198→    atomic_write_json(runtime_cache_path, payload)\n   199→    return payload\n   200→\n   201→\n   202→def extract_events(payload: Any) -> tuple[dict[str, Any] | None, dict[str, Any] | None]:\n   203→    init_event = None\n   204→    result_event = None\n   205→    if isinstance(payload, list):\n   206→        for item in payload:\n   207→            if isinstance(item, dict) and item.get(\"type\") == \"system\" and item.get(\"subtype\") == \"init\":\n   208→                init_event = item\n   209→        for item in reversed(payload):\n   210→            if isinstance(item, dict) and item.get(\"type\") == \"result\":\n   211→                result_event = item\n   212→                break\n   213→    elif isinstance(payload, dict) and payload.get(\"type\") == \"result\":\n   214→        result_event = payload\n   215→    return init_event, result_event\n   216→\n   217→\n   218→def load_raw_json(raw_path: Path) -> tuple[Any, str]:\n   219→    raw_text = raw_path.read_text(encoding=\"utf-8\") if raw_path.exists() else \"\"\n   220→    if not raw_text.strip():\n   221→        return None, raw_text\n   222→    try:\n   223→        return json.loads(raw_text), raw_text\n   224→    except Exception:\n   225→        return None, raw_text\n   226→\n   227→\n   228→def build_meta(\n   229→    *,\n   230→    init_event: dict[str, Any] | None,\n   231→    result_event: dict[str, Any] | None,\n   232→    session_id: str | None,\n   233→    transport_kind: str,\n   234→    native_acp_available: bool,\n   235→    normalization_source: str,\n   236→    fallback_used: bool,\n   237→    raw_text: str,\n   238→    retry_count: int = 0,\n   239→    degraded_contract: str | None = None,\n   240→) -> dict[str, Any]:\n   241→    meta: dict[str, Any] = {\n   242→        \"lane\": \"acp\",\n   243→        \"transport_kind\": transport_kind,\n   244→        \"native_acp_available\": native_acp_available,\n   245→        \"session_id\": session_id,\n   246→        \"normalization_source\": normalization_source,\n   247→        \"fallback_used\": fallback_used,\n   248→        \"retry_count\": retry_count,\n   249→        \"raw_sha256\": hashlib.sha256(raw_text.encode(\"utf-8\")).hexdigest(),\n   250→        \"publishable\": True,\n   251→    }\n   252→    if degraded_contract:\n   253→        meta[\"degraded_contract\"] = degraded_contract\n   254→    if isinstance(result_event, dict):\n   255→        for key in (\"modelUsage\", \"total_cost_usd\", \"duration_ms\", \"duration_api_ms\", \"num_turns\", \"stop_reason\", \"permission_denials\", \"is_error\"):\n   256→            if key in result_event:\n   257→                meta[key] = result_event.get(key)\n   258→    if isinstance(init_event, dict):\n   259→        meta[\"cli_version\"] = init_event.get(\"claude_code_version\")\n   260→        meta[\"init\"] = {\n   261→            key: init_event.get(key)\n   262→            for key in (\"session_id\", \"model\", \"permissionMode\", \"tools\", \"claude_code_version\")\n   263→            if key in init_event\n   264→        }\n   265→    else:\n   266→        meta[\"cli_version\"] = None\n   267→    return {key: value for key, value in meta.items() if value is not None}\n   268→\n   269→\n   270→def coerce_structured_output(candidate: Any) -> tuple[dict[str, Any] | None, bool, str | None]:\n   271→    if isinstance(candidate, dict):\n   272→        required = {\"result\", \"changed_files\", \"verification_results\", \"remaining_risks\"}\n   273→        if required.issubset(candidate.keys()):\n   274→            return candidate, False, None\n   275→        compat = dict(candidate)\n   276→        changed = False\n   277→        if \"result\" not in compat and isinstance(compat.get(\"summary\"), str):\n   278→            compat[\"result\"] = compat[\"summary\"]\n   279→            changed = True\n   280→        if \"changed_files\" not in compat:\n   281→            compat[\"changed_files\"] = []\n   282→            changed = True\n   283→        if \"verification_results\" not in compat:\n   284→            compat[\"verification_results\"] = []\n   285→            changed = True\n   286→        if \"remaining_risks\" not in compat:\n   287→            compat[\"remaining_risks\"] = []\n   288→            changed = True\n   289→        if required.issubset(compat.keys()):\n   290→            return compat, changed, \"compatibility normalization filled missing structured output fields\" if changed else None\n   291→    return None, False, None\n   292→\n   293→\n   294→def normalize_success_result(\n   295→    request: dict,\n   296→    raw_path: Path,\n   297→    *,\n   298→    session_id: str | None,\n   299→    transport_kind: str,\n   300→    native_acp_available: bool,\n   301→) -> dict:\n   302→    raw_payload, raw_text = load_raw_json(raw_path)\n   303→    init_event, result_event = extract_events(raw_payload)\n   304→    if not isinstance(result_event, dict):\n   305→        return build_result(\n   306→            request,\n   307→            status=\"invalid_result\",\n   308→            exit_code=EXIT_INVALID_RESULT,\n   309→            summary=\"ACP adapter could not locate result envelope\",\n   310→            verification_results=[\"result envelope missing\"],\n   311→            remaining_risks=[\"inspect claude-raw.json for output drift\"],\n   312→            meta={\n   313→                \"lane\": \"acp\",\n   314→                \"transport_kind\": transport_kind,\n   315→                \"native_acp_available\": native_acp_available,\n   316→                \"session_id\": session_id,\n   317→                \"publishable\": False,\n   318→            },\n   319→        )\n   320→\n   321→    structured_output = result_event.get(\"structured_output\")\n   322→    candidate, compat_changed, degraded_contract = coerce_structured_output(structured_output)\n   323→    normalization_source = \"structured_output\"\n   324→    fallback_used = False\n   325→    if candidate is None and isinstance(result_event.get(\"result\"), str):\n   326→        raw_result = result_event.get(\"result\")\n   327→        try:\n   328→            candidate_json = json.loads(raw_result)\n   329→        except Exception:\n   330→            fenced = re.findall(r\"```json\\s*(\\{.*?\\})\\s*```\", raw_result, flags=re.IGNORECASE | re.DOTALL)\n   331→            candidate_json = None\n   332→            if len(fenced) == 1:\n   333→                try:\n   334→                    candidate_json = json.loads(fenced[0])\n   335→                except Exception:\n   336→                    candidate_json = None\n   337→        candidate, compat_changed, degraded_contract = coerce_structured_output(candidate_json)\n   338→        if candidate is not None:\n   339→            normalization_source = \"result_json_fallback\"\n   340→            fallback_used = True\n   341→            degraded_contract = degraded_contract or \"structured_output missing; decoded JSON string from result\"\n   342→\n   343→    if candidate is None:\n   344→        return build_result(\n   345→            request,\n   346→            status=\"invalid_result\",\n   347→            exit_code=EXIT_INVALID_RESULT,\n   348→            summary=\"ACP adapter could not normalize Claude output to the structured contract\",\n   349→            verification_results=[\"structured output normalization failed\"],\n   350→            remaining_risks=[\"inspect claude-raw.json for schema drift\"],\n   351→            meta={\n   352→                \"lane\": \"acp\",\n   353→                \"transport_kind\": transport_kind,\n   354→                \"native_acp_available\": native_acp_available,\n   355→                \"session_id\": session_id,\n   356→                \"publishable\": False,\n   357→            },\n   358→        )\n   359→\n   360→    summary = candidate.get(\"summary\") or candidate.get(\"result\") or \"ACP adapter completed successfully\"\n   361→    meta = build_meta(\n   362→        init_event=init_event,\n   363→        result_event=result_event,\n   364→        session_id=session_id or result_event.get(\"session_id\") or (init_event or {}).get(\"session_id\"),\n   365→        transport_kind=transport_kind,\n   366→        native_acp_available=native_acp_available,\n   367→        normalization_source=normalization_source,\n   368→        fallback_used=fallback_used or compat_changed,\n   369→        raw_text=raw_text,\n   370→        degraded_contract=degraded_contract if (fallback_used or compat_changed) else None,\n   371→    )\n   372→    return build_result(\n   373→        request,\n   374→        status=\"success\",\n   375→        exit_code=EXIT_SUCCESS,\n   376→        summary=summary,\n   377→        changed_files=candidate.get(\"changed_files\") or request.get(\"target_paths\", []),\n   378→        verification_results=candidate.get(\"verification_results\") or request.get(\"verification_commands\", []),\n   379→        remaining_risks=candidate.get(\"remaining_risks\") or [],\n   380→        meta=meta,\n   381→    )\n   382→\n   383→\n   384→def write_session_manifest(session_path: Path, payload: dict[str, Any]) -> None:\n   385→    atomic_write_json(session_path, payload)\n   386→\n   387→\n   388→def invoke_claude_compat(\n   389→    request: dict,\n   390→    *,\n   391→    prompt: str,\n   392→    raw_path: Path,\n   393→    stdout_log: Path,\n   394→    stderr_log: Path,\n   395→    claude_bin: str,\n   396→    config: dict[str, Any],\n   397→    existing_session_id: str | None,\n   398→) -> tuple[int, str | None]:\n   399→    command = [\n   400→        claude_bin,\n   401→        \"-p\",\n   402→        \"--output-format\",\n   403→        \"json\",\n   404→        \"--permission-mode\",\n   405→        str(config.get(\"permission_mode_execute\") or \"bypassPermissions\"),\n   406→    ]\n   407→    model = str(config.get(\"model\") or \"\").strip()\n   408→    if model:\n   409→        command.extend([\"--model\", model])\n   410→    if bool(config.get(\"use_json_schema\", True)):\n   411→        command.extend([\"--json-schema\", STRUCTURED_SCHEMA_PATH.read_text(encoding=\"utf-8\")])\n   412→    if existing_session_id:\n   413→        command.extend([\"--resume\", existing_session_id])\n   414→    command.append(prompt)\n   415→    append_log(stdout_log, f\"[openclaw-acp] invoking compat transport: {' '.join(command[:-1])} <rendered-prompt>\")\n   416→    try:\n   417→        completed = subprocess.run(command, check=False, capture_output=True, text=True, timeout=int(config.get(\"timeout_sec\") or 900))\n   418→    except subprocess.TimeoutExpired as exc:\n   419→        append_log(stdout_log, exc.stdout or \"\")\n   420→        append_log(stderr_log, exc.stderr or \"\")\n   421→        raw_payload = {\n   422→            \"adapter\": \"openclaw-acp\",\n   423→            \"transport_kind\": \"claude_print_json_compat\",\n   424→            \"status\": \"timeout\",\n   425→            \"timeout_sec\": int(config.get(\"timeout_sec\") or 900),\n   426→            \"stdout\": exc.stdout or \"\",\n   427→            \"stderr\": exc.stderr or \"\",\n   428→            \"captured_at\": now_iso(),\n   429→        }\n   430→        atomic_write_json(raw_path, raw_payload)\n   431→        return 124, existing_session_id\n   432→\n   433→    append_log(stdout_log, completed.stdout)\n   434→    append_log(stderr_log, completed.stderr)\n   435→    raw_text = completed.stdout if completed.stdout.endswith(\"\\n\") else completed.stdout + \"\\n\"\n   436→    raw_path.write_text(raw_text, encoding=\"utf-8\")\n   437→    session_id = existing_session_id\n   438→    try:\n   439→        raw_payload = json.loads(completed.stdout)\n   440→    except Exception:\n   441→        raw_payload = {\n   442→            \"adapter\": \"openclaw-acp\",\n   443→            \"transport_kind\": \"claude_print_json_compat\",\n   444→            \"captured_at\": now_iso(),\n   445→            \"stdout\": completed.stdout,\n   446→            \"stderr\": completed.stderr,\n   447→            \"exit_code\": completed.returncode,\n   448→        }\n   449→        atomic_write_json(raw_path, raw_payload)\n   450→    else:\n   451→        init_event, result_event = extract_events(raw_payload)\n   452→        session_id = (result_event or {}).get(\"session_id\") or (init_event or {}).get(\"session_id\") or existing_session_id\n   453→        raw_path.write_text(json.dumps(raw_payload, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n   454→    return completed.returncode, session_id\n   455→\n   456→\n   457→def main() -> int:\n   458→    args = parse_args()\n   459→    request_path = Path(args.request)\n   460→    result_path = ensure_parent(Path(args.result))\n   461→    stdout_log = ensure_parent(Path(args.stdout_log))\n   462→    stderr_log = ensure_parent(Path(args.stderr_log))\n   463→    stdout_log.write_text(\"\", encoding=\"utf-8\")\n   464→    stderr_log.write_text(\"\", encoding=\"utf-8\")\n   465→\n   466→    try:\n   467→        request = load_json(request_path, default=None)\n   468→        if not isinstance(request, dict):\n   469→            raise ValueError(\"request payload must be an object\")\n   470→        ensure_schema_valid(request_path, \"execution-request\")\n   471→    except Exception as exc:  # noqa: BLE001\n   472→        atomic_write_json(\n   473→            result_path,\n   474→            build_result({}, status=\"invalid_request\", exit_code=EXIT_INVALID_REQUEST, summary=f\"invalid request: {exc}\", remaining_risks=[\"request validation failed\"]),\n   475→        )\n   476→        return EXIT_INVALID_REQUEST\n   477→\n   478→    raw_path = ensure_parent(resolve_workspace_path(request.get(\"raw_response_path\"), result_path.parent / \"claude-raw.json\"))\n   479→    prompt_path = ensure_parent(resolve_workspace_path(request.get(\"rendered_prompt_path\"), result_path.parent / \"rendered-prompt.txt\"))\n   480→    auth_status_path = ensure_parent(resolve_workspace_path(((request.get(\"auth_artifacts\") or {}).get(\"auth_status_path\")), result_path.parent / \"auth-status.json\"))\n   481→    auth_log_path = ensure_parent(resolve_workspace_path(((request.get(\"auth_artifacts\") or {}).get(\"auth_log_path\")), result_path.parent / \"auth-preflight.log\"))\n   482→    session_path = result_path.parent / \"acp-session.json\"\n   483→\n   484→    config = load_claude_code_config()\n   485→    claude_bin, claude_bin_source = resolve_claude_code_bin(config)\n   486→    claude_bin_path = shutil.which(claude_bin)\n   487→    native_acp_available, native_acp_reason = detect_native_acp_support(claude_bin) if claude_bin_path else (False, \"claude binary not found\")\n   488→    append_log(stdout_log, f\"[openclaw-acp] lane=acp dispatch_attempt={request.get('dispatch_attempt_id')}\")\n   489→    append_log(stdout_log, f\"[openclaw-acp] bin={claude_bin} source={claude_bin_source} resolved={claude_bin_path or '<missing>'}\")\n   490→    append_log(stdout_log, f\"[openclaw-acp] native_acp_available={str(native_acp_available).lower()}\")\n   491→    if native_acp_reason:\n   492→        append_log(stdout_log, f\"[openclaw-acp] native_acp_reason={native_acp_reason}\")\n   493→\n   494→    mock_mode = request.get(\"mock_mode\")\n   495→    explicit_mock = bool(mock_mode)\n   496→    if not claude_bin_path and not explicit_mock:\n   497→        result = build_result(\n   498→            request,\n   499→            status=\"runtime_error\",\n   500→            exit_code=EXIT_RUNTIME_ERROR,\n   501→            summary=\"ACP transport preflight failed: Claude binary not found\",\n   502→            verification_results=[\"acp_transport_preflight\"],\n   503→            remaining_risks=[f\"Claude binary unavailable: {claude_bin}\"],\n   504→            meta={\n   505→                \"lane\": \"acp\",\n   506→                \"failure_stage\": \"transport_preflight\",\n   507→                \"partial_execution\": False,\n   508→                \"side_effects_possible\": False,\n   509→                \"publishable\": False,\n   510→                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n   511→                \"native_acp_available\": native_acp_available,\n   512→            },\n   513→        )\n   514→        atomic_write_json(result_path, result)\n   515→        return EXIT_RUNTIME_ERROR\n   516→\n   517→    if args.dry_run:\n   518→        prompt = build_prompt(request, prompt_path)\n   519→        atomic_write_json(\n   520→            raw_path,\n   521→            {\n   522→                \"adapter\": \"openclaw-acp\",\n   523→                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n   524→                \"native_acp_available\": native_acp_available,\n   525→                \"captured_at\": now_iso(),\n   526→                \"prompt_preview\": prompt[:500],\n   527→            },\n   528→        )\n   529→        result = build_result(\n   530→            request,\n   531→            status=\"success\",\n   532→            exit_code=EXIT_SUCCESS,\n   533→            summary=\"dry-run completed; ACP adapter rendered prompt/settings without invoking Claude\",\n   534→            changed_files=request.get(\"target_paths\", []),\n   535→            verification_results=[\"dry-run\"],\n   536→            remaining_risks=[\"Claude execution skipped by --dry-run\"],\n   537→            meta={\n   538→                \"lane\": \"acp\",\n   539→                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n   540→                \"native_acp_available\": native_acp_available,\n   541→                \"publishable\": True,\n   542→            },\n   543→        )\n   544→        atomic_write_json(result_path, result)\n   545→        ensure_schema_valid(result_path, \"execution-result\")\n   546→        return EXIT_SUCCESS\n   547→\n   548→    if mock_mode in {\"auth_required\", \"acp_auth_required\"}:\n   549→        atomic_write_json(auth_status_path, {\"checked_at\": now_iso(), \"ok\": False, \"logged_in\": False})\n   550→        result = build_result(\n   551→            request,\n   552→            status=\"runtime_error\",\n   553→            exit_code=EXIT_RUNTIME_ERROR,\n   554→            summary=\"ACP auth required before execution can continue\",\n   555→            verification_results=[\"acp_session_start\"],\n   556→            remaining_risks=[\"Claude ACP auth unavailable\"],\n   557→            meta={\n   558→                \"result_code\": \"AUTH_REQUIRED\",\n   559→                \"lane\": \"acp\",\n   560→                \"failure_stage\": \"auth_preflight\",\n   561→                \"partial_execution\": False,\n   562→                \"side_effects_possible\": False,\n   563→                \"publishable\": False,\n   564→                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n   565→                \"native_acp_available\": native_acp_available,\n   566→            },\n   567→        )\n   568→        atomic_write_json(result_path, result)\n   569→        return EXIT_RUNTIME_ERROR\n   570→    if mock_mode in {\"acp_pre_session_failure\", \"pre_session_failure\"}:\n   571→        result = build_result(\n   572→            request,\n   573→            status=\"runtime_error\",\n   574→            exit_code=EXIT_RUNTIME_ERROR,\n   575→            summary=\"ACP session failed before execution started\",\n   576→            verification_results=[\"acp_session_start\"],\n   577→            remaining_risks=[\"ACP unavailable\"],\n   578→            meta={\n   579→                \"lane\": \"acp\",\n   580→                \"failure_stage\": \"session_start\",\n   581→                \"partial_execution\": False,\n   582→                \"side_effects_possible\": False,\n   583→                \"publishable\": False,\n   584→                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n   585→                \"native_acp_available\": native_acp_available,\n   586→            },\n   587→        )\n   588→        atomic_write_json(result_path, result)\n   589→        return EXIT_RUNTIME_ERROR\n   590→    if mock_mode in {\"acp_partial_write_failure\", \"partial_write_failure\"}:\n   591→        result = build_result(\n   592→            request,\n   593→            status=\"runtime_error\",\n   594→            exit_code=EXIT_RUNTIME_ERROR,\n   595→            summary=\"ACP failed after partial write execution\",\n   596→            changed_files=request.get(\"target_paths\", []),\n   597→            verification_results=[\"acp_session_start\", \"acp_execution_started\"],\n   598→            remaining_risks=[\"Partial execution may have side effects\"],\n   599→            meta={\n   600→                \"lane\": \"acp\",\n   601→                \"failure_stage\": \"execution\",\n   602→                \"partial_execution\": True,\n   603→                \"side_effects_possible\": True,\n   604→                \"publishable\": False,\n   605→                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n   606→                \"native_acp_available\": native_acp_available,\n   607→            },\n   608→        )\n   609→        atomic_write_json(result_path, result)\n   610→        return EXIT_RUNTIME_ERROR\n   611→\n   612→    if mock_mode == \"success\":\n   613→        result = build_result(\n   614→            request,\n   615→            status=\"success\",\n   616→            exit_code=EXIT_SUCCESS,\n   617→            summary=\"ACP preflight mock completed successfully\",\n   618→            changed_files=request.get(\"target_paths\", []),\n   619→            verification_results=request.get(\"verification_commands\", []),\n   620→            remaining_risks=[],\n   621→            meta={\n   622→                \"lane\": \"acp\",\n   623→                \"session_mode\": \"preflight_mock\",\n   624→                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n   625→                \"native_acp_available\": native_acp_available,\n   626→                \"publishable\": True,\n   627→            },\n   628→        )\n   629→        atomic_write_json(result_path, result)\n   630→        ensure_schema_valid(result_path, \"execution-result\")\n   631→        return EXIT_SUCCESS\n   632→\n   633→    auth_status = auth_preflight(claude_bin, auth_status_path, auth_log_path)\n   634→    if not auth_status.get(\"ok\"):\n   635→        result = build_result(\n   636→            request,\n   637→            status=\"runtime_error\",\n   638→            exit_code=EXIT_RUNTIME_ERROR,\n   639→            summary=\"ACP auth required before execution can continue\",\n   640→            verification_results=[\"acp_auth_preflight\"],\n   641→            remaining_risks=[\"Claude auth unavailable\"],\n   642→            meta={\n   643→                \"result_code\": \"AUTH_REQUIRED\",\n   644→                \"lane\": \"acp\",\n   645→                \"failure_stage\": \"auth_preflight\",\n   646→                \"partial_execution\": False,\n   647→                \"side_effects_possible\": False,\n   648→                \"publishable\": False,\n   649→                \"auth_status_path\": str(auth_status_path),\n   650→                \"auth_log_path\": str(auth_log_path),\n   651→                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n   652→                \"native_acp_available\": native_acp_available,\n   653→            },\n   654→        )\n   655→        atomic_write_json(result_path, result)\n   656→        ensure_schema_valid(result_path, \"execution-result\")\n   657→        return EXIT_RUNTIME_ERROR\n   658→\n   659→    existing_session = load_json(session_path, default={}) or {}\n   660→    existing_session_id = existing_session.get(\"session_id\") if isinstance(existing_session, dict) else None\n   661→    prompt = build_prompt(request, prompt_path)\n   662→    transport_kind = \"native_acp\" if native_acp_available else \"claude_print_json_compat\"\n   663→    append_log(stdout_log, f\"[openclaw-acp] transport_kind={transport_kind}\")\n   664→    if existing_session_id:\n   665→        append_log(stdout_log, f\"[openclaw-acp] resuming session_id={existing_session_id}\")\n   666→\n   667→    compat_exit, session_id = invoke_claude_compat(\n   668→        request,\n   669→        prompt=prompt,\n   670→        raw_path=raw_path,\n   671→        stdout_log=stdout_log,\n   672→        stderr_log=stderr_log,\n   673→        claude_bin=claude_bin,\n   674→        config=config,\n   675→        existing_session_id=existing_session_id,\n   676→    )\n   677→\n   678→    session_manifest = {\n   679→        \"task_id\": request.get(\"task_id\"),\n   680→        \"lane\": \"acp\",\n   681→        \"transport_kind\": transport_kind,\n   682→        \"native_acp_available\": native_acp_available,\n   683→        \"native_acp_reason\": native_acp_reason,\n   684→        \"session_id\": session_id,\n   685→        \"updated_at\": now_iso(),\n   686→    }\n   687→    write_session_manifest(session_path, session_manifest)\n   688→\n   689→    if compat_exit == 124:\n   690→        result = build_result(\n   691→            request,\n   692→            status=\"timeout\",\n   693→            exit_code=EXIT_TIMEOUT,\n   694→            summary=f\"ACP execution timed out after {int(config.get('timeout_sec') or 900)}s\",\n   695→            verification_results=[\"timeout\"],\n   696→            remaining_risks=[\"consider increasing timeout or simplifying the task\"],\n   697→            meta={\n   698→                \"lane\": \"acp\",\n   699→                \"transport_kind\": transport_kind,\n   700→                \"native_acp_available\": native_acp_available,\n   701→                \"session_id\": session_id,\n   702→                \"publishable\": False,\n   703→            },\n   704→        )\n   705→        atomic_write_json(result_path, result)\n   706→        ensure_schema_valid(result_path, \"execution-result\")\n   707→        return EXIT_TIMEOUT\n   708→\n   709→    if compat_exit != 0:\n   710→        raw_payload, raw_text = load_raw_json(raw_path)\n   711→        init_event, result_event = extract_events(raw_payload)\n   712→        result = build_result(\n   713→            request,\n   714→            status=\"runtime_error\",\n   715→            exit_code=EXIT_RUNTIME_ERROR,\n   716→            summary=f\"ACP executor failed with exit code {compat_exit}\",\n   717→            verification_results=[\"executor returned non-zero\"],\n   718→            remaining_risks=[\"inspect execution.stderr.log and claude-raw.json\"],\n   719→            meta=build_meta(\n   720→                init_event=init_event,\n   721→                result_event=result_event,\n   722→                session_id=session_id,\n   723→                transport_kind=transport_kind,\n   724→                native_acp_available=native_acp_available,\n   725→                normalization_source=\"raw_exit\",\n   726→                fallback_used=False,\n   727→                raw_text=raw_text,\n   728→                degraded_contract=None,\n   729→            ),\n   730→        )\n   731→        result[\"_meta\"][\"publishable\"] = False\n   732→        atomic_write_json(result_path, result)\n   733→        ensure_schema_valid(result_path, \"execution-result\")\n   734→        return EXIT_RUNTIME_ERROR\n   735→\n   736→    result = normalize_success_result(\n   737→        request,\n   738→        raw_path,\n   739→        session_id=session_id,\n   740→        transport_kind=transport_kind,\n   741→        native_acp_available=native_acp_available,\n   742→    )\n   743→    atomic_write_json(result_path, result)\n   744→    try:\n   745→        ensure_schema_valid(result_path, \"execution-result\")\n   746→    except Exception:\n   747→        return EXIT_INVALID_RESULT\n   748→    return int(result.get(\"exit_code\", EXIT_RUNTIME_ERROR))\n   749→\n   750→\n   751→if __name__ == \"__main__\":\n   752→    raise SystemExit(main())\n   753→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"44354d25-3932-4c1a-abfe-c68b7c0638cc","uuid":"06d8c6f9-ae50-44db-9482-4de7fe790dee","timestamp":"2026-03-22T07:43:49.998Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yusuke/.openclaw/workspace/.openclaw/scripts/run_claude_acp.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport hashlib\nimport json\nimport os\nimport re\nimport shutil\nimport subprocess\nimport sys\nfrom datetime import datetime, timezone\nfrom pathlib import Path\nfrom typing import Any\n\nROOT = Path(__file__).resolve().parents[1]\nWORKSPACE = ROOT.parent\nsys.path.insert(0, str(ROOT / \"scripts\"))\n\nfrom task_runtime import (  # noqa: E402\n    atomic_write_json,\n    atomic_write_text,\n    ensure_schema_valid,\n    load_claude_code_config,\n    load_json,\n    resolve_claude_code_bin,\n)\n\nEXIT_SUCCESS = 0\nEXIT_POLICY_BLOCKED = 10\nEXIT_TIMEOUT = 20\nEXIT_RUNTIME_ERROR = 30\nEXIT_INVALID_REQUEST = 40\nEXIT_INVALID_RESULT = 50\nSTRUCTURED_SCHEMA_PATH = ROOT / \"schemas\" / \"claude-structured-output.schema.json\"\n\n\ndef now_iso() -> str:\n    return datetime.now(timezone.utc).astimezone().isoformat(timespec=\"seconds\")\n\n\ndef parse_args() -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Contract-preserving ACP adapter for Claude Code\")\n    parser.add_argument(\"--request\", required=True)\n    parser.add_argument(\"--result\", required=True)\n    parser.add_argument(\"--stdout-log\", required=True)\n    parser.add_argument(\"--stderr-log\", required=True)\n    parser.add_argument(\"--dry-run\", action=\"store_true\")\n    return parser.parse_args()\n\n\ndef build_result(\n    request: dict,\n    *,\n    status: str,\n    exit_code: int,\n    summary: str,\n    changed_files: list[str] | None = None,\n    verification_results: list[str] | None = None,\n    remaining_risks: list[str] | None = None,\n    meta: dict | None = None,\n) -> dict:\n    payload = {\n        \"task_id\": request.get(\"task_id\", \"unknown\"),\n        \"status\": status,\n        \"executor\": \"claude-code\",\n        \"summary\": summary,\n        \"changed_files\": changed_files or [],\n        \"verification_results\": verification_results or [],\n        \"remaining_risks\": remaining_risks or [],\n        \"exit_code\": exit_code,\n        \"started_at\": request.get(\"started_at\") or now_iso(),\n        \"finished_at\": now_iso(),\n        \"dispatch_id\": request.get(\"dispatch_id\"),\n        \"raw_response_path\": str(Path(request.get(\"raw_response_path\") or (Path(request.get(\"context_pack_path\") or \".\").parent / \"claude-raw.json\"))),\n        \"rendered_prompt_path\": str(request.get(\"rendered_prompt_path\") or \"\"),\n    }\n    if meta:\n        payload[\"_meta\"] = meta\n    return payload\n\n\ndef ensure_parent(path: Path) -> Path:\n    path.parent.mkdir(parents=True, exist_ok=True)\n    return path\n\n\ndef resolve_workspace_path(value: str | None, fallback: Path) -> Path:\n    if not value:\n        return fallback\n    path = Path(value)\n    if not path.is_absolute():\n        path = WORKSPACE / path\n    return path\n\n\ndef append_log(path: Path, message: str) -> None:\n    with path.open(\"a\", encoding=\"utf-8\") as fh:\n        fh.write(message)\n        if not message.endswith(\"\\n\"):\n            fh.write(\"\\n\")\n\n\ndef build_prompt(request: dict, prompt_path: Path) -> str:\n    if prompt_path.exists():\n        return prompt_path.read_text(encoding=\"utf-8\")\n    context_text = \"\"\n    context_path = resolve_workspace_path(request.get(\"context_pack_path\"), prompt_path.parent / \"context-pack.md\")\n    if context_path.exists():\n        context_text = context_path.read_text(encoding=\"utf-8\").strip()\n    lines = [\n        f\"Task ID: {request.get('task_id', 'unknown')}\",\n        f\"Dispatch ID: {request.get('dispatch_id', '(none)')}\",\n        \"Execution lane: acp\",\n        \"\",\n        \"Return structured output that matches the provided JSON schema exactly.\",\n        \"Do not wrap the response in markdown fences.\",\n        \"\",\n        \"Task Summary:\",\n        request.get(\"task_summary\", \"\"),\n        \"\",\n        \"Constraints:\",\n    ]\n    constraints = request.get(\"constraints\") or [\"(none)\"]\n    lines.extend([f\"- {item}\" for item in constraints])\n    lines.extend([\"\", \"Target Paths:\"])\n    targets = request.get(\"target_paths\") or [\"(none)\"]\n    lines.extend([f\"- {item}\" for item in targets])\n    lines.extend([\"\", \"Verification Commands:\"])\n    commands = request.get(\"verification_commands\") or [\"(none)\"]\n    lines.extend([f\"- {item}\" for item in commands])\n    lines.extend([\"\", \"Review Focus:\"])\n    focus = request.get(\"review_focus\") or [\"(none)\"]\n    lines.extend([f\"- {item}\" for item in focus])\n    if context_text:\n        lines.extend([\"\", \"Context Pack:\", context_text])\n    prompt = \"\\n\".join(lines).rstrip() + \"\\n\"\n    atomic_write_text(prompt_path, prompt)\n    return prompt\n\n\ndef detect_native_acp_support(claude_bin: str) -> tuple[bool, str | None]:\n    try:\n        help_run = subprocess.run([claude_bin, \"--help\"], check=False, capture_output=True, text=True, timeout=15)\n    except Exception as exc:  # noqa: BLE001\n        return False, f\"help probe failed: {exc}\"\n    combined = f\"{help_run.stdout}\\n{help_run.stderr}\".lower()\n    commands_block = combined.split(\"commands:\", 1)[1] if \"commands:\" in combined else combined\n    if re.search(r\"(?m)^\\s*acp\\b\", commands_block):\n        return True, None\n    return False, \"claude CLI does not expose a native acp subcommand in this environment\"\n\n\ndef auth_preflight(claude_bin: str, auth_status_path: Path, auth_log_path: Path) -> dict[str, Any]:\n    started_at = now_iso()\n    command = [claude_bin, \"auth\", \"status\", \"--json\"]\n    completed = subprocess.run(command, check=False, capture_output=True, text=True)\n    parsed = None\n    parse_error = None\n    try:\n        parsed = json.loads(completed.stdout) if completed.stdout.strip() else None\n    except Exception as exc:  # noqa: BLE001\n        parse_error = str(exc)\n    logged_in = False\n    auth_method = None\n    user_email = None\n    if isinstance(parsed, dict):\n        logged_in = bool(parsed.get(\"loggedIn\") or parsed.get(\"authenticated\") or parsed.get(\"ok\"))\n        auth_method = parsed.get(\"authMethod\") or parsed.get(\"method\")\n        user_email = parsed.get(\"email\") or parsed.get(\"userEmail\")\n    log_lines = [\n        f\"[{started_at}] command={' '.join(command)}\",\n        f\"exit_code={completed.returncode}\",\n        \"--- stdout ---\",\n        completed.stdout.rstrip(),\n        \"--- stderr ---\",\n        completed.stderr.rstrip(),\n    ]\n    atomic_write_text(auth_log_path, \"\\n\".join(log_lines).rstrip() + \"\\n\")\n    payload = {\n        \"checked_at\": now_iso(),\n        \"ok\": completed.returncode == 0 and logged_in,\n        \"cli\": claude_bin,\n        \"command\": command,\n        \"exit_code\": completed.returncode,\n        \"logged_in\": logged_in,\n        \"auth_method\": auth_method,\n        \"user_email\": user_email,\n        \"stderr\": completed.stderr,\n    }\n    if isinstance(parsed, dict):\n        payload[\"stdout\"] = parsed\n    if parse_error:\n        payload[\"message\"] = f\"stdout JSON parse failed: {parse_error}\"\n    atomic_write_json(auth_status_path, payload)\n    runtime_cache_path = ROOT / \"runtime\" / \"auth\" / \"latest-status.json\"\n    ensure_parent(runtime_cache_path)\n    atomic_write_json(runtime_cache_path, payload)\n    return payload\n\n\ndef extract_events(payload: Any) -> tuple[dict[str, Any] | None, dict[str, Any] | None]:\n    init_event = None\n    result_event = None\n    if isinstance(payload, list):\n        for item in payload:\n            if isinstance(item, dict) and item.get(\"type\") == \"system\" and item.get(\"subtype\") == \"init\":\n                init_event = item\n        for item in reversed(payload):\n            if isinstance(item, dict) and item.get(\"type\") == \"result\":\n                result_event = item\n                break\n    elif isinstance(payload, dict) and payload.get(\"type\") == \"result\":\n        result_event = payload\n    return init_event, result_event\n\n\ndef load_raw_json(raw_path: Path) -> tuple[Any, str]:\n    raw_text = raw_path.read_text(encoding=\"utf-8\") if raw_path.exists() else \"\"\n    if not raw_text.strip():\n        return None, raw_text\n    try:\n        return json.loads(raw_text), raw_text\n    except Exception:\n        return None, raw_text\n\n\ndef build_meta(\n    *,\n    init_event: dict[str, Any] | None,\n    result_event: dict[str, Any] | None,\n    session_id: str | None,\n    transport_kind: str,\n    native_acp_available: bool,\n    normalization_source: str,\n    fallback_used: bool,\n    raw_text: str,\n    retry_count: int = 0,\n    degraded_contract: str | None = None,\n) -> dict[str, Any]:\n    meta: dict[str, Any] = {\n        \"lane\": \"acp\",\n        \"transport_kind\": transport_kind,\n        \"native_acp_available\": native_acp_available,\n        \"session_id\": session_id,\n        \"normalization_source\": normalization_source,\n        \"fallback_used\": fallback_used,\n        \"retry_count\": retry_count,\n        \"raw_sha256\": hashlib.sha256(raw_text.encode(\"utf-8\")).hexdigest(),\n        \"publishable\": True,\n    }\n    if degraded_contract:\n        meta[\"degraded_contract\"] = degraded_contract\n    if isinstance(result_event, dict):\n        for key in (\"modelUsage\", \"total_cost_usd\", \"duration_ms\", \"duration_api_ms\", \"num_turns\", \"stop_reason\", \"permission_denials\", \"is_error\"):\n            if key in result_event:\n                meta[key] = result_event.get(key)\n    if isinstance(init_event, dict):\n        meta[\"cli_version\"] = init_event.get(\"claude_code_version\")\n        meta[\"init\"] = {\n            key: init_event.get(key)\n            for key in (\"session_id\", \"model\", \"permissionMode\", \"tools\", \"claude_code_version\")\n            if key in init_event\n        }\n    else:\n        meta[\"cli_version\"] = None\n    return {key: value for key, value in meta.items() if value is not None}\n\n\ndef coerce_structured_output(candidate: Any) -> tuple[dict[str, Any] | None, bool, str | None]:\n    if isinstance(candidate, dict):\n        required = {\"result\", \"changed_files\", \"verification_results\", \"remaining_risks\"}\n        if required.issubset(candidate.keys()):\n            return candidate, False, None\n        compat = dict(candidate)\n        changed = False\n        if \"result\" not in compat and isinstance(compat.get(\"summary\"), str):\n            compat[\"result\"] = compat[\"summary\"]\n            changed = True\n        if \"changed_files\" not in compat:\n            compat[\"changed_files\"] = []\n            changed = True\n        if \"verification_results\" not in compat:\n            compat[\"verification_results\"] = []\n            changed = True\n        if \"remaining_risks\" not in compat:\n            compat[\"remaining_risks\"] = []\n            changed = True\n        if required.issubset(compat.keys()):\n            return compat, changed, \"compatibility normalization filled missing structured output fields\" if changed else None\n    return None, False, None\n\n\ndef normalize_success_result(\n    request: dict,\n    raw_path: Path,\n    *,\n    session_id: str | None,\n    transport_kind: str,\n    native_acp_available: bool,\n) -> dict:\n    raw_payload, raw_text = load_raw_json(raw_path)\n    init_event, result_event = extract_events(raw_payload)\n    if not isinstance(result_event, dict):\n        return build_result(\n            request,\n            status=\"invalid_result\",\n            exit_code=EXIT_INVALID_RESULT,\n            summary=\"ACP adapter could not locate result envelope\",\n            verification_results=[\"result envelope missing\"],\n            remaining_risks=[\"inspect claude-raw.json for output drift\"],\n            meta={\n                \"lane\": \"acp\",\n                \"transport_kind\": transport_kind,\n                \"native_acp_available\": native_acp_available,\n                \"session_id\": session_id,\n                \"publishable\": False,\n            },\n        )\n\n    structured_output = result_event.get(\"structured_output\")\n    candidate, compat_changed, degraded_contract = coerce_structured_output(structured_output)\n    normalization_source = \"structured_output\"\n    fallback_used = False\n    if candidate is None and isinstance(result_event.get(\"result\"), str):\n        raw_result = result_event.get(\"result\")\n        try:\n            candidate_json = json.loads(raw_result)\n        except Exception:\n            fenced = re.findall(r\"```json\\s*(\\{.*?\\})\\s*```\", raw_result, flags=re.IGNORECASE | re.DOTALL)\n            candidate_json = None\n            if len(fenced) == 1:\n                try:\n                    candidate_json = json.loads(fenced[0])\n                except Exception:\n                    candidate_json = None\n        candidate, compat_changed, degraded_contract = coerce_structured_output(candidate_json)\n        if candidate is not None:\n            normalization_source = \"result_json_fallback\"\n            fallback_used = True\n            degraded_contract = degraded_contract or \"structured_output missing; decoded JSON string from result\"\n\n    if candidate is None:\n        return build_result(\n            request,\n            status=\"invalid_result\",\n            exit_code=EXIT_INVALID_RESULT,\n            summary=\"ACP adapter could not normalize Claude output to the structured contract\",\n            verification_results=[\"structured output normalization failed\"],\n            remaining_risks=[\"inspect claude-raw.json for schema drift\"],\n            meta={\n                \"lane\": \"acp\",\n                \"transport_kind\": transport_kind,\n                \"native_acp_available\": native_acp_available,\n                \"session_id\": session_id,\n                \"publishable\": False,\n            },\n        )\n\n    summary = candidate.get(\"summary\") or candidate.get(\"result\") or \"ACP adapter completed successfully\"\n    meta = build_meta(\n        init_event=init_event,\n        result_event=result_event,\n        session_id=session_id or result_event.get(\"session_id\") or (init_event or {}).get(\"session_id\"),\n        transport_kind=transport_kind,\n        native_acp_available=native_acp_available,\n        normalization_source=normalization_source,\n        fallback_used=fallback_used or compat_changed,\n        raw_text=raw_text,\n        degraded_contract=degraded_contract if (fallback_used or compat_changed) else None,\n    )\n    return build_result(\n        request,\n        status=\"success\",\n        exit_code=EXIT_SUCCESS,\n        summary=summary,\n        changed_files=candidate.get(\"changed_files\") or request.get(\"target_paths\", []),\n        verification_results=candidate.get(\"verification_results\") or request.get(\"verification_commands\", []),\n        remaining_risks=candidate.get(\"remaining_risks\") or [],\n        meta=meta,\n    )\n\n\ndef write_session_manifest(session_path: Path, payload: dict[str, Any]) -> None:\n    atomic_write_json(session_path, payload)\n\n\ndef invoke_claude_compat(\n    request: dict,\n    *,\n    prompt: str,\n    raw_path: Path,\n    stdout_log: Path,\n    stderr_log: Path,\n    claude_bin: str,\n    config: dict[str, Any],\n    existing_session_id: str | None,\n) -> tuple[int, str | None]:\n    command = [\n        claude_bin,\n        \"-p\",\n        \"--output-format\",\n        \"json\",\n        \"--permission-mode\",\n        str(config.get(\"permission_mode_execute\") or \"bypassPermissions\"),\n    ]\n    model = str(config.get(\"model\") or \"\").strip()\n    if model:\n        command.extend([\"--model\", model])\n    if bool(config.get(\"use_json_schema\", True)):\n        command.extend([\"--json-schema\", STRUCTURED_SCHEMA_PATH.read_text(encoding=\"utf-8\")])\n    if existing_session_id:\n        command.extend([\"--resume\", existing_session_id])\n    command.append(prompt)\n    append_log(stdout_log, f\"[openclaw-acp] invoking compat transport: {' '.join(command[:-1])} <rendered-prompt>\")\n    try:\n        completed = subprocess.run(command, check=False, capture_output=True, text=True, timeout=int(config.get(\"timeout_sec\") or 900))\n    except subprocess.TimeoutExpired as exc:\n        append_log(stdout_log, exc.stdout or \"\")\n        append_log(stderr_log, exc.stderr or \"\")\n        raw_payload = {\n            \"adapter\": \"openclaw-acp\",\n            \"transport_kind\": \"claude_print_json_compat\",\n            \"status\": \"timeout\",\n            \"timeout_sec\": int(config.get(\"timeout_sec\") or 900),\n            \"stdout\": exc.stdout or \"\",\n            \"stderr\": exc.stderr or \"\",\n            \"captured_at\": now_iso(),\n        }\n        atomic_write_json(raw_path, raw_payload)\n        return 124, existing_session_id\n\n    append_log(stdout_log, completed.stdout)\n    append_log(stderr_log, completed.stderr)\n    raw_text = completed.stdout if completed.stdout.endswith(\"\\n\") else completed.stdout + \"\\n\"\n    raw_path.write_text(raw_text, encoding=\"utf-8\")\n    session_id = existing_session_id\n    try:\n        raw_payload = json.loads(completed.stdout)\n    except Exception:\n        raw_payload = {\n            \"adapter\": \"openclaw-acp\",\n            \"transport_kind\": \"claude_print_json_compat\",\n            \"captured_at\": now_iso(),\n            \"stdout\": completed.stdout,\n            \"stderr\": completed.stderr,\n            \"exit_code\": completed.returncode,\n        }\n        atomic_write_json(raw_path, raw_payload)\n    else:\n        init_event, result_event = extract_events(raw_payload)\n        session_id = (result_event or {}).get(\"session_id\") or (init_event or {}).get(\"session_id\") or existing_session_id\n        raw_path.write_text(json.dumps(raw_payload, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n    return completed.returncode, session_id\n\n\ndef main() -> int:\n    args = parse_args()\n    request_path = Path(args.request)\n    result_path = ensure_parent(Path(args.result))\n    stdout_log = ensure_parent(Path(args.stdout_log))\n    stderr_log = ensure_parent(Path(args.stderr_log))\n    stdout_log.write_text(\"\", encoding=\"utf-8\")\n    stderr_log.write_text(\"\", encoding=\"utf-8\")\n\n    try:\n        request = load_json(request_path, default=None)\n        if not isinstance(request, dict):\n            raise ValueError(\"request payload must be an object\")\n        ensure_schema_valid(request_path, \"execution-request\")\n    except Exception as exc:  # noqa: BLE001\n        atomic_write_json(\n            result_path,\n            build_result({}, status=\"invalid_request\", exit_code=EXIT_INVALID_REQUEST, summary=f\"invalid request: {exc}\", remaining_risks=[\"request validation failed\"]),\n        )\n        return EXIT_INVALID_REQUEST\n\n    raw_path = ensure_parent(resolve_workspace_path(request.get(\"raw_response_path\"), result_path.parent / \"claude-raw.json\"))\n    prompt_path = ensure_parent(resolve_workspace_path(request.get(\"rendered_prompt_path\"), result_path.parent / \"rendered-prompt.txt\"))\n    auth_status_path = ensure_parent(resolve_workspace_path(((request.get(\"auth_artifacts\") or {}).get(\"auth_status_path\")), result_path.parent / \"auth-status.json\"))\n    auth_log_path = ensure_parent(resolve_workspace_path(((request.get(\"auth_artifacts\") or {}).get(\"auth_log_path\")), result_path.parent / \"auth-preflight.log\"))\n    session_path = result_path.parent / \"acp-session.json\"\n\n    config = load_claude_code_config()\n    claude_bin, claude_bin_source = resolve_claude_code_bin(config)\n    claude_bin_path = shutil.which(claude_bin)\n    native_acp_available, native_acp_reason = detect_native_acp_support(claude_bin) if claude_bin_path else (False, \"claude binary not found\")\n    append_log(stdout_log, f\"[openclaw-acp] lane=acp dispatch_attempt={request.get('dispatch_attempt_id')}\")\n    append_log(stdout_log, f\"[openclaw-acp] bin={claude_bin} source={claude_bin_source} resolved={claude_bin_path or '<missing>'}\")\n    append_log(stdout_log, f\"[openclaw-acp] native_acp_available={str(native_acp_available).lower()}\")\n    if native_acp_reason:\n        append_log(stdout_log, f\"[openclaw-acp] native_acp_reason={native_acp_reason}\")\n\n    mock_mode = request.get(\"mock_mode\")\n    explicit_mock = bool(mock_mode)\n    if not claude_bin_path and not explicit_mock:\n        result = build_result(\n            request,\n            status=\"runtime_error\",\n            exit_code=EXIT_RUNTIME_ERROR,\n            summary=\"ACP transport preflight failed: Claude binary not found\",\n            verification_results=[\"acp_transport_preflight\"],\n            remaining_risks=[f\"Claude binary unavailable: {claude_bin}\"],\n            meta={\n                \"lane\": \"acp\",\n                \"failure_stage\": \"transport_preflight\",\n                \"partial_execution\": False,\n                \"side_effects_possible\": False,\n                \"publishable\": False,\n                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n                \"native_acp_available\": native_acp_available,\n            },\n        )\n        atomic_write_json(result_path, result)\n        return EXIT_RUNTIME_ERROR\n\n    if args.dry_run:\n        prompt = build_prompt(request, prompt_path)\n        atomic_write_json(\n            raw_path,\n            {\n                \"adapter\": \"openclaw-acp\",\n                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n                \"native_acp_available\": native_acp_available,\n                \"captured_at\": now_iso(),\n                \"prompt_preview\": prompt[:500],\n            },\n        )\n        result = build_result(\n            request,\n            status=\"success\",\n            exit_code=EXIT_SUCCESS,\n            summary=\"dry-run completed; ACP adapter rendered prompt/settings without invoking Claude\",\n            changed_files=request.get(\"target_paths\", []),\n            verification_results=[\"dry-run\"],\n            remaining_risks=[\"Claude execution skipped by --dry-run\"],\n            meta={\n                \"lane\": \"acp\",\n                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n                \"native_acp_available\": native_acp_available,\n                \"publishable\": True,\n            },\n        )\n        atomic_write_json(result_path, result)\n        ensure_schema_valid(result_path, \"execution-result\")\n        return EXIT_SUCCESS\n\n    if mock_mode in {\"auth_required\", \"acp_auth_required\"}:\n        atomic_write_json(auth_status_path, {\"checked_at\": now_iso(), \"ok\": False, \"logged_in\": False})\n        result = build_result(\n            request,\n            status=\"runtime_error\",\n            exit_code=EXIT_RUNTIME_ERROR,\n            summary=\"ACP auth required before execution can continue\",\n            verification_results=[\"acp_session_start\"],\n            remaining_risks=[\"Claude ACP auth unavailable\"],\n            meta={\n                \"result_code\": \"AUTH_REQUIRED\",\n                \"lane\": \"acp\",\n                \"failure_stage\": \"auth_preflight\",\n                \"partial_execution\": False,\n                \"side_effects_possible\": False,\n                \"publishable\": False,\n                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n                \"native_acp_available\": native_acp_available,\n            },\n        )\n        atomic_write_json(result_path, result)\n        return EXIT_RUNTIME_ERROR\n    if mock_mode in {\"acp_pre_session_failure\", \"pre_session_failure\"}:\n        result = build_result(\n            request,\n            status=\"runtime_error\",\n            exit_code=EXIT_RUNTIME_ERROR,\n            summary=\"ACP session failed before execution started\",\n            verification_results=[\"acp_session_start\"],\n            remaining_risks=[\"ACP unavailable\"],\n            meta={\n                \"lane\": \"acp\",\n                \"failure_stage\": \"session_start\",\n                \"partial_execution\": False,\n                \"side_effects_possible\": False,\n                \"publishable\": False,\n                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n                \"native_acp_available\": native_acp_available,\n            },\n        )\n        atomic_write_json(result_path, result)\n        return EXIT_RUNTIME_ERROR\n    if mock_mode in {\"acp_partial_write_failure\", \"partial_write_failure\"}:\n        result = build_result(\n            request,\n            status=\"runtime_error\",\n            exit_code=EXIT_RUNTIME_ERROR,\n            summary=\"ACP failed after partial write execution\",\n            changed_files=request.get(\"target_paths\", []),\n            verification_results=[\"acp_session_start\", \"acp_execution_started\"],\n            remaining_risks=[\"Partial execution may have side effects\"],\n            meta={\n                \"lane\": \"acp\",\n                \"failure_stage\": \"execution\",\n                \"partial_execution\": True,\n                \"side_effects_possible\": True,\n                \"publishable\": False,\n                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n                \"native_acp_available\": native_acp_available,\n            },\n        )\n        atomic_write_json(result_path, result)\n        return EXIT_RUNTIME_ERROR\n\n    if mock_mode == \"success\":\n        result = build_result(\n            request,\n            status=\"success\",\n            exit_code=EXIT_SUCCESS,\n            summary=\"ACP preflight mock completed successfully\",\n            changed_files=request.get(\"target_paths\", []),\n            verification_results=request.get(\"verification_commands\", []),\n            remaining_risks=[],\n            meta={\n                \"lane\": \"acp\",\n                \"session_mode\": \"preflight_mock\",\n                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n                \"native_acp_available\": native_acp_available,\n                \"publishable\": True,\n            },\n        )\n        atomic_write_json(result_path, result)\n        ensure_schema_valid(result_path, \"execution-result\")\n        return EXIT_SUCCESS\n\n    auth_status = auth_preflight(claude_bin, auth_status_path, auth_log_path)\n    if not auth_status.get(\"ok\"):\n        result = build_result(\n            request,\n            status=\"runtime_error\",\n            exit_code=EXIT_RUNTIME_ERROR,\n            summary=\"ACP auth required before execution can continue\",\n            verification_results=[\"acp_auth_preflight\"],\n            remaining_risks=[\"Claude auth unavailable\"],\n            meta={\n                \"result_code\": \"AUTH_REQUIRED\",\n                \"lane\": \"acp\",\n                \"failure_stage\": \"auth_preflight\",\n                \"partial_execution\": False,\n                \"side_effects_possible\": False,\n                \"publishable\": False,\n                \"auth_status_path\": str(auth_status_path),\n                \"auth_log_path\": str(auth_log_path),\n                \"transport_kind\": \"native_acp\" if native_acp_available else \"claude_print_json_compat\",\n                \"native_acp_available\": native_acp_available,\n            },\n        )\n        atomic_write_json(result_path, result)\n        ensure_schema_valid(result_path, \"execution-result\")\n        return EXIT_RUNTIME_ERROR\n\n    existing_session = load_json(session_path, default={}) or {}\n    existing_session_id = existing_session.get(\"session_id\") if isinstance(existing_session, dict) else None\n    prompt = build_prompt(request, prompt_path)\n    transport_kind = \"native_acp\" if native_acp_available else \"claude_print_json_compat\"\n    append_log(stdout_log, f\"[openclaw-acp] transport_kind={transport_kind}\")\n    if existing_session_id:\n        append_log(stdout_log, f\"[openclaw-acp] resuming session_id={existing_session_id}\")\n\n