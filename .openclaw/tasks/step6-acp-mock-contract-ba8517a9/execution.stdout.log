manual\")\n   347→        updated_review = load_json(paths[\"review\"])\n   348→        self.assertTrue(updated_review[\"publishable\"])\n   349→        self.assertFalse(updated_review[\"requires_manual_review\"])\n   350→        self.assertEqual(updated_review[\"publish_recommendation\"], \"publish\")\n   351→\n   352→    def test_invalid_queue_artifact_fails_safe_to_review_failed(self) -> None:\n   353→        task_id = self.make_id(\"invalid-artifact\")\n   354→        route = self.route_payload(task_id, route_decision_id=\"route-invalid\")\n   355→        dispatch = self.dispatch_payload(task_id, dispatch_id=\"dispatch-invalid\")\n   356→        result = self.result_payload(task_id, status=\"runtime_error\", exit_code=30, result_code=\"AUTH_REQUIRED\")\n   357→        review = self.review_payload(task_id, publish_recommendation=\"hold\", publishable=False, requires_manual_review=False, result_classification=\"auth_required\")\n   358→        paths = self.seed_task(task_id, state_name=\"AUTH_REQUIRED\", route=route, dispatch=dispatch, result=result, review=review)\n   359→        runtime_entry = ROOT / \"runtime\" / \"queue\" / \"waiting_auth\" / f\"{task_id}.json\"\n   360→        runtime_entry.write_text(\"{not-json\\n\", encoding=\"utf-8\")\n   361→\n   362→        rebalance = self.run_script(str(SCRIPTS / \"rebalance_queue.py\"), \"--task-id\", task_id)\n   363→        self.assertEqual(rebalance[\"results\"][0][\"action\"], \"invalid\")\n   364→        state = load_json(paths[\"state\"])\n   365→        self.assertEqual(state[\"state\"], \"REVIEW_FAILED\")\n   366→        review_after = load_json(paths[\"review\"])\n   367→        self.assertEqual(review_after[\"result_classification\"], \"queue_artifact_invalid\")\n   368→        self.assertFalse(runtime_entry.exists())\n   369→\n   370→    def test_duplicate_rebalance_is_deduped(self) -> None:\n   371→        task_id = self.make_id(\"dedupe\")\n   372→        route = self.route_payload(task_id, route_decision_id=\"route-dedupe\")\n   373→        dispatch = self.dispatch_payload(task_id, dispatch_id=\"dispatch-dedupe\")\n   374→        result = self.result_payload(task_id, status=\"runtime_error\", exit_code=30, result_code=\"AUTH_REQUIRED\")\n   375→        review = self.review_payload(task_id, publish_recommendation=\"hold\", publishable=False, requires_manual_review=False, result_classification=\"auth_required\")\n   376→        paths = self.seed_task(task_id, state_name=\"AUTH_REQUIRED\", route=route, dispatch=dispatch, result=result, review=review)\n   377→        lock_path = paths[\"dir\"] / \".lock\"\n   378→        lock_path.write_text(\"held by test\\n\", encoding=\"utf-8\")\n   379→        try:\n   380→            rebalance = self.run_script(str(SCRIPTS / \"rebalance_queue.py\"), \"--task-id\", task_id)\n   381→        finally:\n   382→            lock_path.unlink(missing_ok=True)\n   383→        self.assertEqual(rebalance[\"results\"][0][\"action\"], \"skipped_locked\")\n   384→        self.assertEqual(load_json(paths[\"state\"])[\"state\"], \"AUTH_REQUIRED\")\n   385→\n   386→    def test_resume_does_not_redispatch_existing_dispatch(self) -> None:\n   387→        task_id = self.make_id(\"resume-no-redispatch\")\n   388→        route = self.route_payload(task_id, route_decision_id=\"route-no-redispatch\")\n   389→        dispatch = self.dispatch_payload(task_id, dispatch_id=\"dispatch-no-redispatch\")\n   390→        paths = self.seed_task(task_id, state_name=\"READY_FOR_EXECUTION\", route=route, dispatch=dispatch)\n   391→        before = load_json(paths[\"dispatch\"])\n   392→\n   393→        subprocess.run([\n   394→            \"python3\",\n   395→            str(SCRIPTS / \"execute_task.py\"),\n   396→            \"--task-id\",\n   397→            task_id,\n   398→            \"--task-file\",\n   399→            str(paths[\"task\"]),\n   400→        ], cwd=str(WORKSPACE), check=True)\n   401→\n   402→        after = load_json(paths[\"dispatch\"])\n   403→        self.assertEqual(after[\"dispatch_id\"], before[\"dispatch_id\"])\n   404→        state = load_json(paths[\"state\"])\n   405→        self.assertEqual(state[\"dispatch_id\"], \"dispatch-no-redispatch\")\n   406→        self.assertEqual(state[\"route_decision_id\"], \"route-no-redispatch\")\n   407→\n   408→    def test_plan_only_auth_ng_defaults_to_waiting_auth_and_preprocess_exception_marks_context_pack(self) -> None:\n   409→        assignment = {\n   410→            \"task_id\": \"t-dispatch-auth\",\n   411→            \"lead_role\": \"engineering\",\n   412→            \"advisory_subroles\": [],\n   413→            \"active_subroles\": [],\n   414→            \"mandatory_review_roles\": [],\n   415→        }\n   416→        auth_ng_snapshot = ({\n   417→            \"healthy\": True,\n   418→            \"remaining_requests_ratio\": 0.8,\n   419→            \"remaining_tokens_ratio\": 0.8,\n   420→            \"usage_pressure\": 0.1,\n   421→            \"cost_pressure\": 0.1,\n   422→            \"hard_blocked\": False,\n   423→            \"captured_at\": \"2026-03-22T13:02:00+09:00\",\n   424→            \"source\": \"test\",\n   425→        }, {\n   426→            \"healthy\": True,\n   427→            \"acp_healthy\": True,\n   428→            \"cli_healthy\": True,\n   429→            \"cli_backend_healthy\": True,\n   430→            \"auth_ok\": False,\n   431→            \"rpm_pressure\": 0.1,\n   432→            \"itpm_pressure\": 0.1,\n   433→            \"otpm_pressure\": 0.1,\n   434→            \"spend_pressure\": 0.1,\n   435→            \"retry_after_sec\": 0,\n   436→            \"hard_blocked\": False,\n   437→            \"captured_at\": \"2026-03-22T13:02:00+09:00\",\n   438→            \"source\": \"test\",\n   439→        })\n   440→\n   441→        task_default = {\n   442→            \"task_id\": self.make_id(\"plan-auth-default\"),\n   443→            \"task\": \"Implement adapter change\",\n   444→            \"requested_paths\": [\".openclaw/scripts/task_runtime.py\", \".openclaw/scripts/rebalance_queue.py\"],\n   445→            \"constraints\": [],\n   446→            \"verification_commands\": [\"python3 -m unittest\"],\n   447→            \"review_focus\": [\"correctness\"],\n   448→            \"requested_actions\": [\"edit\"],\n   449→            \"requested_route\": \"claude-code\",\n   450→        }\n   451→        with mock.patch(\"dispatch_task.refresh_provider_snapshots\", return_value=auth_ng_snapshot):\n   452→            plan_default = build_dispatch_plan(task_default, assignment)\n   453→        self.assertEqual(plan_default[\"execution_mode\"], \"plan_only\")\n   454→        self.assertTrue(plan_default[\"auth_blocked\"])\n   455→        self.assertFalse(plan_default[\"pre_auth_openclaw_phase\"])\n   456→        self.assertEqual(plan_default[\"queue_reason\"], \"waiting_auth\")\n   457→\n   458→        task_exception = {\n   459→            **task_default,\n   460→            \"task_id\": self.make_id(\"plan-auth-exception\"),\n   461→            \"task\": \"Implement adapter change and prepare docs draft\",\n   462→            \"constraints\": [\"prepare context pack and docs draft before Claude resumes\"],\n   463→            \"review_focus\": [\"documentation\"],\n   464→        }\n   465→        with mock.patch(\"dispatch_task.refresh_provider_snapshots\", return_value=auth_ng_snapshot):\n   466→            plan_exception = build_dispatch_plan(task_exception, assignment)\n   467→        self.assertTrue(plan_exception[\"pre_auth_openclaw_phase\"])\n   468→\n   469→        task_id = self.make_id(\"plan-auth-runtime\")\n   470→        fake_plan = self.dispatch_payload(\n   471→            task_id,\n   472→            dispatch_id=\"dispatch-auth-runtime\",\n   473→            execution_mode=\"plan_only\",\n   474→            selected_provider=\"claude_code\",\n   475→            selected_executor=\"claude-code\",\n   476→            queue_reason=\"waiting_auth\",\n   47