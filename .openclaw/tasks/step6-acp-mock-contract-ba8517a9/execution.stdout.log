alid_queue_artifact,\n    18→    load_json,\n    19→    now_iso,\n    20→    read_queue_artifact,\n    21→    sync_queue_for_task,\n    22→    task_lock,\n    23→    task_paths,\n    24→    update_state,\n    25→    write_runtime_metrics,\n    26→)\n    27→\n    28→AUTH_RUNTIME_PATH = ROOT / \"runtime\" / \"auth\" / \"latest-status.json\"\n    29→CAPACITY_RUNTIME_PATH = ROOT / \"runtime\" / \"capacity\" / \"latest-capacity.json\"\n    30→\n    31→\n    32→def parse_args() -> argparse.Namespace:\n    33→    parser = argparse.ArgumentParser(description=\"Re-evaluate queued OpenClaw tasks\")\n    34→    parser.add_argument(\"--task-id\")\n    35→    parser.add_argument(\"--reason\", choices=list(QUEUE_REASONS))\n    36→    return parser.parse_args()\n    37→\n    38→\n    39→def iter_queue_entries(task_id: str | None = None, reason: str | None = None) -> Iterable[Path]:\n    40→    reasons = [reason] if reason else list(QUEUE_REASONS)\n    41→    for queue_reason in reasons:\n    42→        queue_dir = ROOT / \"runtime\" / \"queue\" / queue_reason\n    43→        if not queue_dir.exists():\n    44→            continue\n    45→        for path in sorted(queue_dir.glob(\"*.json\")):\n    46→            if task_id and path.stem != task_id:\n    47→                continue\n    48→            yield path\n    49→\n    50→\n    51→def auth_recovered() -> bool:\n    52→    status = load_json(AUTH_RUNTIME_PATH, default={}) or {}\n    53→    stdout = status.get(\"stdout\") if isinstance(status.get(\"stdout\"), dict) else {}\n    54→    return bool(status.get(\"ok\")) and bool(\n    55→        status.get(\"logged_in\")\n    56→        or status.get(\"auth_ok\")\n    57→        or stdout.get(\"loggedIn\")\n    58→    )\n    59→\n    60→\n    61→def capacity_recovered(dispatch: Dict[str, Any]) -> bool:\n    62→    snapshot = load_json(CAPACITY_RUNTIME_PATH, default={}) or {}\n    63→    providers = snapshot.get(\"providers\") if isinstance(snapshot.get(\"providers\"), dict) else {}\n    64→    if not providers:\n    65→        return False\n    66→    policy = load_json_like(CONFIG_ROOT / \"capacity-policy.yaml\")\n    67→    selected_provider = str(dispatch.get(\"selected_provider\") or \"\")\n    68→    if selected_provider == \"claude_code\":\n    69→        provider = providers.get(\"claude_code\") or {}\n    70→        return bool(provider) and pressure_level_claude(provider, policy) == \"normal\"\n    71→    if selected_provider == \"openclaw\":\n    72→        provider = providers.get(\"openclaw\") or {}\n    73→        return bool(provider) and pressure_level_openclaw(provider, policy) == \"normal\"\n    74→    openclaw = providers.get(\"openclaw\") or {}\n    75→    claude = providers.get(\"claude_code\") or {}\n    76→    return bool(openclaw and claude) and pressure_level_openclaw(openclaw, policy) == \"normal\" and pressure_level_claude(claude, policy) == \"normal\"\n    77→\n    78→\n    79→def manual_review_resolved(paths: Dict[str, Path], state: Dict[str, Any]) -> bool:\n    80→    marker = load_json(paths[\"manual_review_status\"], default={}) or {}\n    81→    if marker.get(\"resolved\") is True:\n    82→        return True\n    83→    if marker.get(\"approved\") is True:\n    84→        return True\n    85→    return bool(state.get(\"manual_review_resolved\"))\n    86→\n    87→\n    88→def review_can_publish(review: Dict[str, Any]) -> bool:\n    89→    return bool(review.get(\"publishable\", review.get(\"publish_recommendation\") == \"publish\")) and not bool(review.get(\"requires_manual_review\"))\n    90→\n    91→\n    92→def release_waiting_auth(task_id: str, state: Dict[str, Any], route: Dict[str, Any], dispatch: Dict[str, Any], review: Dict[str, Any], now: str) -> Dict[str, Any]:\n    93→    ready_state = update_state(\n    94→        task_id,\n    95→        \"READY_FOR_EXECUTION\",\n    96→        route=state.get(\"route\") or route.get(\"decision\"),\n    97→        route_decision_id=state.get(\"route_decision_id\") or route.get(\"route_decision_id\"),\n    98→        approval=state.get(\"approval\", {}),\n    99→        approval_id=state.get(\"approval_id\"),\n   100→        dispatch_id=state.get(\"dispatch_id\") or dispatch.get(\"dispatch_id\"),\n   101→        message=\"queue rebalanced: auth recovered; ready to resume\",\n   102→    )\n   103→    sync_queue_for_task(task_id, state_payload=ready_state, route=route, dispatch=dispatch, review=review, rebalanced_at=now)\n   104→    return ready_state\n   105→\n   106→\n   107→def release_waiting_approval(task_id: str, state: Dict[str, Any], route: Dict[str, Any], dispatch: Dict[str, Any], review: Dict[str, Any], now: str) -> Dict[str, Any]:\n   108→    ready_state = update_state(\n   109→        task_id,\n   110→        \"READY_FOR_EXECUTION\",\n   111→        route=state.get(\"route\") or route.get(\"decision\"),\n   112→        route_decision_id=state.get(\"route_decision_id\") or route.get(\"route_decision_id\"),\n   113→        approval=state.get(\"approval\", {}),\n   114→        approval_id=state.get(\"approval_id\"),\n   115→        dispatch_id=state.get(\"dispatch_id\") or dispatch.get(\"dispatch_id\"),\n   116→        message=\"queue rebalanced: approval detected; ready to resume\",\n   117→    )\n   118→    sync_queue_for_task(task_id, state_payload=ready_state, route=route, dispatch=dispatch, review=review, rebalanced_at=now)\n   119→    return ready_state\n   120→\n   121→\n   122→def release_waiting_capacity(task_id: str, state: Dict[str, Any], route: Dict[str, Any], dispatch: Dict[str, Any], review: Dict[str, Any], now: str) -> Dict[str, Any]:\n   123→    ready_state = update_state(\n   124→        task_id,\n   125→        \"READY_FOR_EXECUTION\",\n   126→        route=state.get(\"route\") or route.get(\"decision\"),\n   127→        route_decision_id=state.get(\"route_decision_id\") or route.get(\"route_decision_id\"),\n   128→        approval=state.get(\"approval\", {}),\n   129→        approval_id=state.get(\"a