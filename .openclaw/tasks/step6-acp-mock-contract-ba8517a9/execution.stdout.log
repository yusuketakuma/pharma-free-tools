raise ValidationError(\"execution-result: non-success requires non-zero exit_code\")\n   801→        for key in (\"started_at\", \"finished_at\"):\n   802→            try:\n   803→                datetime.fromisoformat(str(payload.get(key)))\n   804→            except Exception as exc:  # noqa: BLE001\n   805→                raise ValidationError(f\"execution-result: invalid ISO timestamp in {key}\") from exc\n   806→        meta = payload.get(\"_meta\") if isinstance(payload.get(\"_meta\"), dict) else {}\n   807→        result_code = meta.get(\"result_code\")\n   808→        if result_code == \"AUTH_REQUIRED\" and status != \"runtime_error\":\n   809→            raise ValidationError(\"execution-result: AUTH_REQUIRED must use status=runtime_error\")\n   810→        if result_code == \"AUTH_REQUIRED\" and exit_code == 0:\n   811→            raise ValidationError(\"execution-result: AUTH_REQUIRED requires non-zero exit_code\")\n   812→        if status == \"success\" and meta.get(\"fallback_used\"):\n   813→            required_meta = [\n   814→                \"normalization_source\",\n   815→                \"fallback_used\",\n   816→                \"retry_count\",\n   817→                \"cli_version\",\n   818→                \"raw_sha256\",\n   819→                \"degraded_contract\",\n   820→            ]\n   821→            missing = [key for key in required_meta if key not in meta]\n   822→            if missing:\n   823→                raise ValidationError(\n   824→                    \"execution-result: degraded success missing _meta fields: \" + \", \".join(missing)\n   825→                )\n   826→    elif schema_name == \"execution-request\":\n   827→        if payload.get(\"executor\") != \"claude-code\":\n   828→            raise ValidationError(\"execution-request: executor must be claude-code\")\n   829→    elif schema_name == \"route-decision\":\n   830→        if payload.get(\"approval_required\") and not payload.get(\"protected_paths\"):\n   831→            raise ValidationError(\"route-decision: approval_required=true needs protected_paths\")\n   832→    elif schema_name == \"lane-selection\":\n   833→        if payload.get(\"primary_mode\") not in {\"acp\", \"cli\"}:\n   834→            raise ValidationError(\"lane-selection: primary_mode must be one of acp|cli\")\n   835→        if payload.get(\"selected_lane\") not in {\"acp\", \"cli\", \"cli_backend_safety_net\", \"none\"}:\n   836→            raise ValidationError(\"lane-selection: selected_lane must be a known lane\")\n   837→        if parse_iso_or_none(payload.get(\"captured_at\")) is None:\n   838→            raise ValidationError(\"lane-selection: captured_at must be ISO timestamp\")\n   839→        lane_health_snapshot = payload.get(\"lane_health_snapshot\") if isinstance(payload.get(\"lane_health_snapshot\"), dict) else {}\n   840→        snapshot_captured_at = lane_health_snapshot.get(\"captured_at\")\n   841→        if snapshot_captured_at is not None and parse_iso_or_none(snapshot_captured_at) is None:\n   842→            raise ValidationError(\"lane-selection: lane_health_snapshot.captured_at must be ISO timestamp or null\")\n   843→        if payload.get(\"version\") != LANE_SELECTION_SCHEMA_VERSION:\n   844→            raise ValidationError(f\"lane-selection: version must be {LANE_SELECTION_SCHEMA_VERSION}\")\n   845→    elif schema_name == \"dispatch-attempt\":\n   846→        for field in (\"started_at\", \"finished_at\"):\n   847→            if parse_iso_or_none(payload.get(field)) is None:\n   848→                raise ValidationError(f\"dispatch-attempt: {field} must be ISO timestamp\")\n   849→        if payload.get(\"attempt_index\") != int(payload.get(\"attempt_index\") or 0):\n   850→            raise ValidationError(\"dispatch-attempt: attempt_index must be an integer\")\n   851→        fallback_triggered = bool(payload.get(\"fallback_triggered\"))\n   852→        fallback_target = payload.get(\"fallback_target\")\n   853→        if fallback_triggered and not fallback_target:\n   854→            raise ValidationError(\"dispatch-attempt: fallback_target is required when fallback_triggered=true\")\n   855→        if not fallback_triggered and fallback_target is not None:\n   856→            raise ValidationError(\"dispatch-attempt: fallback_target must be null when fallback_triggered=false\")\n   857→        if payload.get(\"version\") != DISPATCH_ATTEMPT_SCHEMA_VERSION:\n   858→            raise ValidationError(f\"dispatch-attempt: version must be {DISPATCH_ATTEMPT_SCHEMA_VERSION}\")\n   859→    elif schema_name in {\"queue-status\", \"runtime-queue-entry\"}:\n   860→        reason = payload.get(\"queue_reason\")\n   861→        target = payload.get(\"resume_target_state\")\n   862→        if reason is None:\n   863→            if target is not None:\n   864→                raise ValidationError(f\"{schema_name}: inactive queue must not set resume_target_state\")\n   865→        else:\n   866→            if reason not in QUEUE_REASONS:\n   867→                raise ValidationError(f\"{schema_name}: invalid queue_reason={reason}\")\n   868→            expected = queue_resume_target(reason)\n   869→            if target != expected:\n   870→                raise ValidationError(f\"{schema_name}: resume_target_state must be {expected} for {reason}\")\n   871→        if payload.get(\"queued_at\") is not None and parse_iso_or_none(payload.get(\"queued_at\")) is None:\n   872→            raise ValidationError(f\"{schema_name}: queued_at must be ISO timestamp or null\")\n   873→        for field in (\"last_rebalanced_at\", \"released_at\", \"updated_at\"):\n   874→            value = payload.get(field)\n   875→            if value is not None and parse_iso_or_none(value) is None:\n   876→                raise ValidationError(f\"{schema_name}: {field} must be ISO timestamp or null\")\n   877→        if payload.get(\"version\") != QUEUE_SCHEMA_VERSION:\n   878→            raise ValidationError(f\"{schema_name}: version must be {QUEUE_SCHEMA_VERSION}\")\n   879→\n   880→\n   881→def validate_claude_code_config(config: Dict[str, Any]) -> None:\n   882→    if config[\"mode\"] not in {\"mock\", \"cli\", \"sdk\"}:\n   883→        raise ValidationError(\"claude-code config: mode must be one of mock|cli|sdk\")\n   884→    if config[\"primary_mode\"] not in {\"acp\", \"cli\"}:\n   885→        raise ValidationError(\"claude-code config: primary_mode must be one of acp|cli\")\n   886→    if config[\"secondary_mode\"] not in {\"cli\"}:\n   887→        raise ValidationError(\"claude-code config: secondary_mode must remain cli\")\n   888→    if config[\"backend_safety_net\"] not in {\"cli\"}:\n   889→        raise ValidationError(\"claude-code config: backend_safety_net must remain cli\")\n   890→    for key in (\"permission_mode_default\", \"permission_mode_execute\"):\n   891→        if not str(config.get(key) or \"\").strip():\n   892→            raise ValidationError(f\"claude-code config: {key} must be non-empty\")\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"47c44d7c-67c9-43fe-bbe4-8ae91e77bb61","uuid":"27f6072c-c9b6-4175-8a88-9a3d3b555684","timestamp":"2026-03-22T07:47:48.335Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yusuke/.openclaw/workspace/.openclaw/scripts/task_runtime.py","content":"def validate_runtime_semantics(schema_name: str, payload: Dict[str, Any]) -> None:\n    if schema_name == \"execution-result\":\n        status = payload.get(\"status\")\n        exit_code = payload.get(\"exit_code\")\n        if status == \"success\" and exit_code != 0:\n            raise ValidationError(\"execution-result: success requires exit_code=0\")\n        if status != \"success\" and exit_code == 0:\n            raise ValidationError(\"execution-result: non-success requires non-zero exit_code\")\n        for key in (\"started_at\", \"finished_at\"):\n            try:\n                datetime.fromisoformat(str(payload.get(key)))\n            except Exception as exc:  # noqa: BLE001\n                raise ValidationError(f\"execution-result: invalid ISO timestamp in {key}\") from exc\n        meta = payload.get(\"_meta\") if isinstance(payload.get(\"_meta\"), dict) else {}\n        result_code = meta.get(\"result_code\")\n        if result_code == \"AUTH_REQUIRED\" and status != \"runtime_error\":\n            raise ValidationError(\"execution-result: AUTH_REQUIRED must use status=runtime_error\")\n        if result_code == \"AUTH_REQUIRED\" and exit_code == 0:\n            raise ValidationError(\"execution-result: AUTH_REQUIRED requires non-zero exit_code\")\n        if status == \"success\" and meta.get(\"fallback_used\"):\n            required_meta = [\n                \"normalization_source\",\n                \"fallback_used\",\n                \"retry_count\",\n                \"cli_version\",\n                \"raw_sha256\",\n                \"degraded_contract\",\n            ]\n            missing = [key for key in required_meta if key not in meta]\n            if missing:\n                raise ValidationError(\n                    \"execution-result: degraded success missing _meta fields: \" + \", \".join(missing)\n                )\n    elif schema_name == \"execution-request\":\n        if payload.get(\"executor\") != \"claude-code\":\n            raise ValidationError(\"execution-request: executor must be claude-code\")\n    elif schema_name == \"route-decision\":\n        if payload.get(\"approval_required\") and not payload.get(\"protected_paths\"):\n            raise ValidationError(\"route-decision: approval_required=true needs protected_paths\")\n    el