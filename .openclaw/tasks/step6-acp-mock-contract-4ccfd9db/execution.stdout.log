def rebalance_one(task_id: str, expected_reason: str | None = None, artifact_path: Path | None = None) -> Dict[str, Any]:\n   165→    paths = task_paths(task_id)\n   166→    if artifact_path is not None:\n   167→        try:\n   168→            artifact = read_queue_artifact(artifact_path)\n   169→        except ValidationError as exc:\n   170→            result = handle_invalid_queue_artifact(task_id, artifact_path, f\"invalid queue artifact: {artifact_path}: {exc}\")\n   171→            write_runtime_metrics()\n   172→            return result\n   173→        if expected_reason and artifact.get(\"queue_reason\") != expected_reason:\n   174→            return {\"task_id\": task_id, \"queue_reason\": expected_reason, \"action\": \"held\", \"state\": \"mismatch\"}\n   175→    try:\n   176→        with task_lock(paths[\"dir\"]):\n   177→            state = load_json(paths[\"state\"], default={}) or {}\n   178→            route = load_json(paths[\"route\"], default={}) or {}\n   179→            dispatch = load_json(paths[\"dispatch\"], default={}) or {}\n   180→            review = load_json(paths[\"review\"], default={}) or {}\n   181→            queue_status = load_json(paths[\"queue_status\"], default={}) or {}\n   182→            reason = expected_reason or queue_status.get(\"queue_reason\") or queue_status.get(\"last_queue_reason\")\n   183→            now = now_iso()\n   184→            if reason == \"waiting_auth\":\n   185→                if auth_recovered():\n   186→                    new_state = release_waiting_auth(task_id, state, route, dispatch, review, now)\n   187→                    write_runtime_metrics()\n   188→                    return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"released\", \"state\": new_state.get(\"state\")}\n   189→            elif reason == \"waiting_approval\":\n   190→                if (state.get(\"approval\") or {}).get(\"approved\"):\n   191→                    new_state = release_waiting_approval(task_id, state, route, dispatch, review, now)\n   192→                    write_runtime_metrics()\n   193→                    return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"released\", \"state\": new_state.get(\"state\")}\n   194→            elif reason == \"waiting_capacity\":\n   195→                if capacity_recovered(dispatch):\n   196→                    new_state = release_waiting_capacity(task_id, state, route, dispatch, review, now)\n   197→                    write_runtime_metrics()\n   198→                    return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"released\", \"state\": new_state.get(\"state\")}\n   199→            elif reason == \"waiting_manual_review\":\n   200→                if manual_review_resolved(paths, state) and not review_can_publish(review):\n   201→                    new_state = release_waiting_manual_review(task_id, state, route, dispatch, review, now, paths)\n   202→                    write_runtime_metrics()\n   203→                    return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"released\", \"state\": new_state.get(\"state\")}\n   204→\n   205→            synced = sync_queue_for_task(task_id, state_payload=state, route=route, dispatch=dispatch, review=review, rebalanced_at=now)\n   206→            write_runtime_metrics()\n   207→            return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"held\", \"state\": synced.get(\"state\")}\n   208→    except LockError:\n   209→        write_runtime_metrics()\n   210→        return {\"task_id\": task_id, \"queue_reason\": expected_reason, \"action\": \"skipped_locked\", \"state\": \"locked\"}\n   211→\n   212→\n   213→def main() -> int:\n   214→    args = parse_args()\n   215→    results: List[Dict[str, Any]] = []\n   216→    seen: set[str] = set()\n   217→    if args.task_id:\n   218→        artifact_path = next(iter_queue_entries(task_id=args.task_id, reason=args.reason), None)\n   219→        results.append(rebalance_one(args.task_id, args.reason, artifact_path))\n   220→    else:\n   221→        for path in iter_queue_entries(reason=args.reason):\n   222→            if path.stem in seen:\n   223→                results.append({\"task_id\": path.stem, \"queue_reason\": path.parent.name, \"action\": \"skipped_duplicate\", \"state\": \"deduped\"})\n   224→                continue\n   225→            seen.add(path.stem)\n   226→            results.append(rebalance_one(path.stem, args.reason or path.parent.name, path))\n   227→    write_runtime_metrics()\n   228→    print(json.dumps({\"results\": results}, ensure_ascii=False, indent=2))\n   229→    return 0\n   230→\n   231→\n   232→if __name__ == \"__main__\":\n   233→    raise SystemExit(main())\n   234→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7a3b2848-fb3c-4af3-9179-4363804c6042","uuid":"e3abe1de-40f8-4fc7-a190-dabfacab3fed","timestamp":"2026-03-22T07:41:20.823Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yusuke/.openclaw/workspace/.openclaw/scripts/rebalance_queue.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nfrom pathlib import Path\nfrom typing import Any, Dict, Iterable, List\n\nfrom dispatch_task import load_json_like, pressure_level_claude, pressure_level_openclaw\nfrom task_runtime import (\n    CONFIG_ROOT,\n    QUEUE_REASONS,\n    ROOT,\n    LockError,\n    ValidationError,\n    atomic_write_json,\n    handle_invalid_queue_artifact,\n    load_json,\n    now_iso,\n    read_queue_artifact,\n    sync_queue_for_task,\n    task_lock,\n    task_paths,\n    update_state,\n    write_runtime_metrics,\n)\n\nAUTH_RUNTIME_PATH = ROOT / \"runtime\" / \"auth\" / \"latest-status.json\"\nCAPACITY_RUNTIME_PATH = ROOT / \"runtime\" / \"capacity\" / \"latest-capacity.json\"\n\n\ndef parse_args() -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Re-evaluate queued OpenClaw tasks\")\n    parser.add_argument(\"--task-id\")\n    parser.add_argument(\"--reason\", choices=list(QUEUE_REASONS))\n    return parser.parse_args()\n\n\ndef iter_queue_entries(task_id: str | None = None, reason: str | None = None) -> Iterable[Path]:\n    reasons = [reason] if reason else list(QUEUE_REASONS)\n    for queue_reason in reasons:\n        queue_dir = ROOT / \"runtime\" / \"queue\" / queue_reason\n        if not queue_dir.exists():\n            continue\n        for path in sorted(queue_dir.glob(\"*.json\")):\n            if task_id and path.stem != task_id:\n                continue\n            yield path\n\n\ndef auth_recovered() -> bool:\n    status = load_json(AUTH_RUNTIME_PATH, default={}) or {}\n    stdout = status.get(\"stdout\") if isinstance(status.get(\"stdout\"), dict) else {}\n    return bool(status.get(\"ok\")) and bool(\n        status.get(\"logged_in\")\n        or status.get(\"auth_ok\")\n        or stdout.get(\"loggedIn\")\n    )\n\n\ndef capacity_recovered(dispatch: Dict[str, Any]) -> bool:\n    snapshot = load_json(CAPACITY_RUNTIME_PATH, default={}) or {}\n    providers = snapshot.get(\"providers\") if isinstance(snapshot.get(\"providers\"), dict) else {}\n    if not providers:\n        return False\n    policy = load_json_like(CONFIG_ROOT / \"capacity-policy.yaml\")\n    selected_provider = str(dispatch.get(\"selected_provider\") or \"\")\n    if selected_provider == \"claude_code\":\n        provider = providers.get(\"claude_code\") or {}\n        return bool(provider) and pressure_level_claude(provider, policy) == \"normal\"\n    if selected_provider == \"openclaw\":\n        provider = providers.get(\"openclaw\") or {}\n        return bool(provider) and pressure_level_openclaw(provider, policy) == \"normal\"\n    openclaw = providers.get(\"openclaw\") or {}\n    claude = providers.get(\"claude_code\") or {}\n    return bool(openclaw and claude) and pressure_level_openclaw(openclaw, policy) == \"normal\" and pressure_level_claude(claude, policy) == \"normal\"\n\n\ndef manual_review_resolved(paths: Dict[str, Path], state: Dict[str, Any]) -> bool:\n    marker = load_json(paths[\"manual_review_status\"], default={}) or {}\n    if marker.get(\"resolved\") is True:\n        return True\n    if marker.get(\"approved\") is True:\n        return True\n    return bool(state.get(\"manual_review_resolved\"))\n\n\ndef review_can_publish(review: Dict[str, Any]) -> bool:\n    return bool(review.get(\"publishable\", review.get(\"publish_recommendation\") == \"publish\")) and not bool(review.get(\"requires_manual_review\"))\n\n\ndef release_waiting_auth(task_id: str, state: Dict[str, Any], route: Dict[str, Any], dispatch: Dict[str, Any], review: Dict[str, Any], now: str) -> Dict[str, Any]:\n    ready_state = update_state(\n        task_id,\n        \"READY_FOR_EXECUTION\",\n        route=state.get(\"route\") or route.get(\"decision\"),\n        route_decision_id=state.get(\"route_decision_id\") or route.get(\"route_decision_id\"),\n        approval=state.get(\"approval\", {}),\n        approval_id=state.get(\"approval_id\"),\n        dispatch_id=state.get(\"dispatch_id\") or dispatch.get(\"dispatch_id\"),\n        message=\"queue rebalanced: auth recovered; ready to resume\",\n    )\n    sync_queue_for_task(task_id, state_payload=ready_state, route=route, dispatch=dispatch, review=review, rebalanced_at=now)\n    return ready_state\n\n\ndef release_waiting_approval(task_id: str, state: Dict[str, Any], route: Dict[str, Any], dispatch: Dict[str, Any], review: Dict[str, Any], now: str) -> Dict[str, Any]:\n    ready_state = update_state(\n        task_id,\n        \"READY_FOR_EXECUTION\",\n        route=state.get(\"route\") or route.get(\"decision\"),\n        route_decision_id=state.get(\"route_decision_id\") or route.get(\"route_decision_id\"),\n        approval=state.get(\"approval\", {}),\n        approval_id=state.get(\"approval_id\"),\n        dispatch_id=state.get(\"dispatch_id\") or dispatch.get(\"dispatch_id\"),\n        message=\"queue rebalanced: approval detected; ready to resume\",\n    )\n    sync_queue_for_task(task_id, state_payload=ready_state, route=route, dispatch=dispatch, review=review, rebalanced_at=now)\n    return ready_state\n\n\ndef release_waiting_capacity(task_id: str, state: Dict[str, Any], route: Dict[str, Any], dispatch: Dict[str, Any], review: Dict[str, Any], now: str) -> Dict[str, Any]:\n    ready_state = update_state(\n        task_id,\n        \"READY_FOR_EXECUTION\",\n        route=state.get(\"route\") or route.get(\"decision\"),\n        route_decision_id=state.get(\"route_decision_id\") or route.get(\"route_decision_id\"),\n        approval=state.get(\"approval\", {}),\n        approval_id=state.get(\"approval_id\"),\n        dispatch_id=state.get(\"dispatch_id\") or dispatch.get(\"dispatch_id\"),\n        message=\"queue rebalanced: provider capacity recovered; ready to resume\",\n    )\n    sync_queue_for_task(task_id, state_payload=ready_state, route=route, dispatch=dispatch, review=review, rebalanced_at=now)\n    return ready_state\n\n\ndef release_waiting_manual_review(task_id: str, state: Dict[str, Any], route: Dict[str, Any], dispatch: Dict[str, Any], review: Dict[str, Any], now: str, paths: Dict[str, Path]) -> Dict[str, Any]:\n    updated_review = dict(review)\n    updated_review[\"verdict\"] = \"pass\"\n    updated_review[\"publish_recommendation\"] = \"publish\"\n    updated_review[\"publishable\"] = True\n    updated_review[\"requires_manual_review\"] = False\n    updated_review[\"summary\"] = \"Manual review resolved; result may be published.\"\n    issues = list(updated_review.get(\"issues\", []))\n    if \"manual review resolved\" not in issues:\n        issues.append(\"manual review resolved\")\n    updated_review[\"issues\"] = issues\n    atomic_write_json(paths[\"review\"], updated_review)\n\n    reviewing_state = update_state(\n        task_id,\n        \"REVIEWING\",\n        route=state.get(\"route\") or route.get(\"decision\"),\n        route_decision_id=state.get(\"route_decision_id\") or route.get(\"route_decision_id\"),\n        approval=state.get(\"approval\", {}),\n        approval_id=state.get(\"approval_id\"),\n        dispatch_id=state.get(\"dispatch_id\") or dispatch.get(\"dispatch_id\"),\n        message=\"queue rebalanced: manual review resolved; ready for publish\",\n    )\n    sync_queue_for_task(task_id, state_payload=reviewing_state, route=route, dispatch=dispatch, review=updated_review, rebalanced_at=now)\n    return reviewing_state\n\n\ndef rebalance_one(task_id: str, expected_reason: str | None = None, artifact_path: Path | None = None) -> Dict[str, Any]:\n    paths = task_paths(task_id)\n    if artifact_path is not None:\n        try:\n            artifact = read_queue_artifact(artifact_path)\n        except ValidationError as exc:\n            result = handle_invalid_queue_artifact(task_id, artifact_path, f\"invalid queue artifact: {artifact_path}: {exc}\")\n            write_runtime_metrics()\n            return result\n        if expected_reason and artifact.get(\"queue_reason\") != expected_reason:\n            return {\"task_id\": task_id, \"queue_reason\": expected_reason, \"action\": \"held\", \"state\": \"mismatch\"}\n    try:\n        with task_lock(paths[\"dir\"]):\n            state = load_json(paths[\"state\"], default={}) or {}\n            route = load_json(paths[\"route\"], default={}) or {}\n            dispatch = load_json(paths[\"dispatch\"], default={}) or {}\n            review = load_json(paths[\"review\"], default={}) or {}\n            queue_status = load_json(paths[\"queue_status\"], default={}) or {}\n            reason = expected_reason or queue_status.get(\"queue_reason\") or queue_status.get(\"last_queue_reason\")\n            now = now_iso()\n            if reason == \"waiting_auth\":\n                if auth_recovered():\n                    new_state = release_waiting_auth(task_id, state, route, dispatch, review, now)\n                    write_runtime_metrics()\n                    return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"released\", \"state\": new_state.get(\"state\")}\n            elif reason == \"waiting_approval\":\n                if (state.get(\"approval\") or {}).get(\"approved\"):\n                    new_state = release_waiting_approval(task_id, state, route, dispatch, review, now)\n                    write_runtime_metrics()\n                    return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"released\", \"state\": new_state.get(\"state\")}\n            elif reason == \"waiting_capacity\":\n                if capacity_recovered(dispatch):\n                    new_state = release_waiting_capacity(task_id, state, route, dispatch, review, now)\n                    write_runtime_metrics()\n                    return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"released\", \"state\": new_state.get(\"state\")}\n            elif reason == \"waiting_manual_review\":\n                if manual_review_resolved(paths, state) and not review_can_publish(review):\n                    new_state = release_waiting_manual_review(task_id, state, route, dispatch, review, now, paths)\n                    write_runtime_metrics()\n                    return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"released\", \"state\": new_state.get(\"state\")}\n\n            synced = sync_queue_for_task(task_id, state_payload=state, route=route, dispatch=dispatch, review=review, rebalanced_at=now)\n            write_runtime_metrics()\n            return {\"task_id\": task_id, \"queue_reason\": reason, \"action\": \"held\", \"state\": synced.get(\"state\")}\n    except LockError:\n        write_runtime_metrics()\n        return {\"task_id\": task_id, \"queue_reason\": expected_reason, \"action\": \"skipped_locked\", \"state\": \"locked\"}\n\n\ndef main() -> int:\n    args = parse_args()\n    results: List[Dict[str, Any]] = []\n    seen: set[str] = set()\n    if args.task_id:\n        artifact_path = next(iter_queue_entries(task_id=args.task_id, reason=args.reason), None)\n        results.append(rebalance_one(args.task_id, args.reason, artifact_path))\n    else:\n        for path in iter_queue_entries(reason=args.reason):\n            if path.stem in seen:\n                results.append({\"task_id\": path.stem, \"queue_reason\": path.parent.name, \"action\": \"skipped_duplicate\", \"state\": \"deduped\"})\n                continue\n            seen.add(path.stem)\n            results.append(rebalance_one(path.stem, args.reason or path.parent.name, path))\n    write_runtime_metrics()\n    print(json.dumps({\"results\": results}, ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n","numLines":234,"startLine":1,"totalLines":234}}},{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PcQ1zdqwKXKBdRGa2np9dZ","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→from __future__ import annotations\n     3→\n     4→import argparse\n     5→import json\n     6→import subprocess\n     7→import sys\n     8→from pathlib import Path\n     9→\n    10→from task_runtime import (\n    11→    ROOT,\n    12→    WORKSPACE_ROOT,\n    13→    ApprovalError,\n    14→    ValidationError,\n    15→    append_dispatch_attempt_artifact,\n    16→    atomic_write_json,\n    17→    atomic_write_text,\n    18→    build_context_pack,\n    19→    build_execution_request,\n    20→    build_openclaw_result,\n    21→    build_review_report,\n    22→    build_task_record,\n    23→    ensure_schema_valid,\n    24→    is_plan_only_task,\n    25→    is_write_task,\n    26→    load_dispatch_attempts_artifact,\n    27→    load_json,\n    28→    read_lane_selection_artifact,\n    29→    write_lane_selection_artifact,\n    30→    new_operation_id,\n    31→    now_iso,\n    32→    route_task,\n    33→    sync_queue_for_task,\n    34→    task_lock,\n    35→    task_paths,\n    36→    update_state,\n    37→    write_runtime_metrics,\n    38→)\n    39→from analyze_task import analyze_task\n    40→from select_assignees import save_assignment_plan, select_assignment_plan\n    41→from dispatch_task import build_dispatch_plan\n    42→\n    43→EXIT_CODE_TO_STATUS = {\n    44→    0: \"success\",\n    45→    10: \"policy_blocked\",\n    46→    20: \"timeout\",\n    47→    30: \"runtime_error\",\n    48→    40: \"invalid_request\",\n    49→    50: \"invalid_result\",\n    50→}\n    51→\n    52→\n    53→def parse_args() -> argparse.Namespace:\n    54→    parser = argparse.ArgumentParser(description=\"Execute an OpenClaw task closed-loop\")\n    55→    parser.add_argument(\"--task-id\", required=True)\n    56→    parser.add_argument(\"--task\")\n    57→    parser.add_argument(\"--paths\", nargs=\"*\", default=[])\n    58→    parser.add_argument(\"--constraint\", action=\"append\", default=[])\n    59→    parser.add_argument(\"--verify\", action=\"append\", default=[])\n    60→    parser.add_argument(\"--review-focus\", action=\"append\", default=[])\n    61→    parser.add_argument(\"--action\", action=\"append\", default=[])\n    62→    parser.add_argument(\"--requested-route\", choices=[\"openclaw\", \"claude-code\"])\n    63→    parser.add_argument(\"--task-file\", help=\"JSON file with task payload\")\n    64→    return parser.parse_args()\n    65→\n    66→\n    67→def load_task_payload(args: argparse.Namespace) -> dict:\n    68→    if args.task_file:\n    69→        return json.loads(Path(args.task_file).read_text(encoding=\"utf-8\"))\n    70→    return {\n    71→        \"task\": args.task or \"\",\n    72→        \"requested_paths\": args.paths,\n    73→        \"constraints\": args.constraint,\n    74→        \"verification_commands\": args.verify,\n    75→        \"review_focus\": args.review_focus,\n    76→        \"requested_actions\": args.action,\n    77→        \"requested_route\": args.requested_route,\n    78→    }\n    79→\n    80→\n    81→def next_dispatch_attempt_id(task_id: str, dispatch_id: str) -> tuple[str, int]:\n    82→    attempts = load_dispatch_attempts_artifact(task_paths(task_id)[\"dispatch_attempts\"])\n    83→    next_index = len(attempts) + 1\n    84→    return f\"{dispatch_id}_attempt_{next_index:02d}\", next_index\n    85→\n    86→\n    87→def run_claude_lane(task: dict, route: dict, approval: dict, *, dispatch_id: str | None = None, selected_lane: str = \"cli\", fallback_triggered: bool = False) -> tuple[int, dict | None, str, str]:\n    88→    paths = task_paths(task[\"task_id\"])\n    89→    dispatch_id = dispatch_id or new_operation_id(\"dispatch\")\n    90→    dispatch_attempt_id, attempt_index = next_dispatch_attempt_id(task[\"task_id\"], dispatch_id)\n    91→    request = build_execution_request(task, route, dispatch_id=dispatch_id)\n    92→    request[\"started_at\"] = now_iso()\n    93→    request[\"dispatch_attempt_id\"] = dispatch_attempt_id\n    94→    request[\"selected_lane\"] = selected_lane\n    95→    request[\"task_type\"] = \"plan_only\" if is_plan_only_task(task) else \"write\" if is_write_task(task) else \"read_only\"\n    96→    if selected_lane != \"acp\" and request.get(\"mock_mode\") in {\"acp_pre_session_failure\", \"pre_session_failure\"}:\n    97→        request[\"mock_mode\"] = \"success\"\n    98→    atomic_write_json(paths[\"request\"], request)\n    99→    ensure_schema_valid(paths[\"request\"], \"execution-request\")\n   100→\n   101→    if route[\"approval_required\"] and not approval.get(\"approved\"):\n   102→        raise ApprovalError(\"protected paths require approval before execution\")\n   103→\n   104→    update_state(\n   105→        task[\"task_id\"],\n   106→        \"READY_FOR_EXECUTION\",\n   107→        route=route[\"decision\"],\n   108→        route_decision_id=route.get(\"route_decision_id\"),\n   109→        approval=approval,\n   110→        dispatch_id=dispatch_id,\n   111→        message=f\"execution request saved lane={selected_lane} attempt={dispatch_attempt_id}\",\n   112→    )\n   113→    update_state(\n   114→        task[\"task_id\"],\n   115→        \"RUNNING\",\n   116→        route=route[\"decision\"],\n   117→        route_decision_id=route.get(\"route_decision_id\"),\n   118→        approval=approval,\n   119→        dispatch_id=dispatch_id,\n   120→        message=f\"executor started lane={selected_lane} attempt={dispatch_attempt_id}\",\n   121→    )\n   122→\n   123→    command = [\n   124→        \"bash\",\n   125→        str(ROOT / \"scripts\" / \"run_claude_code.sh\"),\n   126→        \"--request\",\n   127→        str(paths[\"request\"]),\n   128→        \"--result\",\n   129→        str(paths[\"result\"]),\n   130→        \"--stdout-log\",\n   131→        str(paths[\"stdout\"]),\n   132→        \"--stderr-log\",\n   133→        str(paths[\"stderr\"]),\n   134→    ]\n   135→    if selected_lane == \"acp\":\n   136→        command = [\n   137→            \"python3\",\n   138→            str(ROOT / \"scripts\" / \"run_claude_acp.py\"),\n   139→            \"--request\",\n   140→            str(paths[\"request\"]),\n   141→            \"--result\",\n   142→            str(paths[\"result\"]),\n   143→            \"--stdout-log\",\n   144→            str(paths[\"stdout\"]),\n   145→            \"--stderr-log\",\n   146→            str(paths[\"stderr\"]),\n   147→        ]\n   148→    completed = subprocess.run(command, cwd=str(WORKSPACE_ROOT), check=False)\n   149→    result_payload = None\n   150→    if paths[\"result\"].exists():\n   151→        try:\n   152→            result_payload = ensure_schema_valid(paths[\"result\"], \"execution-result\")\n   153→        except ValidationError:\n   154→            result_payload = load_json(paths[\"result\"], default={}) or {}\n   155→            raise\n   156→    result_meta = result_payload.get(\"_meta\") if isinstance((result_payload or {}).get(\"_meta\"), dict) else {}\n   157→    attempt_payload = {\n   158→        \"task_id\": task[\"task_id\"],\n   159→        \"dispatch_id\": dispatch_id,\n   160→        \"dispatch_attempt_id\": dispatch_attempt_id,\n   161→        \"lane\": selected_lane,\n   162→        \"attempt_index\": attempt_index,\n   163→        \"status\": (result_payload or {}).get(\"status\") or EXIT_CODE_TO_STATUS.get(completed.returncode, \"failed\"),\n   164→        \"exit_code\": completed.returncode,\n   165→        \"started_at\": request.get(\"started_at\") or (result_payload or {}).get(\"started_at\"),\n   166→        \"finished_at\": (result_payload or {}).get(\"finished_at\") or now_iso(),\n   167→        \"result_code\": result_meta.get(\"result_code\"),\n   168→        \"fallback_triggered\": fallback_triggered,\n   169→        \"fallback_target\": selected_lane if fallback_triggered else None,\n   170→        \"version\": 1,\n   171→    }\n   172→    append_dispatch_attempt_artifact(paths[\"dispatch_attempts\"], attempt_payload)\n   173→    write_runtime_metrics()\n   174→    return completed.returncode, result_payload, dispatch_id, dispatch_attempt_id\n   175→\n   176→\n   177→def resolve_route(task: dict, paths: dict, existing_state: dict) -> tuple[dict, bool]:\n   178→    existing_route = load_json(paths[\"route\"], default={}) or {}\n   179→    if existing_route and existing_state.get(\"state\") in {\n   180→        \"WAITING_APPROVAL\",\n   181→        \"AUTH_REQUIRED\",\n   182→        \"READY_FOR_EXECUTION\",\n   183→        \"WAITING_CAPACITY\",\n   184→        \"WAITING_MANUAL_REVIEW\",\n   185→        \"RUNNING\",\n   186→        \"REVIEWING\",\n   187→        \"PUBLISHED\",\n   188→        \"EXECUTION_FAILED\",\n   189→        \"REVIEW_FAILED\",\n   190→    }:\n   191→        ensure_schema_valid(paths[\"route\"], \"route-decision\")\n   192→        return existing_route, True\n   193→    route = route_task(task)\n   194→    atomic_write_json(paths[\"route\"], route)\n   195→    return route, False\n   196→\n   197→\n   198→def resolve_dispatch(task: dict, paths: dict, existing_state: dict, assignment_plan: dict) -> tuple[dict, bool]:\n   199→    existing_dispatch = load_json(paths[\"dispatch\"], default={}) or {}\n   200→    if existing_dispatch and existing_state.get(\"state\") in {\n   201→        \"WAITING_APPROVAL\",\n   202→        \"AUTH_REQUIRED\",\n   203→        \"READY_FOR_EXECUTION\",\n   204→        \"WAITING_CAPACITY\",\n   205→        \"WAITING_MANUAL_REVIEW\",\n   206→        \"RUNNING\",\n   207→        \"REVIEWING\",\n   208→        \"PUBLISHED\",\n   209→        \"EXECUTION_FAILED\",\n   210→        \"REVIEW_FAILED\",\n   211→    }:\n   212→        ensure_schema_valid(paths[\"dispatch\"], \"dispatch-plan\")\n   213→        if paths[\"lane_selection\"].exists():\n   214→            read_lane_selection_artifact(paths[\"lane_selection\"])\n   215→        return existing_dispatch, True\n   216→    dispatch = build_dispatch_plan(task, assignment_plan)\n   217→    return dispatch, False\n   218→\n   219→\n   220→def can_auto_fallback(task: dict, result: dict | None) -> tuple[bool, str]:\n   221→    meta = result.get(\"_meta\") if isinstance((result or {}).get(\"_meta\"), dict) else {}\n   222→    result_code = str(meta.get(\"result_code\") or \"\")\n   223→    failure_stage = str(meta.get(\"failure_stage\") or \"\")\n   224→    partial_execution = bool(meta.get(\"partial_execution\", False))\n   225→    side_effects_possible = bool(meta.get(\"side_effects_possible\", False))\n   226→    if result_code == \"AUTH_REQUIRED\":\n   227→        return True, \"auth failure before execution\"\n   228→    if failure_stage in {\"session_start\", \"health_check\", \"capacity_check\", \"auth_preflight\"}:\n   229→        return True, f\"pre-execution failure: {failure_stage}\"\n   230→    if not is_write_task(task):\n   231→        return True, \"read-only or plan-only task\"\n   232→    if partial_execution or side_effects_possible or failure_stage in {\"execution\", \"worktree_created\", \"edit_started\"}:\n   233→        return False, \"write task may have side effects\"\n   234→    return False, \"write task fallback is disabled by policy\"\n   235→\n   236→\n   237→def next_lane_after(current_lane: str, dispatch_plan: dict) -> str | None:\n   238→    chain = [str(item) for item in dispatch_plan.get(\"fallback_chain\", []) if isinstance(item, str)]\n   239→    if current_lane not in chain:\n   240→        return None\n   241→    idx = chain.index(current_lane)\n   242→    return chain[idx + 1] if idx + 1 < len(chain) else None\n   243→\n   244→\n   245→def main() -> int:\n   246→    args = parse_args()\n   247→    payload = load_task_payload(args)\n   248→    task = build_task_record(args.task_id, payload)\n   249→    paths = task_paths(task[\"task_id\"])\n   250→\n   251→    with task_lock(paths[\"dir\"]):\n   252→        existing_task = load_json(paths[\"task\"], default={}) or {}\n   253→        existing_state = load_json(paths[\"state\"], default={}) or {}\n   254→        merged_task = dict(existing_task)\n   255→        merged_task.update({k: v for k, v in task.items() if v not in (None, [], \"\")})\n   256→        task = merged_task\n   257→        atomic_write_json(paths[\"task\"], task)\n   258→\n   259→        existing_approval = existing_state.get(\"approval\", {}) if existing_state else {}\n   260→        approval_payload = {\n   261→            \"required\": False,\n   262→            \"approved\": bool(existing_approval.get(\"approved\")),\n   263→        }\n   264→        for key in (\"approved_by\", \"approved_at\", \"note\"):\n   265→            if key in existing_approval:\n   266→                approval_payload[key] = existing_approval[key]\n   267→        if not existing_state:\n   268→            update_state(task[\"task_id\"], \"RECEIVED\", message=\"task stored\", approval=approval_payload)\n   269→\n   270→        assignment_plan = load_json(paths[\"assignment\"], default={}) or {}\n   271→        if not assignment_plan:\n   272→            try:\n   273→                assignment_plan = select_assignment_plan(analyze_task(task))\n   274→                save_assignment_plan(assignment_plan, paths[\"assignment\"])\n   275→            except Exception as exc:  # noqa: BLE001\n   276→                print(f\"warning: assignment planning skipped: {exc}\", file=sys.stderr)\n   277→\n   278→        route, reused_route = resolve_route(task, paths, existing_state)\n   279→        dispatch_plan, reused_dispatch = resolve_dispatch(task, paths, existing_state, assignment_plan)\n   280→        dispatch_mode = dispatch_plan.get(\"execution_mode\")\n   281→        dispatch_route = route[\"decision\"]\n   282→        if dispatch_mode == \"openclaw\":\n   283→            dispatch_route = \"openclaw\"\n   284→        elif dispatch_mode in {\"claude_code\", \"split\", \"plan_only\"}:\n   285→            dispatch_route = \"claude-code\"\n   286→        route[\"decision\"] = dispatch_route\n   287→        approval_payload[\"required\"] = route[\"approval_required\"]\n   288→        if not reused_route:\n   289→            route[\"dispatch_mode\"] = dispatch_mode\n   290→            update_state(\n   291→                task[\"task_id\"],\n   292→                \"ROUTED\",\n   293→                route=dispatch_route,\n   294→                route_decision_id=route.get(\"route_decision_id\"),\n   295→                approval=approval_payload,\n   296→                protected_paths=route[\"protected_paths\"],\n   297→                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   298→                message=\"route decision stored\",\n   299→            )\n   300→\n   301→        should_emit_context_pack = dispatch_mode != \"plan_only\" or bool(dispatch_plan.get(\"pre_auth_openclaw_phase\"))\n   302→        if should_emit_context_pack:\n   303→            atomic_write_text(paths[\"context\"], build_context_pack(task, route))\n   304→\n   305→        if dispatch_mode == \"queued\":\n   306→            queued_state = update_state(\n   307→                task[\"task_id\"],\n   308→                \"WAITING_CAPACITY\",\n   309→                route=dispatch_route,\n   310→                route_decision_id=route.get(\"route_decision_id\"),\n   311→                approval=approval_payload,\n   312→                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   313→                message=\"dispatch queued pending provider capacity\",\n   314→            )\n   315→            sync_queue_for_task(task[\"task_id\"], state_payload=queued_state, route=route, dispatch=dispatch_plan)\n   316→            return 0\n   317→\n   318→        if dispatch_mode == \"plan_only\":\n   319→            if dispatch_plan.get(\"auth_blocked\"):\n   320→                waiting_state = update_state(\n   321→                    task[\"task_id\"],\n   322→                    \"AUTH_REQUIRED\",\n   323→                    route=dispatch_route,\n   324→                    route_decision_id=route.get(\"route_decision_id\"),\n   325→                    approval=approval_payload,\n   326→                    dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   327→                    message=(\n   328→                        \"pre-auth OpenClaw artifacts prepared; waiting for Claude auth\"\n   329→                        if dispatch_plan.get(\"pre_auth_openclaw_phase\")\n   330→                        else \"Claude auth required before execution can continue\"\n   331→                    ),\n   332→                )\n   333→                sync_queue_for_task(task[\"task_id\"], state_payload=waiting_state, route=route, dispatch=dispatch_plan)\n   334→                return 0\n   335→            routed_state = update_state(\n   336→                task[\"task_id\"],\n   337→                \"ROUTED\",\n   338→                route=dispatch_route,\n   339→                route_decision_id=route.get(\"route_decision_id\"),\n   340→                approval=approval_payload,\n   341→                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   342→                message=f\"dispatch withheld: {dispatch_mode}\",\n   343→            )\n   344→            sync_queue_for_task(task[\"task_id\"], state_payload=routed_state, route=route, dispatch=dispatch_plan)\n   345→            return 0\n   346→\n   347→        if route[\"approval_required\"] and not approval_payload.get(\"approved\"):\n   348→            if existing_state.get(\"state\") != \"WAITING_APPROVAL\":\n   349→                approval_state = update_state(\n   350→                    task[\"task_id\"],\n   351→                    \"WAITING_APPROVAL\",\n   352→                    route=route[\"decision\"],\n   353→                    route_decision_id=route.get(\"route_decision_id\"),\n   354→                    approval=approval_payload,\n   355→                    protected_paths=route[\"protected_paths\"],\n   356→                    dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   357→                    message=\"waiting for approval\",\n   358→                )\n   359→            else:\n   360→                approval_state = load_json(paths[\"state\"], default={}) or {}\n   361→            sync_queue_for_task(task[\"task_id\"], state_payload=approval_state, route=route, dispatch=dispatch_plan)\n   362→            return 0\n   363→\n   364→        if route[\"decision\"] == \"openclaw\":\n   365→            direct_approval = dict(approval_payload)\n   366→            direct_approval[\"approved\"] = True\n   367→            update_state(\n   368→                task[\"task_id\"],\n   369→                \"READY_FOR_EXECUTION\",\n   370→                route=\"openclaw\",\n   371→                route_decision_id=route.get(\"route_decision_id\"),\n   372→                approval=direct_approval,\n   373→                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   374→                message=\"direct execution ready\",\n   375→            )\n   376→            update_state(\n   377→                task[\"task_id\"],\n   378→                \"RUNNING\",\n   379→                route=\"openclaw\",\n   380→                route_decision_id=route.get(\"route_decision_id\"),\n   381→                approval=direct_approval,\n   382→                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   383→                message=\"openclaw execution started\",\n   384→            )\n   385→            result = build_openclaw_result(task, route)\n   386→            atomic_write_json(paths[\"result\"], result)\n   387→            ensure_schema_valid(paths[\"result\"], \"execution-result\")\n   388→            review = build_review_report({**task, \"approval\": direct_approval}, route, result)\n   389→            atomic_write_json(paths[\"review\"], review)\n   390→            ensure_schema_valid(paths[\"review\"], \"review-report\")\n   391→            current_state_name = \"WAITING_MANUAL_REVIEW\" if review.get(\"requires_manual_review\") else \"REVIEWING\"\n   392→            reviewed_state = update_state(\n   393→                task[\"task_id\"],\n   394→                current_state_name,\n   395→                route=\"openclaw\",\n   396→                route_decision_id=route.get(\"route_decision_id\"),\n   397→                approval=direct_approval,\n   398→                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   399→                message=\"manual review required before publish\" if current_state_name == \"WAITING_MANUAL_REVIEW\" else \"reviewing direct result\",\n   400→            )\n   401→            sync_queue_for_task(task[\"task_id\"], state_payload=reviewed_state, route=route, dispatch=dispatch_plan, result=result, review=review)\n   402→            return 0\n   403→\n   404→        selected_lane = dispatch_plan.get(\"selected_lane\") or \"cli\"\n   405→        try:\n   406→            exit_code, result, dispatch_id, dispatch_attempt_id = run_claude_lane(\n   407→                task,\n   408→                route,\n   409→                approval_payload,\n   410→                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   411→                selected_lane=selected_lane,\n   412→                fallback_triggered=False,\n   413→            )\n   414→        except ApprovalError as exc:\n   415→            approval_state = update_state(\n   416→                task[\"task_id\"],\n   417→                \"WAITING_APPROVAL\",\n   418→                route=route[\"decision\"],\n   419→                route_decision_id=route.get(\"route_decision_id\"),\n   420→                approval={\"required\": True, \"approved\": False},\n   421→                protected_paths=route[\"protected_paths\"],\n   422→                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n   423→                message=str(exc),\n   424→            )\n   425→            sync_queue_for_task(task[\"task_id\"], state_payload=approval_state, route=route, dispatch=dispatch_plan)\n   426→            return 0\n   427→        except ValidationError as exc:\n   428→            approved_payload = dict(approval_payload)\n   429→            approved_payload[\"approved\"] = True\n   430→            update_state(\n   431→                task[\"task_id\"],\n   432→                \"REVIEW_FAILED\",\n   433→                route=route[\"decision\"],\n   434→                route_decision_id=route.get(\"route_decision_id\"),\n   435→                approval=approved_payload,\n   436→                message=str(exc),\n   437→            )\n   438→            review = {\n   439→                \"task_id\": task[\"task_id\"],\n   440→                \"verdict\": \"blocked\",\n   441→                \"summary\": \"Execution result schema validation failed.\",\n   442→                \"issues\": [str(exc)],\n   443→                \"publish_recommendation\": \"hold\",\n   444→            }\n   445→            atomic_write_json(paths[\"review\"], review)\n   446→            return 50\n   447→\n   448→        status = EXIT_CODE_TO_STATUS.get(exit_code, \"failed\")\n   449→        approved_payload = dict(approval_payload)\n   450→        approved_payload[\"approved\"] = True\n   451→        if result is None:\n   452→            failed_state = update_state(\n   453→                task[\"task_id\"],\n   454→                \"EXECUTION_FAILED\",\n   455→                route=route[\"decision\"],\n   456→                route_decision_id=route.get(\"route_decision_id\"),\n   457→                approval=approved_payload,\n   458→                dispatch_id=dispatch_id,\n   459→                message=\"executor returned without result\",\n   460→            )\n   461→            sync_queue_for_task(task[\"task_id\"], state_payload=failed_state, route=route, dispatch=dispatch_plan)\n   462→            return exit_code or 30\n   463→\n   464→        result_meta = result.get(\"_meta\") if isinstance(result.get(\"_meta\"), dict) else {}\n   465→        result_code = str(result_meta.get(\"result_code\") or \"\")\n   466→        if result_code == \"AUTH_REQUIRED\":\n   467→            auth_state = update_state(\n   468→                task[\"task_id\"],\n   469→                \"AUTH_REQUIRED\",\n   470→                route=route[\"decision\"],\n   471→                route_decision_id=route.get(\"route_decision_id\"),\n   472→                approval=approved_payload,\n   473→                dispatch_id=dispatch_id,\n   474→                message=\"Claude auth required before execution can continue\",\n   475→            )\n   476→            review = build_review_report({**task, \"approval\": approved_payload}, route, result)\n   477→            atomic_write_json(paths[\"review\"], review)\n   478→            ensure_schema_valid(paths[\"review\"], \"review-report\")\n   479→            sync_queue_for_task(task[\"task_id\"], state_payload=auth_state, route=route, dispatch=dispatch_plan, result=result, review=review)\n   480→            return exit_code or 30\n   481→\n   482→        if status != \"success\":\n   483→            fallback_allowed, fallback_reason = can_auto_fallback(task, result)\n   484→            fallback_lane = next_lane_after(selected_lane, dispatch_plan) if fallback_allowed else None\n   485→            if fallback_lane:\n   486→                dispatch_plan[\"selected_lane\"] = fallback_lane\n   487→                dispatch_plan[\"selection_reasons\"] = list(dispatch_plan.get(\"selection_reasons\", [])) + [f\"auto fallback {selected_lane}->{fallback_lane}: {fallback_reason}\"]\n   488→                atomic_write_json(paths[\"dispatch\"], dispatch_plan)\n   489→                lane_selection = {\n   490→                    \"task_id\": task[\"task_id\"],\n   491→                    \"provider\": dispatch_plan.get(\"selected_provider\", \"claude_code\"),\n   492→                    \"primary_mode\": dispatch_plan.get(\"primary_mode\", \"acp\"),\n   493→                    \"selected_lane\": dispatch_plan.get(\"selected_lane\", fallback_lane),\n   494→                    \"fallback_chain\": dispatch_plan.get(\"fallback_chain\", []),\n   495→                    \"selection_reasons\": dispatch_plan.get(\"selection_reasons\", []),\n   496→                    \"lane_health_snapshot\": dispatch_plan.get(\"lane_health_snapshot\", {}),\n   497→                    \"captured_at\": dispatch_plan.get(\"captured_at\") or now_iso(),\n   498→                    \"version\": 1,\n   499→                }\n   500→                if paths[\"lane_selection\"].exists():\n   501→                    lane_selection.update(read_lane_selection_artifact(paths[\"lane_selection\"], default={}) or {})\n   502→                lane_selection.update({\n   503→                    \"selected_lane\": fallback_lane,\n   504→                    \"selection_reasons\": dispatch_plan[\"selection_reasons\"],\n   505→                    \"captured_at\": lane_selection.get(\"captured_at\") or dispatch_plan.get(\"captured_at\") or now_iso(),\n   506→                    \"version\": 1,\n   507→                })\n   508→                write_lane_selection_artifact(paths[\"lane_selection\"], lane_selection)\n   509→                exit_code, result, dispatch_id, dispatch_attempt_id = run_claude_lane(\n   510→                    task,\n   511→                    route,\n   512→                    approved_payload,\n   513→                    dispatch_id=dispatch_id,\n   514→                    selected_lane=fallback_lane,\n   515→                    fallback_triggered=True,\n   516→                )\n   517→                status = EXIT_CODE_TO_STATUS.get(exit_code, \"failed\")\n   518→                result_meta = result.get(\"_meta\") if isinstance(result.get(\"_meta\"), dict) else {}\n   519→                result_code = str(result_meta.get(\"result_code\") or \"\")\n   520→                if result_code == \"AUTH_REQUIRED\":\n   521→                    auth_state = update_state(\n   522→                        task[\"task_id\"],\n   523→                        \"AUTH_REQUIRED\",\n   524→                        route=route[\"decision\"],\n   525→                        route_decision_id=route.get(\"route_decision_id\"),\n   526→                        approval=approved_payload,\n   527→                        dispatch_id=dispatch_id,\n   528→                        message=\"Claude auth required before execution can continue\",\n   529→                    )\n   530→                    review = build_review_report({**task, \"approval\": approved_payload}, route, result)\n   531→                    atomic_write_json(paths[\"review\"], review)\n   532→                    ensure_schema_valid(paths[\"review\"], \"review-report\")\n   533→                    sync_queue_for_task(task[\"task_id\"], state_payload=auth_state, route=route, dispatch=dispatch_plan, result=result, review=review)\n   534→                    return exit_code or 30\n   535→            if status != \"success\":\n   536→                target_state = \"WAITING_MANUAL_REVIEW\" if not fallback_allowed else \"EXECUTION_FAILED\"\n   537→                failed_state = update_state(\n   538→                    task[\"task_id\"],\n   539→                    target_state,\n   540→                    route=route[\"decision\"],\n   541→                    route_decision_id=route.get(\"route_decision_id\"),\n   542→                    approval=approved_payload,\n   543→                    dispatch_id=dispatch_id,\n   544→                    message=(f\"automatic fallback blocked: {fallback_reason}\" if target_state == \"WAITING_MANUAL_REVIEW\" else f\"executor finished with status={status}\"),\n   545→                )\n   546→                review = build_review_report({**task, \"approval\": approved_payload}, route, result)\n   547→                atomic_write_json(paths[\"review\"], review)\n   548→                sync_queue_for_task(task[\"task_id\"], state_payload=failed_state, route=route, dispatch=dispatch_plan, result=result, review=review)\n   549→                return exit_code\n   550→\n   551→        review = build_review_report({**task, \"approval\": approved_payload}, route, result)\n   552→        atomic_write_json(paths[\"review\"], review)\n   553→        ensure_schema_valid(paths[\"review\"], \"review-report\")\n   554→        current_state_name = \"WAITING_MANUAL_REVIEW\" if review.get(\"requires_manual_review\") else \"REVIEWING\"\n   555→        reviewed_state = update_state(\n   556→            task[\"task_id\"],\n   557→            current_state_name,\n   558→            route=route[\"decision\"],\n   559→            route_decision_id=route.get(\"route_decision_id\"),\n   560→            approval=approved_payload,\n   561→            dispatch_id=dispatch_id,\n   562→            message=\"manual review required before publish\" if current_state_name == \"WAITING_MANUAL_REVIEW\" else \"execution succeeded; entering review\",\n   563→        )\n   564→        sync_queue_for_task(task[\"task_id\"], state_payload=reviewed_state, route=route, dispatch=dispatch_plan, result=result, review=review)\n   565→        return 0\n   566→\n   567→\n   568→if __name__ == \"__main__\":\n   569→    sys.exit(main())\n   570→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7a3b2848-fb3c-4af3-9179-4363804c6042","uuid":"3726b64d-e950-4087-99fc-86fa1ca514f3","timestamp":"2026-03-22T07:41:20.872Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yusuke/.openclaw/workspace/.openclaw/scripts/execute_task.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nimport sys\nfrom pathlib import Path\n\nfrom task_runtime import (\n    ROOT,\n    WORKSPACE_ROOT,\n    ApprovalError,\n    ValidationError,\n    append_dispatch_attempt_artifact,\n    atomic_write_json,\n    atomic_write_text,\n    build_context_pack,\n    build_execution_request,\n    build_openclaw_result,\n    build_review_report,\n    build_task_record,\n    ensure_schema_valid,\n    is_plan_only_task,\n    is_write_task,\n    load_dispatch_attempts_artifact,\n    load_json,\n    read_lane_selection_artifact,\n    write_lane_selection_artifact,\n    new_operation_id,\n    now_iso,\n    route_task,\n    sync_queue_for_task,\n    task_lock,\n    task_paths,\n    update_state,\n    write_runtime_metrics,\n)\nfrom analyze_task import analyze_task\nfrom select_assignees import save_assignment_plan, select_assignment_plan\nfrom dispatch_task import build_dispatch_plan\n\nEXIT_CODE_TO_STATUS = {\n    0: \"success\",\n    10: \"policy_blocked\",\n    20: \"timeout\",\n    30: \"runtime_error\",\n    40: \"invalid_request\",\n    50: \"invalid_result\",\n}\n\n\ndef parse_args() -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Execute an OpenClaw task closed-loop\")\n    parser.add_argument(\"--task-id\", required=True)\n    parser.add_argument(\"--task\")\n    parser.add_argument(\"--paths\", nargs=\"*\", default=[])\n    parser.add_argument(\"--constraint\", action=\"append\", default=[])\n    parser.add_argument(\"--verify\", action=\"append\", default=[])\n    parser.add_argument(\"--review-focus\", action=\"append\", default=[])\n    parser.add_argument(\"--action\", action=\"append\", default=[])\n    parser.add_argument(\"--requested-route\", choices=[\"openclaw\", \"claude-code\"])\n    parser.add_argument(\"--task-file\", help=\"JSON file with task payload\")\n    return parser.parse_args()\n\n\ndef load_task_payload(args: argparse.Namespace) -> dict:\n    if args.task_file:\n        return json.loads(Path(args.task_file).read_text(encoding=\"utf-8\"))\n    return {\n        \"task\": args.task or \"\",\n        \"requested_paths\": args.paths,\n        \"constraints\": args.constraint,\n        \"verification_commands\": args.verify,\n        \"review_focus\": args.review_focus,\n        \"requested_actions\": args.action,\n        \"requested_route\": args.requested_route,\n    }\n\n\ndef next_dispatch_attempt_id(task_id: str, dispatch_id: str) -> tuple[str, int]:\n    attempts = load_dispatch_attempts_artifact(task_paths(task_id)[\"dispatch_attempts\"])\n    next_index = len(attempts) + 1\n    return f\"{dispatch_id}_attempt_{next_index:02d}\", next_index\n\n\ndef run_claude_lane(task: dict, route: dict, approval: dict, *, dispatch_id: str | None = None, selected_lane: str = \"cli\", fallback_triggered: bool = False) -> tuple[int, dict | None, str, str]:\n    paths = task_paths(task[\"task_id\"])\n    dispatch_id = dispatch_id or new_operation_id(\"dispatch\")\n    dispatch_attempt_id, attempt_index = next_dispatch_attempt_id(task[\"task_id\"], dispatch_id)\n    request = build_execution_request(task, route, dispatch_id=dispatch_id)\n    request[\"started_at\"] = now_iso()\n    request[\"dispatch_attempt_id\"] = dispatch_attempt_id\n    request[\"selected_lane\"] = selected_lane\n    request[\"task_type\"] = \"plan_only\" if is_plan_only_task(task) else \"write\" if is_write_task(task) else \"read_only\"\n    if selected_lane != \"acp\" and request.get(\"mock_mode\") in {\"acp_pre_session_failure\", \"pre_session_failure\"}:\n        request[\"mock_mode\"] = \"success\"\n    atomic_write_json(paths[\"request\"], request)\n    ensure_schema_valid(paths[\"request\"], \"execution-request\")\n\n    if route[\"approval_required\"] and not approval.get(\"approved\"):\n        raise ApprovalError(\"protected paths require approval before execution\")\n\n    update_state(\n        task[\"task_id\"],\n        \"READY_FOR_EXECUTION\",\n        route=route[\"decision\"],\n        route_decision_id=route.get(\"route_decision_id\"),\n        approval=approval,\n        dispatch_id=dispatch_id,\n        message=f\"execution request saved lane={selected_lane} attempt={dispatch_attempt_id}\",\n    )\n    update_state(\n        task[\"task_id\"],\n        \"RUNNING\",\n        route=route[\"decision\"],\n        route_decision_id=route.get(\"route_decision_id\"),\n        approval=approval,\n        dispatch_id=dispatch_id,\n        message=f\"executor started lane={selected_lane} attempt={dispatch_attempt_id}\",\n    )\n\n    command = [\n        \"bash\",\n        str(ROOT / \"scripts\" / \"run_claude_code.sh\"),\n        \"--request\",\n        str(paths[\"request\"]),\n        \"--result\",\n        str(paths[\"result\"]),\n        \"--stdout-log\",\n        str(paths[\"stdout\"]),\n        \"--stderr-log\",\n        str(paths[\"stderr\"]),\n    ]\n    if selected_lane == \"acp\":\n        command = [\n            \"python3\",\n            str(ROOT / \"scripts\" / \"run_claude_acp.py\"),\n            \"--request\",\n            str(paths[\"request\"]),\n            \"--result\",\n            str(paths[\"result\"]),\n            \"--stdout-log\",\n            str(paths[\"stdout\"]),\n            \"--stderr-log\",\n            str(paths[\"stderr\"]),\n        ]\n    completed = subprocess.run(command, cwd=str(WORKSPACE_ROOT), check=False)\n    result_payload = None\n    if paths[\"result\"].exists():\n        try:\n            result_payload = ensure_schema_valid(paths[\"result\"], \"execution-result\")\n        except ValidationError:\n            result_payload = load_json(paths[\"result\"], default={}) or {}\n            raise\n    result_meta = result_payload.get(\"_meta\") if isinstance((result_payload or {}).get(\"_meta\"), dict) else {}\n    attempt_payload = {\n        \"task_id\": task[\"task_id\"],\n        \"dispatch_id\": dispatch_id,\n        \"dispatch_attempt_id\": dispatch_attempt_id,\n        \"lane\": selected_lane,\n        \"attempt_index\": attempt_index,\n        \"status\": (result_payload or {}).get(\"status\") or EXIT_CODE_TO_STATUS.get(completed.returncode, \"failed\"),\n        \"exit_code\": completed.returncode,\n        \"started_at\": request.get(\"started_at\") or (result_payload or {}).get(\"started_at\"),\n        \"finished_at\": (result_payload or {}).get(\"finished_at\") or now_iso(),\n        \"result_code\": result_meta.get(\"result_code\"),\n        \"fallback_triggered\": fallback_triggered,\n        \"fallback_target\": selected_lane if fallback_triggered else None,\n        \"version\": 1,\n    }\n    append_dispatch_attempt_artifact(paths[\"dispatch_attempts\"], attempt_payload)\n    write_runtime_metrics()\n    return completed.returncode, result_payload, dispatch_id, dispatch_attempt_id\n\n\ndef resolve_route(task: dict, paths: dict, existing_state: dict) -> tuple[dict, bool]:\n    existing_route = load_json(paths[\"route\"], default={}) or {}\n    if existing_route and existing_state.get(\"state\") in {\n        \"WAITING_APPROVAL\",\n        \"AUTH_REQUIRED\",\n        \"READY_FOR_EXECUTION\",\n        \"WAITING_CAPACITY\",\n        \"WAITING_MANUAL_REVIEW\",\n        \"RUNNING\",\n        \"REVIEWING\",\n        \"PUBLISHED\",\n        \"EXECUTION_FAILED\",\n        \"REVIEW_FAILED\",\n    }:\n        ensure_schema_valid(paths[\"route\"], \"route-decision\")\n        return existing_route, True\n    route = route_task(task)\n    atomic_write_json(paths[\"route\"], route)\n    return route, False\n\n\ndef resolve_dispatch(task: dict, paths: dict, existing_state: dict, assignment_plan: dict) -> tuple[dict, bool]:\n    existing_dispatch = load_json(paths[\"dispatch\"], default={}) or {}\n    if existing_dispatch and existing_state.get(\"state\") in {\n        \"WAITING_APPROVAL\",\n        \"AUTH_REQUIRED\",\n        \"READY_FOR_EXECUTION\",\n        \"WAITING_CAPACITY\",\n        \"WAITING_MANUAL_REVIEW\",\n        \"RUNNING\",\n        \"REVIEWING\",\n        \"PUBLISHED\",\n        \"EXECUTION_FAILED\",\n        \"REVIEW_FAILED\",\n    }:\n        ensure_schema_valid(paths[\"dispatch\"], \"dispatch-plan\")\n        if paths[\"lane_selection\"].exists():\n            read_lane_selection_artifact(paths[\"lane_selection\"])\n        return existing_dispatch, True\n    dispatch = build_dispatch_plan(task, assignment_plan)\n    return dispatch, False\n\n\ndef can_auto_fallback(task: dict, result: dict | None) -> tuple[bool, str]:\n    meta = result.get(\"_meta\") if isinstance((result or {}).get(\"_meta\"), dict) else {}\n    result_code = str(meta.get(\"result_code\") or \"\")\n    failure_stage = str(meta.get(\"failure_stage\") or \"\")\n    partial_execution = bool(meta.get(\"partial_execution\", False))\n    side_effects_possible = bool(meta.get(\"side_effects_possible\", False))\n    if result_code == \"AUTH_REQUIRED\":\n        return True, \"auth failure before execution\"\n    if failure_stage in {\"session_start\", \"health_check\", \"capacity_check\", \"auth_preflight\"}:\n        return True, f\"pre-execution failure: {failure_stage}\"\n    if not is_write_task(task):\n        return True, \"read-only or plan-only task\"\n    if partial_execution or side_effects_possible or failure_stage in {\"execution\", \"worktree_created\", \"edit_started\"}:\n        return False, \"write task may have side effects\"\n    return False, \"write task fallback is disabled by policy\"\n\n\ndef next_lane_after(current_lane: str, dispatch_plan: dict) -> str | None:\n    chain = [str(item) for item in dispatch_plan.get(\"fallback_chain\", []) if isinstance(item, str)]\n    if current_lane not in chain:\n        return None\n    idx = chain.index(current_lane)\n    return chain[idx + 1] if idx + 1 < len(chain) else None\n\n\ndef main() -> int:\n    args = parse_args()\n    payload = load_task_payload(args)\n    task = build_task_record(args.task_id, payload)\n    paths = task_paths(task[\"task_id\"])\n\n    with task_lock(paths[\"dir\"]):\n        existing_task = load_json(paths[\"task\"], default={}) or {}\n        existing_state = load_json(paths[\"state\"], default={}) or {}\n        merged_task = dict(existing_task)\n        merged_task.update({k: v for k, v in task.items() if v not in (None, [], \"\")})\n        task = merged_task\n        atomic_write_json(paths[\"task\"], task)\n\n        existing_approval = existing_state.get(\"approval\", {}) if existing_state else {}\n        approval_payload = {\n            \"required\": False,\n            \"approved\": bool(existing_approval.get(\"approved\")),\n        }\n        for key in (\"approved_by\", \"approved_at\", \"note\"):\n            if key in existing_approval:\n                approval_payload[key] = existing_approval[key]\n        if not existing_state:\n            update_state(task[\"task_id\"], \"RECEIVED\", message=\"task stored\", approval=approval_payload)\n\n        assignment_plan = load_json(paths[\"assignment\"], default={}) or {}\n        if not assignment_plan:\n            try:\n                assignment_plan = select_assignment_plan(analyze_task(task))\n                save_assignment_plan(assignment_plan, paths[\"assignment\"])\n            except Exception as exc:  # noqa: BLE001\n                print(f\"warning: assignment planning skipped: {exc}\", file=sys.stderr)\n\n        route, reused_route = resolve_route(task, paths, existing_state)\n        dispatch_plan, reused_dispatch = resolve_dispatch(task, paths, existing_state, assignment_plan)\n        dispatch_mode = dispatch_plan.get(\"execution_mode\")\n        dispatch_route = route[\"decision\"]\n        if dispatch_mode == \"openclaw\":\n            dispatch_route = \"openclaw\"\n        elif dispatch_mode in {\"claude_code\", \"split\", \"plan_only\"}:\n            dispatch_route = \"claude-code\"\n        route[\"decision\"] = dispatch_route\n        approval_payload[\"required\"] = route[\"approval_required\"]\n        if not reused_route:\n            route[\"dispatch_mode\"] = dispatch_mode\n            update_state(\n                task[\"task_id\"],\n                \"ROUTED\",\n                route=dispatch_route,\n                route_decision_id=route.get(\"route_decision_id\"),\n                approval=approval_payload,\n                protected_paths=route[\"protected_paths\"],\n                dispatch_id=dispatch_plan.get(\"dispatch_id\"),\n                message=\"route decision stored\",\n            )\n\n        should_emit_context_pack = dispatch_mode != \"plan_only\" or bool(dispatch_plan.get(\"pre_auth_openclaw_phase\"))\n        if should_emit_context_pack:\n            atomic_write_text(paths[\"context\"], build_context_pack(task, route))\n\n        if dispatch_mode == \"qu