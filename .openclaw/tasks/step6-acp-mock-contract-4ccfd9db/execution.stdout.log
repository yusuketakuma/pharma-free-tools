":"toolu_012UP42vVprVSiR5CUvGVHvw","type":"tool_result","content":"     1→#!/usr/bin/env python3\n     2→from __future__ import annotations\n     3→\n     4→import argparse\n     5→import json\n     6→import subprocess\n     7→from pathlib import Path\n     8→from datetime import datetime\n     9→from typing import Any, Dict, List, Tuple\n    10→\n    11→from analyze_task import analyze_task\n    12→from task_runtime import (\n    13→    CONFIG_ROOT,\n    14→    ROOT,\n    15→    ValidationError,\n    16→    atomic_write_json,\n    17→    ensure_schema_valid,\n    18→    write_lane_selection_artifact,\n    19→    is_plan_only_task,\n    20→    is_write_task,\n    21→    load_claude_code_config,\n    22→    load_json,\n    23→    new_operation_id,\n    24→    now_iso,\n    25→    task_paths,\n    26→)\n    27→\n    28→\n    29→CAPACITY_RUNTIME_ROOT = ROOT / \"runtime\" / \"capacity\"\n    30→HEALTH_RUNTIME_ROOT = ROOT / \"runtime\" / \"health\"\n    31→LANE_HEALTH_FRESHNESS_SEC = 900\n    32→\n    33→\n    34→def load_json_like(path: Path, default: Dict[str, Any] | None = None) -> Dict[str, Any]:\n    35→    if not path.exists():\n    36→        return dict(default or {})\n    37→    return json.loads(path.read_text(encoding=\"utf-8\"))\n    38→\n    39→\n    40→def parse_args() -> argparse.Namespace:\n    41→    parser = argparse.ArgumentParser(description=\"Build capacity snapshot + dispatch plan\")\n    42→    parser.add_argument(\"--task-id\")\n    43→    parser.add_argument(\"--task-file\")\n    44→    parser.add_argument(\"--assignment-plan\")\n    45→    parser.add_argument(\"--output\")\n    46→    return parser.parse_args()\n    47→\n    48→\n    49→def load_task(args: argparse.Namespace) -> Dict[str, Any]:\n    50→    if args.task_file:\n    51→        payload = json.loads(Path(args.task_file).read_text(encoding=\"utf-8\"))\n    52→        if args.task_id and \"task_id\" not in payload:\n    53→            payload[\"task_id\"] = args.task_id\n    54→        return payload\n    55→    if not args.task_id:\n    56→        raise ValidationError(\"--task-id or --task-file is required\")\n    57→    task = load_json(task_paths(args.task_id)[\"task\"], default=None)\n    58→    if not task:\n    59→        raise ValidationError(f\"task not found: {args.task_id}\")\n    60→    return task\n    61→\n    62→\n    63→def load_assignment_plan(task_id: str, explicit: str | None) -> Dict[str, Any]:\n    64→    path = Path(explicit) if explicit else task_paths(task_id)[\"assignment\"]\n    65→    plan = load_json(path, default=None)\n    66→    if not plan:\n    67→        raise ValidationError(f\"assignment plan not found: {path}\")\n    68→    temp = path.parent / \"assignment-plan.dispatch.validate.json\"\n    69→    temp.write_text(json.dumps(plan, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n    70→    ensure_schema_valid(temp, \"assignment-plan\")\n    71→    return plan\n    72→\n    73→\n    74→def refresh_provider_snapshots() -> Tuple[Dict[str, Any], Dict[str, Any]]:\n    75→    subprocess.run([\"python3\", str(ROOT / \"scripts\" / \"provider_capacity_openai.py\")], check=True, capture_output=True, text=True)\n    76→    subprocess.run([\"python3\", str(ROOT / \"scripts\" / \"provider_capacity_claude.py\")], check=True, capture_output=True, text=True)\n    77→    openclaw = load_json(CAPACITY_RUNTIME_ROOT / \"openai-capacity.json\", default={}) or {}\n    78→    claude = load_json(CAPACITY_RUNTIME_ROOT / \"claude-capacity.json\", default={}) or {}\n    79→    return openclaw, claude\n    80→\n    81→\n    82→def build_capacity_snapshot(task_id: str) -> Dict[str, Any]:\n    83→    openclaw, claude = refresh_provider_snapshots()\n    84→    captured_at = max(str(openclaw.get(\"captured_at\", \"\")), str(claude.get(\"captured_at\", \"\"))) or now_iso()\n    85→    snapshot = {\n    86→        \"task_id\": task_id,\n    87→        \"captured_at\": captured_at,\n    88→        \"providers\": {\n    89→            \"openclaw\": openclaw,\n    90→            \"claude_code\": claude,\n    91→        },\n    92→    }\n    93→    temp = task_paths(task_id)[\"dir\"] / \"capacity-snapshot.validate.json\"\n    94→    temp.parent.mkdir(parents=True, exist_ok=True)\n    95→    temp.write_text(json.dumps(snapshot, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n    96→    ensure_schema_valid(temp, \"capacity-snapshot\")\n    97→    atomic_write_json(CAPACITY_RUNTIME_ROOT / \"latest-capacity.json\", snapshot)\n    98→    return snapshot\n    99→\n   100→\n   101→def is_heavy_task(task: Dict[str, Any], intake: Dict[str, Any], assignment: Dict[str, Any]) -> bool:\n   102→    requested_paths = task.get(\"requested_paths\", intake.get(\"requested_paths\", []))\n   103→    text = (task.get(\"task\") or intake.get(\"task_summary\") or \"\").lower()\n   104→    return (\n   105→        intake.get(\"complexity\") in {\"high\", \"very_high\"}\n   106→        or len(requested_paths) > 1\n   107→        or \"multi-file-change\" in intake.get(\"required_capabilities\", [])\n   108→        or any(token in text for token in [\"implement\", \"refactor\", \"migration\", \"heavy\", \"multi-file\"])\n   109→        or len(assignment.get(\"active_subroles\", [])) > 0\n   110→    )\n   111→\n   112→\n   113→def is_multi_file_write(task: Dict[str, Any], intake: Dict[str, Any]) -> bool:\n   114→    requested_paths = task.get(\"requested_paths\", intake.get(\"requested_paths\", []))\n   115→    text = (task.get(\"task\") or intake.get(\"task_summary\") or \"\").lower()\n   116→    if len(requested_paths) <= 1:\n   117→        return False\n   118→    read_only_markers = [\"read-only\", \"read only\", \"without changing files\", \"no file changes\"]\n   119→    return not any(marker in text for marker in read_only_markers)\n   120→\n   121→\n   122→def is_single_department_light(intake: Dict[str, Any], assignment: Dict[str, Any]) -> bool:\n   123→    return (\n   124→        len(intake.get(\"departments_involved\", [])) == 1\n   125→        and intake.get(\"complexity\") == \"low\"\n   126→        and intake.get(\"risk_level\") == \"low\"\n   127→        and not assignment.get(\"active_subroles\")\n   128→    )\n   129→\n   130→\n   131→def has_pre_auth_openclaw_value(task: Dict[str, Any], intake: Dict[str, Any], assignment: Dict[str, Any]) -> bool:\n   132→    desired_outputs = {str(item) for item in intake.get(\"desired_outputs\", [])}\n   133→    required_capabilities = {str(item) for item in intake.get(\"required_capabilities\", [])}\n   134→    review_focus = {str(item).lower() for item in task.get(\"review_focus\", [])}\n   135→    constraints = \" \".join(str(item) for item in task.get(\"constraints\", []))\n   136→    return bool(\n   137→        desired_outputs.intersection({\"doc\", \"plan\", \"report\", \"task-brief\"})\n   138→        or required_capabilities.intersection({\"docs\", \"copy\", \"analysis\", \"coordination\", \"requirements\"})\n   139→        or any(token in constraints.lower() for token in [\"context pack\", \"docs draft\", \"reviewer template\"])\n   140→        or any(token in review_focus for token in [\"reviewer\", \"documentation\", \"docs\"])\n   141→        or len(assignment.get(\"advisory_subroles\", [])) > 0\n   142→    )\n   143→\n   144→\n   145→def pressure_level_openclaw(snapshot: Dict[str, Any], policy: Dict[str, Any]) -> str:\n   146→    thresholds = policy[\"providers\"][\"openclaw\"][\"thresholds\"]\n   147→    usage = max(float(snapshot.get(\"usage_pressure\", 0)), float(snapshot.get(\"cost_pressure\", 0)))\n   148→    if snapshot.get(\"hard_blocked\") or usage >= float(thresholds[\"hard_pressure_at\"]):\n   149→        return \"hard\"\n   150→    if usage >= float(thresholds[\"high_pressure_at\"]):\n   151→        return \"high\"\n   152→    return \"normal\"\n   153→\n   154→\n   155→def pressure_level_claude(snapshot: Dict[str, Any], policy: Dict[str, Any]) -> str:\n   156→    thresholds = policy[\"providers\"][\"claude_code\"][\"thresholds\"]\n   157→    pressure = max(\n   158→        float(snapshot.get(\"rpm_pressure\", 0)),\n   159→        float(snapshot.get(\"itpm_pressure\", 0)),\n   160→        float(snapshot.get(\"otpm_pressure\", 0)),\n   161→        float(snapshot.get(\"spend_pressure\", 0)),\n   162→    )\n   163→    if snapshot.get(\"hard_blocked\") or pressure >= float(thresholds[\"hard_pressure_at\"]):\n   164→        return \"hard\"\n   165→    if pressure >= float(thresholds[\"high_pressure_at\"]) or float(snapshot.get(\"retry_after_sec\", 0)) >= float(thresholds[\"retry_after_high_at\"]):\n   166→        return \"high\"\n   167→    return \"normal\"\n   168→\n   169→\n   170→def load_lane_probe(max_age_sec: int = LANE_HEALTH_FRESHNESS_SEC) -> Tuple[Dict[str, Any], bool]:\n   171→    path = HEALTH_RUNTIME_ROOT / \"lane-health.json\"\n   172→    payload = load_json(path, default={}) or {}\n   173→    captured_at = payload.get(\"captured_at\") if isinstance(payload, dict) else None\n   174→    captured_dt = None\n   175→    if captured_at:\n   176→        try:\n   177→            captured_dt = datetime.fromisoformat(str(captured_at))\n   178→        except Exception:  # noqa: BLE001\n   179→            captured_dt = None\n   180→    is_fresh = False\n   181→    if captured_dt is not None:\n   182→        is_fresh = (datetime.now(captured_dt.tzinfo or None) - captured_dt).total_seconds() <= max_age_sec\n   183→    return payload if isinstance(payload, dict) else {}, is_fresh\n   184→\n   185→\n   186→def lane_health_snapshot(task: Dict[str, Any], claude_snapshot: Dict[str, Any]) -> Dict[str, Any]:\n   187→    metrics = load_json(ROOT / \"runtime\" / \"metrics\" / \"latest-metrics.json\", default={}) or {}\n   188→    probe_payload, probe_fresh = load_lane_probe()\n   189→    probe_lanes = probe_payload.get(\"lanes\") if isinstance(probe_payload.get(\"lanes\"), dict) else {}\n   190→    auth_payload = probe_payload.get(\"auth\") if isinstance(probe_payload.get(\"auth\"), dict) else {}\n   191→\n   192→    auth_ok = bool(claude_snapshot.get(\"auth_ok\", True))\n   193→    acp_healthy = bool(claude_snapshot.get(\"acp_healthy\", claude_snapshot.get(\"healthy\", False)))\n   194→    cli_healthy = bool(claude_snapshot.get(\"cli_healthy\", claude_snapshot.get(\"healthy\", False)))\n   195→    cli_backend_healthy = bool(claude_snapshot.get(\"cli_backend_healthy\", cli_healthy))\n   196→    lane_errors: Dict[str, Any] = {}\n   197→    lane_latencies: Dict[str, Any] = {}\n   198→    probe_transport: Dict[str, Any] = {}\n   199→\n   200→    if probe_fresh:\n   201→        auth_ok = bool(auth_payload.get(\"auth_ok\", auth_ok))\n   202→        acp = probe_lanes.get(\"acp\") if isinstance(probe_lanes.get(\"acp\"), dict) else {}\n   203→        cli = probe_lanes.get(\"cli\") if isinstance(probe_lanes.get(\"cli\"), dict) else {}\n   204→        cli_backend = probe_lanes.get(\"cli_backend_safety_net\") if isinstance(probe_lanes.get(\"cli_backend_safety_net\"), dict) else {}\n   205→        acp_healthy = bool(acp.get(\"healthy\", acp_healthy))\n   206→        cli_healthy = bool(cli.get(\"healthy\", cli_healthy))\n   207→        cli_backend_healthy = bool(cli_backend.get(\"healthy\", cli_backend_healthy))\n   208→        lane_errors = {\n   209→            \"acp\": acp.get(\"last_error\"),\n   210→            \"cli\": cli.get(\"last_error\"),\n   211→            \"cli_backend_safety_net\": cli_backend.get(\"last_error\"),\n   212→        }\n   213→        lane_latencies = {\n   214→            \"acp\": acp.get(\"latency_ms\"),\n   215→            \"cli\": cli.get(\"latency_ms\"),\n   216→            \"cli_backend_safety_net\": cli_backend.get(\"latency_ms\"),\n   217→        }\n   218→        probe_transport = {\n   219→            \"acp\": acp.get(\"transport_kind\"),\n   220→            \"cli\": cli.get(\"transport_kind\"),\n   221→            \"cli_backend_safety_net\": cli_backend.get(\"transport_kind\"),\n   222→        }\n   223→\n   224→    return {\n   225→        \"auth_ok\": auth_ok,\n   226→        \"acp_healthy\": acp_healthy,\n   227→        \"cli_healthy\": cli_healthy,\n   228→        \"cli_backend_healthy\": cli_backend_healthy,\n   229→        \"acp_last_success_at\": metrics.get(\"acp_last_success_at\"),\n   230→        \"cli_last_success_at\": metrics.get(\"cli_last_success_at\"),\n   231→        \"acp_consecutive_failures\": int(metrics.get(\"acp_consecutive_failures\", 0) or 0),\n   232→        \"cli_consecutive_failures\": int(metrics.get(\"cli_consecutive_failures\", 0) or 0),\n   233→        \"retry_after_sec\": float(claude_snapshot.get(\"retry_after_sec\", 0) or 0),\n   234→        \"hard_blocked\": bool(claude_snapshot.get(\"hard_blocked\", False)),\n   235→        \"probe_fresh\": probe_fresh,\n   236→        \"probe_path\": str((HEALTH_RUNTIME_ROOT / \"lane-health.json\").relative_to(ROOT.parent)),\n   237→        \"lane_last_error\": lane_errors,\n   238→        \"lane_latency_ms\": lane_latencies,\n   239→        \"lane_transport\": probe_transport,\n   240→        \"captured_at\": (probe_payload.get(\"captured_at\") if probe_fresh else claude_snapshot.get(\"captured_at\")) or now_iso(),\n   241→    }\n   242→\n   243→\n   244→def fallback_chain_for_primary_mode(primary_mode: str) -> List[str]:\n   245→    if primary_mode == \"cli\":\n   246→        return [\"cli\", \"cli_backend_safety_net\"]\n   247→    return [\"acp\", \"cli\", \"cli_backend_safety_net\"]\n   248→\n   249→\n   250→def select_claude_lane(task: Dict[str, Any], claude_snapshot: Dict[str, Any]) -> Tuple[str, List[str], List[str], Dict[str, Any], str | None]:\n   251→    config = load_claude_code_config()\n   252→    primary_mode = str(config.get(\"primary_mode\") or \"acp\")\n   253→    fallback_chain = fallback_chain_for_primary_mode(primary_mode)\n   254→    health = lane_health_snapshot(task, claude_snapshot)\n   255→    reasons: List[str] = [f\"primary_mode={primary_mode}\"]\n   256→    if not health[\"auth_ok\"]:\n   257→        reasons.append(\"claude auth unavailable\")\n   258→        return \"none\", reasons, fallback_chain, health, \"waiting_auth\"\n   259→\n   260→    for lane in fallback_chain:\n   261→        healthy_key = {\n   262→            \"acp\": \"acp_healthy\",\n   263→            \"cli\": \"cli_healthy\",\n   264→            \"cli_backend_safety_net\": \"cli_backend_healthy\",\n   265→        }[lane]\n   266→        if health.get(healthy_key):\n   267→            reasons.append(f\"selected {lane} because {healthy_key}=true\")\n   268→            return lane, reasons, fallback_chain, health, None\n   269→        reasons.append(f\"skip {lane} because {healthy_key}=false\")\n   270→\n   271→    reasons.append(\"no Claude lane healthy\")\n   272→    return \"none\", reasons, fallback_chain, health, \"waiting_capacity\"\n   273→\n   274→\n   275→def role_provider_preference(role_name: str) -> List[str]:\n   276→    role_caps = load_json_like(CONFIG_ROOT / \"role-capability.yaml\")\n   277→    role = (role_caps.get(\"roles\") or {}).get(role_name, {})\n   278→    prefs = role.get(\"default_provider_preference\") or [\"openclaw\", \"claude-code\"]\n   279→    normalized: List[str] = []\n   280→    for item in prefs:\n   281→        if item == \"claude-code\":\n   282→            normalized.append(\"claude_code\")\n   283→        else:\n   284→            normalized.append(str(item))\n   285→    return normalized\n   286→\n   287→\n   288→def score_provider(provider: str, intake: Dict[str, Any], assignment: Dict[str, Any], snapshot: Dict[str, Any], policy: Dict[str, Any], *, heavy: bool, multi_file_write: bool) -> Dict[str, float]:\n   289→    provider_policy = policy[\"providers\"][provider]\n   290→    preferred_for = set(provider_policy.get(\"preferred_for\", []))\n   291→    lead_pref = role_provider_preference(assignment[\"lead_role\"])\n   292→    capability_fit = 0.9 if (provider == \"claude_code\" and heavy) else 0.9 if (provider == \"openclaw\" and not heavy) else 0.45\n   293→    if multi_file_write and provider == \"claude_code\":\n   294→        capability_fit = min(1.0, capability_fit + 0.1)\n   295→    if is_single_department_light(intake, assignment) and provider == \"openclaw\":\n   296→        capability_fit = 1.0\n   297→\n   298→    preference_tokens = set()\n   299→    if is_single_department_light(intake, assignment):\n   300→        preference_tokens.add(\"single_department_light\")\n   301→    if \"docs\" in intake.get(\"required_capabilities\", []) or \"doc\" in intake.get(\"desired_outputs\", []):\n   302→        preference_tokens.add(\"docs\")\n   303→    if heavy:\n   304→        preference_tokens.update({\"heavy_code\", \"implementation\", \"multi_file_change\"})\n   305→    provider_preference_fit = 0.7 if any(token in preferred_for for token in preference_tokens) else 0.4\n   306→    if lead_pref and lead_pref[0] == provider:\n   307→        provider_preference_fit = min(1.0, provider_preference_fit + 0.2)\n   308→\n   309→    historical_success = 0.82 if provider == \"claude_code\" else 0.78\n   310→    latency_fit = 0.85 if (provider == \"openclaw\" and not heavy) else 0.7 if provider == \"claude_code\" else 0.45\n   311→    if provider == \"openclaw\":\n   312→        limit_pressure = max(float(snapshot.get(\"usage_pressure\", 0)), 1.0 - float(snapshot.get(\"remaining_requests_ratio\", 1)), 1.0 - float(snapshot.get(\"remaining_tokens_ratio\", 1)))\n   313→        cost_pressure = float(snapshot.get(\"cost_pressure\", 0))\n   314→    else:\n   315→        limit_pressure = max(float(snapshot.get(\"rpm_pressure\", 0)), float(snapshot.get(\"itpm_pressure\", 0)), float(snapshot.get(\"otpm_pressure\", 0)))\n   316→        cost_pressure = float(snapshot.get(\"spend_pressure\", 0))\n   317→    queue_penalty = 0.2 if provider == \"claude_code\" and heavy else 0.05\n   318→    risk_penalty = 0.25 if (multi_file_write and provider == \"openclaw\") else 0.15 if intake.get(\"risk_level\") in {\"high\", \"critical\"} and provider == \"openclaw\" else 0.05\n   319→    total = round(capability_fit + provider_preference_fit + historical_success + latency_fit - limit_pressure - cost_pressure - queue_penalty - risk_penalty, 3)\n   320→    return {\n   321→        \"capability_fit\": round(capability_fit, 3),\n   322→        \"provider_preference_fit\": round(provider_preference_fit, 3),\n   323→        \"historical_success\": round(historical_success, 3),\n   324→        \"latency_fit\": round(latency_fit, 3),\n   325→        \"limit_pressure\": round(limit_pressure, 3),\n   326→        \"cost_pressure\": round(cost_pressure, 3),\n   327→        \"queue_penalty\": round(queue_penalty, 3),\n   328→        \"risk_penalty\": round(risk_penalty, 3),\n   329→        \"total\": total,\n   330→    }\n   331→\n   332→\n   333→def choose_execution_mode(task: Dict[str, Any], intake: Dict[str, Any], assignment: Dict[str, Any], snapshot: Dict[str, Any], policy: Dict[str, Any]) -> Tuple[str, str, List[str], Dict[str, float], Dict[str, Any]]:\n   334→    openclaw = snapshot[\"providers\"][\"openclaw\"]\n   335→    claude = snapshot[\"providers\"][\"claude_code\"]\n   336→    heavy = is_heavy_task(task, intake, assignment)\n   337→    multi_file_write = is_multi_file_write(task, intake)\n   338→    openclaw_pressure = pressure_level_openclaw(openclaw, policy)\n   339→    claude_pressure = pressure_level_claude(claude, policy)\n   340→    reasons: List[str] = []\n   341→    flags: Dict[str, Any] = {}\n   342→\n   343→    openclaw_scores = score_provider(\"openclaw\", intake, assignment, openclaw, policy, heavy=heavy, multi_file_write=multi_file_write)\n   344→    claude_scores = score_provider(\"claude_code\", intake, assignment, claude, policy, heavy=heavy, multi_file_write=multi_file_write)\n   345→\n   346→    if not claude.get(\"auth_ok\", True):\n   347→        preprocess_value = has_pre_auth_openclaw_value(task, intake, assignment)\n   348→        flags.update({\n   349→            \"auth_blocked\": True,\n   350→            \"auth_blocked_provider\": \"claude_code\",\n   351→            \"pre_auth_openclaw_phase\": preprocess_value,\n   352→            \"queue_reason\": \"waiting_auth\",\n   353→        })\n   354→        reasons.append(\"Claude auth NG のため claude_code 実行は保留\")\n   355→        if preprocess_value:\n   356→            reasons.append(\"OpenClaw 前処理価値ありのため context pack / docs draft 系のみ先行\")\n   357→        else:\n   358→            reasons.append(\"OpenClaw 前処理価値が薄いため即 WAITING_AUTH\")\n   359→        reasons.append(\"route / dispatch を再積みせず auth 回復後に READY_FOR_EXECUTION へ戻す\")\n   360→        return \"plan_only\", \"claude-code\", reasons, claude_scores, flags\n   361→\n   362→    if openclaw_pressure in {\"high\", \"hard\"} and claude_pressure in {\"high\", \"hard\"}:\n   363→        reasons.append(\"両 provider が high pressure のため queued\")\n   364→        flags[\"queue_reason\"] = \"waiting_capacity\"\n   365→        return \"queued\", \"plan_only\", reasons, claude_scores if claude_scores[\"total\"] >= openclaw_scores[\"total\"] else openclaw_scores, flags\n   366→\n   367→    if heavy and openclaw_pressure == \"hard\":\n   368→        reasons.append(\"OpenClaw hard pressure のため heavy task を流さない\")\n   369→        if claude_pressure == \"normal\":\n   370→            return \"claude_code\", \"claude-code\", reasons, claude_scores, flags\n   371→        if multi_file_write:\n   372→            reasons.append(\"heavy write を誤 dispatch しないため queued\")\n   373→            flags[\"queue_reason\"] = \"waiting_capacity\"\n   374→            return \"queued\", \"plan_only\", reasons, claude_scores, flags\n   375→        return \"plan_only\", \"plan_only\", reasons, claude_scores, flags\n   376→\n   377→    if multi_file_write and claude_pressure == \"hard\":\n   378→        reasons.append(\"Claude hard pressure のため multi-file write を流さない\")\n   379→        flags[\"queue_reason\"] = \"waiting_capacity\"\n   380→        return \"queued\", \"plan_only\", reasons, claude_scores, flags\n   381→\n   382→    if heavy and multi_file_write and claude_pressure in {\"high\", \"hard\"}:\n   383→        reasons.append(\"heavy multi-file write は安全側で queued\")\n   384→        flags[\"queue_reason\"] = \"waiting_capacity\"\n   385→        return \"queued\", \"plan_only\", reasons, claude_scores, flags\n   386→\n   387→    if is_single_department_light(intake, assignment) and openclaw_pressure == \"normal\":\n   388→        reasons.append(\"単一部門・軽タスクのため openclaw\")\n   389→        return \"openclaw\", \"openclaw\", reasons, openclaw_scores, flags\n   390→\n   391→    if heavy and claude.get(\"healthy\", False) and claude_pressure == \"normal\":\n   392→        if assignment.get(\"active_subroles\") or len(assignment.get(\"departments_involved\", [])) > 1:\n   393→            reasons.append(\"重いコードタスク + Claude healthy + 複数役割のため split\")\n   394→            return \"split\", \"claude-code\", reasons, claude_scores, flags\n   395→        reasons.append(\"重いコードタスク + Claude healthy のため claude_code\")\n   396→        return \"claude_code\", \"claude-code\", reasons, claude_scores, flags\n   397→\n   398→    if claude_scores[\"total\"] > openclaw_scores[\"total\"] and claude.get(\"healthy\", False) and claude_pressure != \"hard\":\n   399→        reasons.append(\"score 優位のため claude_code\")\n   400→        return \"claude_code\", \"claude-code\", reasons, claude_scores, flags\n   401→\n   402→    if task.get(\"requested_route\") == \"claude-code\" and claude_pressure != \"hard\":\n   403→        reasons.append(\"requested_route=claude-code を尊重\")\n   404→        return \"claude_code\", \"claude-code\", reasons, claude_scores, flags\n   405→\n   406→    if openclaw_pressure != \"hard\":\n   407→        reasons.append(\"safe fallback として openclaw\")\n   408→        return \"openclaw\", \"openclaw\", reasons, openclaw_scores, flags\n   409→\n   410→    reasons.append(\"安全側で plan_only\")\n   411→    return \"plan_only\", \"plan_only\", reasons, openclaw_scores, flags\n   412→\n   413→\n   414→def build_provider_assignments(assignment: Dict[str, Any], execution_mode: str, *, auth_blocked: bool = False) -> Dict[str, Any]:\n   415→    if auth_blocked:\n   416→        lead_provider = \"claude_code\"\n   417→        lead_executor = \"deferred\"\n   418→    else:\n   419→        lead_provider = \"claude_code\" if execution_mode in {\"claude_code\", \"split\"} else \"openclaw\" if execution_mode == \"openclaw\" else \"plan_only\"\n   420→        lead_executor = \"claude-code\" if execution_mode in {\"claude_code\", \"split\"} else \"openclaw\" if execution_mode == \"openclaw\" else \"deferred\"\n   421→    subroles = []\n   422→    for role in assignment.get(\"active_subroles\", []):\n   423→        provider = \"openclaw\" if execution_mode == \"split\" and not auth_blocked else lead_provider\n   424→        executor = \"openclaw\" if execution_mode == \"split\" and not auth_blocked else lead_executor\n   425→        subroles.append({\"role\": role, \"provider\": provider, \"executor\": executor})\n   426→    for role in assignment.get(\"advisory_subroles\", []):\n   427→        subroles.append({\"role\": role, \"provider\": \"openclaw\", \"executor\": \"openclaw\", \"mode\": \"advisory\"})\n   428→    return {\n   429→        \"lead\": {\n   430→            \"role\": assignment[\"lead_role\"],\n   431→            \"provider\": lead_provider,\n   432→            \"executor\": lead_executor,\n   433→        },\n   434→        \"subroles\": subroles,\n   435→    }\n   436→\n   437→\n   438→def build_dispatch_plan(task: Dict[str, Any], assignment: Dict[str, Any]) -> Dict[str, Any]:\n   439→    policy = load_json_like(CONFIG_ROOT / \"capacity-policy.yaml\")\n   440→    snapshot = build_capacity_snapshot(task[\"task_id\"])\n   441→    intake = analyze_task(task)\n   442→    execution_mode, selected_executor, reasons, scores, flags = choose_execution_mode(task, intake, assignment, snapshot, policy)\n   443→    auth_blocked = bool(flags.get(\"auth_blocked\"))\n   444→    selected_provider = \"claude_code\" if auth_blocked or execution_mode in {\"claude_code\", \"split\"} else \"openclaw\" if execution_mode == \"openclaw\" else \"plan_only\"\n   445→    selected_lane = \"none\"\n   446→    selection_reasons: List[str] = []\n   447→    fallback_chain: List[str] = []\n   448→    lane_snapshot: Dict[str, Any] = {}\n   449→    queue_reason = flags.get(\"queue_reason\")\n   450→    primary_mode = load_claude_code_config().get(\"primary_mode\", \"acp\")\n   451→    if selected_provider == \"claude_code\":\n   452→        selected_lane, selection_reasons, fallback_chain, lane_snapshot, lane_queue_reason = select_claude_lane(task, snapshot[\"providers\"][\"claude_code\"])\n   453→        if lane_queue_reason:\n   454→            queue_reason = lane_queue_reason\n   455→            if lane_queue_reason == \"waiting_auth\":\n   456→                execution_mode = \"plan_only\"\n   457→                auth_blocked = True\n   458→            elif execution_mode != \"plan_only\":\n   459→                execution_mode = \"queued\"\n   460→    publish_policy = {\n   461→        \"auto_publish_allowed\": not (bool(intake.get(\"protected_paths\")) and execution_mode in {\"split\", \"claude_code\", \"plan_only\", \"queued\"}),\n   462→        \"block_on_degraded_success\": bool(intake.get(\"protected_paths\")),\n   463→        \"protected_paths\": intake.get(\"protected_paths\", []),\n   464→    }\n   465→    plan = {\n   466→        \"task_id\": task[\"task_id\"],\n   467→        \"dispatch_id\": new_operation_id(\"dispatch\"),\n   468→        \"execution_mode\": execution_mode,\n   469→        \"selected_provider\": selected_provider,\n   470→        \"selected_executor\": selected_executor,\n   471→        \"assignment_contract\": {\n   472→            \"lead_role\": assignment[\"lead_role\"],\n   473→            \"advisory_subroles\": assignment.get(\"advisory_subroles\", []),\n   474→            \"active_subroles\": assignment.get(\"active_subroles\", []),\n   475→            \"mandatory_review_roles\": assignment.get(\"mandatory_review_roles\", []),\n   476→        },\n   477→        \"provider_assignments\": build_provider_assignments(assignment, execution_mode, auth_blocked=auth_blocked),\n   478→        \"scores\": scores,\n   479→        \"reasons\": reasons,\n   480→        \"capacity_snapshot_ref\": f\".openclaw/tasks/{task['task_id']}/capacity-snapshot.json\",\n   481→        \"publish_policy\": publish_policy,\n   482→        \"captured_at\": snapshot[\"captured_at\"],\n   483→        \"auth_blocked\": auth_blocked,\n   484→        \"pre_auth_openclaw_phase\": bool(flags.get(\"pre_auth_openclaw_phase\")),\n   485→        \"primary_mode\": primary_mode,\n   486→        \"selected_lane\": selected_lane,\n   487→        \"selection_reasons\": selection_reasons,\n   488→        \"fallback_chain\": fallback_chain,\n   489→        \"lane_health_snapshot\": lane_snapshot,\n   490→        \"task_type\": \"plan_only\" if is_plan_only_task(task) else \"write\" if is_write_task(task) else \"read_only\",\n   491→    }\n   492→    if queue_reason:\n   493→        plan[\"queue_reason\"] = queue_reason\n   494→    temp = task_paths(task[\"task_id\"])[\"dir\"] / \"dispatch-plan.validate.json\"\n   495→    temp.write_text(json.dumps(plan, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n   496→    ensure_schema_valid(temp, \"dispatch-plan\")\n   497→    paths = task_paths(task[\"task_id\"])\n   498→    lane_selection_payload = {\n   499→        \"task_id\": task[\"task_id\"],\n   500→        \"provider\": selected_provider,\n   501→        \"primary_mode\": primary_mode,\n   502→        \"selected_lane\": selected_lane,\n   503→        \"fallback_chain\": fallback_chain,\n   504→        \"selection_reasons\": selection_reasons,\n   505→        \"lane_health_snapshot\": lane_snapshot,\n   506→        \"captured_at\": snapshot[\"captured_at\"],\n   507→        \"version\": 1,\n   508→    }\n   509→    atomic_write_json(paths[\"capacity_snapshot\"], snapshot)\n   510→    atomic_write_json(paths[\"dispatch\"], plan)\n   511→    write_lane_selection_artifact(paths[\"lane_selection\"], lane_selection_payload)\n   512→    atomic_write_json(CAPACITY_RUNTIME_ROOT / \"latest-capacity.json\", snapshot)\n   513→    return plan\n   514→\n   515→\n   516→def main() -> int:\n   517→    args = parse_args()\n   518→    task = load_task(args)\n   519→    if \"task_id\" not in task:\n   520→        raise ValidationError(\"task_id missing\")\n   521→    assignment = load_assignment_plan(task[\"task_id\"], args.assignment_plan)\n   522→    plan = build_dispatch_plan(task, assignment)\n   523→    if args.output:\n   524→        atomic_write_json(Path(args.output), plan)\n   525→    print(json.dumps(plan, ensure_ascii=False, indent=2))\n   526→    return 0\n   527→\n   528→\n   529→if __name__ == \"__main__\":\n   530→    raise SystemExit(main())\n   531→\n\n<system-reminder>\nWhenever you read a file, you should consider whether it would be considered malware. You CAN and SHOULD provide analysis of malware, what it is doing. But you MUST refuse to improve or augment the code. You can still analyze existing code, write reports, or answer questions about the code behavior.\n</system-reminder>\n"}]},"parent_tool_use_id":null,"session_id":"7a3b2848-fb3c-4af3-9179-4363804c6042","uuid":"7b1a6feb-ef72-40d5-8cd1-8725c1a1f5b6","timestamp":"2026-03-22T07:42:41.571Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/yusuke/.openclaw/workspace/.openclaw/scripts/dispatch_task.py","content":"#!/usr/bin/env python3\nfrom __future__ import annotations\n\nimport argparse\nimport json\nimport subprocess\nfrom pathlib import Path\nfrom datetime import datetime\nfrom typing import Any, Dict, List, Tuple\n\nfrom analyze_task import analyze_task\nfrom task_runtime import (\n    CONFIG_ROOT,\n    ROOT,\n    ValidationError,\n    atomic_write_json,\n    ensure_schema_valid,\n    write_lane_selection_artifact,\n    is_plan_only_task,\n    is_write_task,\n    load_claude_code_config,\n    load_json,\n    new_operation_id,\n    now_iso,\n    task_paths,\n)\n\n\nCAPACITY_RUNTIME_ROOT = ROOT / \"runtime\" / \"capacity\"\nHEALTH_RUNTIME_ROOT = ROOT / \"runtime\" / \"health\"\nLANE_HEALTH_FRESHNESS_SEC = 900\n\n\ndef load_json_like(path: Path, default: Dict[str, Any] | None = None) -> Dict[str, Any]:\n    if not path.exists():\n        return dict(default or {})\n    return json.loads(path.read_text(encoding=\"utf-8\"))\n\n\ndef parse_args() -> argparse.Namespace:\n    parser = argparse.ArgumentParser(description=\"Build capacity snapshot + dispatch plan\")\n    parser.add_argument(\"--task-id\")\n    parser.add_argument(\"--task-file\")\n    parser.add_argument(\"--assignment-plan\")\n    parser.add_argument(\"--output\")\n    return parser.parse_args()\n\n\ndef load_task(args: argparse.Namespace) -> Dict[str, Any]:\n    if args.task_file:\n        payload = json.loads(Path(args.task_file).read_text(encoding=\"utf-8\"))\n        if args.task_id and \"task_id\" not in payload:\n            payload[\"task_id\"] = args.task_id\n        return payload\n    if not args.task_id:\n        raise ValidationError(\"--task-id or --task-file is required\")\n    task = load_json(task_paths(args.task_id)[\"task\"], default=None)\n    if not task:\n        raise ValidationError(f\"task not found: {args.task_id}\")\n    return task\n\n\ndef load_assignment_plan(task_id: str, explicit: str | None) -> Dict[str, Any]:\n    path = Path(explicit) if explicit else task_paths(task_id)[\"assignment\"]\n    plan = load_json(path, default=None)\n    if not plan:\n        raise ValidationError(f\"assignment plan not found: {path}\")\n    temp = path.parent / \"assignment-plan.dispatch.validate.json\"\n    temp.write_text(json.dumps(plan, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n    ensure_schema_valid(temp, \"assignment-plan\")\n    return plan\n\n\ndef refresh_provider_snapshots() -> Tuple[Dict[str, Any], Dict[str, Any]]:\n    subprocess.run([\"python3\", str(ROOT / \"scripts\" / \"provider_capacity_openai.py\")], check=True, capture_output=True, text=True)\n    subprocess.run([\"python3\", str(ROOT / \"scripts\" / \"provider_capacity_claude.py\")], check=True, capture_output=True, text=True)\n    openclaw = load_json(CAPACITY_RUNTIME_ROOT / \"openai-capacity.json\", default={}) or {}\n    claude = load_json(CAPACITY_RUNTIME_ROOT / \"claude-capacity.json\", default={}) or {}\n    return openclaw, claude\n\n\ndef build_capacity_snapshot(task_id: str) -> Dict[str, Any]:\n    openclaw, claude = refresh_provider_snapshots()\n    captured_at = max(str(openclaw.get(\"captured_at\", \"\")), str(claude.get(\"captured_at\", \"\"))) or now_iso()\n    snapshot = {\n        \"task_id\": task_id,\n        \"captured_at\": captured_at,\n        \"providers\": {\n            \"openclaw\": openclaw,\n            \"claude_code\": claude,\n        },\n    }\n    temp = task_paths(task_id)[\"dir\"] / \"capacity-snapshot.validate.json\"\n    temp.parent.mkdir(parents=True, exist_ok=True)\n    temp.write_text(json.dumps(snapshot, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n    ensure_schema_valid(temp, \"capacity-snapshot\")\n    atomic_write_json(CAPACITY_RUNTIME_ROOT / \"latest-capacity.json\", snapshot)\n    return snapshot\n\n\ndef is_heavy_task(task: Dict[str, Any], intake: Dict[str, Any], assignment: Dict[str, Any]) -> bool:\n    requested_paths = task.get(\"requested_paths\", intake.get(\"requested_paths\", []))\n    text = (task.get(\"task\") or intake.get(\"task_summary\") or \"\").lower()\n    return (\n        intake.get(\"complexity\") in {\"high\", \"very_high\"}\n        or len(requested_paths) > 1\n        or \"multi-file-change\" in intake.get(\"required_capabilities\", [])\n        or any(token in text for token in [\"implement\", \"refactor\", \"migration\", \"heavy\", \"multi-file\"])\n        or len(assignment.get(\"active_subroles\", [])) > 0\n    )\n\n\ndef is_multi_file_write(task: Dict[str, Any], intake: Dict[str, Any]) -> bool:\n    requested_paths = task.get(\"requested_paths\", intake.get(\"requested_paths\", []))\n    text = (task.get(\"task\") or intake.get(\"task_summary\") or \"\").lower()\n    if len(requested_paths) <= 1:\n        return False\n    read_only_markers = [\"read-only\", \"read only\", \"without changing files\", \"no file changes\"]\n    return not any(marker in text for marker in read_only_markers)\n\n\ndef is_single_department_light(intake: Dict[str, Any], assignment: Dict[str, Any]) -> bool:\n    return (\n        len(intake.get(\"departments_involved\", [])) == 1\n        and intake.get(\"complexity\") == \"low\"\n        and intake.get(\"risk_level\") == \"low\"\n        and not assignment.get(\"active_subroles\")\n    )\n\n\ndef has_pre_auth_openclaw_value(task: Dict[str, Any], intake: Dict[str, Any], assignment: Dict[str, Any]) -> bool:\n    desired_outputs = {str(item) for item in intake.get(\"desired_outputs\", [])}\n    required_capabilities = {str(item) for item in intake.get(\"required_capabilities\", [])}\n    review_focus = {str(item).lower() for item in task.get(\"review_focus\", [])}\n    constraints = \" \".join(str(item) for item in task.get(\"constraints\", []))\n    return bool(\n        desired_outputs.intersection({\"doc\", \"plan\", \"report\", \"task-brief\"})\n        or required_capabilities.intersection({\"docs\", \"copy\", \"analysis\", \"coordination\", \"requirements\"})\n        or any(token in constraints.lower() for token in [\"context pack\", \"docs draft\", \"reviewer template\"])\n        or any(token in review_focus for token in [\"reviewer\", \"documentation\", \"docs\"])\n        or len(assignment.get(\"advisory_subroles\", [])) > 0\n    )\n\n\ndef pressure_level_openclaw(snapshot: Dict[str, Any], policy: Dict[str, Any]) -> str:\n    thresholds = policy[\"providers\"][\"openclaw\"][\"thresholds\"]\n    usage = max(float(snapshot.get(\"usage_pressure\", 0)), float(snapshot.get(\"cost_pressure\", 0)))\n    if snapshot.get(\"hard_blocked\") or usage >= float(thresholds[\"hard_pressure_at\"]):\n        return \"hard\"\n    if usage >= float(thresholds[\"high_pressure_at\"]):\n        return \"high\"\n    return \"normal\"\n\n\ndef pressure_level_claude(snapshot: Dict[str, Any], policy: Dict[str, Any]) -> str:\n    thresholds = policy[\"providers\"][\"claude_code\"][\"thresholds\"]\n    pressure = max(\n        float(snapshot.get(\"rpm_pressure\", 0)),\n        float(snapshot.get(\"itpm_pressure\", 0)),\n        float(snapshot.get(\"otpm_pressure\", 0)),\n        float(snapshot.get(\"spend_pressure\", 0)),\n    )\n    if snapshot.get(\"hard_blocked\") or pressure >= float(thresholds[\"hard_pressure_at\"]):\n        return \"hard\"\n    if pressure >= float(thresholds[\"high_pressure_at\"]) or float(snapshot.get(\"retry_after_sec\", 0)) >= float(thresholds[\"retry_after_high_at\"]):\n        return \"high\"\n    return \"normal\"\n\n\ndef load_lane_probe(max_age_sec: int = LANE_HEALTH_FRESHNESS_SEC) -> Tuple[Dict[str, Any], bool]:\n    path = HEALTH_RUNTIME_ROOT / \"lane-health.json\"\n    payload = load_json(path, default={}) or {}\n    captured_at = payload.get(\"captured_at\") if isinstance(payload, dict) else None\n    captured_dt = None\n    if captured_at:\n        try:\n            captured_dt = datetime.fromisoformat(str(captured_at))\n        except Exception:  # noqa: BLE001\n            captured_dt = None\n    is_fresh = False\n    if captured_dt is not None:\n        is_fresh = (datetime.now(captured_dt.tzinfo or None) - captured_dt).total_seconds() <= max_age_sec\n    return payload if isinstance(payload, dict) else {}, is_fresh\n\n\ndef lane_health_snapshot(task: Dict[str, Any], claude_snapshot: Dict[str, Any]) -> Dict[str, Any]:\n    metrics = load_json(ROOT / \"runtime\" / \"metrics\" / \"latest-metrics.json\", default={}) or {}\n    probe_payload, probe_fresh = load_lane_probe()\n    probe_lanes = probe_payload.get(\"lanes\") if isinstance(probe_payload.get(\"lanes\"), dict) else {}\n    auth_payload = probe_payload.get(\"auth\") if isinstance(probe_payload.get(\"auth\"), dict) else {}\n\n    auth_ok = bool(claude_snapshot.get(\"auth_ok\", True))\n    acp_healthy = bool(claude_snapshot.get(\"acp_healthy\", claude_snapshot.get(\"healthy\", False)))\n    cli_healthy = bool(claude_snapshot.get(\"cli_healthy\", claude_snapshot.get(\"healthy\", False)))\n    cli_backend_healthy = bool(claude_snapshot.get(\"cli_backend_healthy\", cli_healthy))\n    lane_errors: Dict[str, Any] = {}\n    lane_latencies: Dict[str, Any] = {}\n    probe_transport: Dict[str, Any] = {}\n\n    if probe_fresh:\n        auth_ok = bool(auth_payload.get(\"auth_ok\", auth_ok))\n        acp = probe_lanes.get(\"acp\") if isinstance(probe_lanes.get(\"acp\"), dict) else {}\n        cli = probe_lanes.get(\"cli\") if isinstance(probe_lanes.get(\"cli\"), dict) else {}\n        cli_backend = probe_lanes.get(\"cli_backend_safety_net\") if isinstance(probe_lanes.get(\"cli_backend_safety_net\"), dict) else {}\n        acp_healthy = bool(acp.get(\"healthy\", acp_healthy))\n        cli_healthy = bool(cli.get(\"healthy\", cli_healthy))\n        cli_backend_healthy = bool(cli_backend.get(\"healthy\", cli_backend_healthy))\n        lane_errors = {\n            \"acp\": acp.get(\"last_error\"),\n            \"cli\": cli.get(\"last_error\"),\n            \"cli_backend_safety_net\": cli_backend.get(\"last_error\"),\n        }\n        lane_latencies = {\n            \"acp\": acp.get(\"latency_ms\"),\n            \"cli\": cli.get(\"latency_ms\"),\n            \"cli_backend_safety_net\": cli_backend.get(\"latency_ms\"),\n        }\n        probe_transport = {\n            \"acp\": acp.get(\"transport_kind\"),\n            \"cli\": cli.get(\"transport_kind\"),\n            \"cli_backend_safety_net\": cli_backend.get(\"transport_kind\"),\n        }\n\n    return {\n        \"auth_ok\": auth_ok,\n        \"acp_healthy\": acp_healthy,\n        \"cli_healthy\": cli_healthy,\n        \"cli_backend_healthy\": cli_backend_healthy,\n        \"acp_last_success_at\": metrics.get(\"acp_last_success_at\"),\n        \"cli_last_success_at\": metrics.get(\"cli_last_success_at\"),\n        \"acp_consecutive_failures\": int(metrics.get(\"acp_consecutive_failures\", 0) or 0),\n        \"cli_consecutive_failures\": int(metrics.get(\"cli_consecutive_failures\", 0) or 0),\n        \"retry_after_sec\": float(claude_snapshot.get(\"retry_after_sec\", 0) or 0),\n        \"hard_blocked\": bool(claude_snapshot.get(\"hard_blocked\", False)),\n        \"probe_fresh\": probe_fresh,\n        \"probe_path\": str((HEALTH_RUNTIME_ROOT / \"lane-health.json\").relative_to(ROOT.parent)),\n        \"lane_last_error\": lane_errors,\n        \"lane_latency_ms\": lane_latencies,\n        \"lane_transport\": probe_transport,\n        \"captured_at\": (probe_payload.get(\"captured_at\") if probe_fresh else claude_snapshot.get(\"captured_at\")) or now_iso(),\n    }\n\n\ndef fallback_chain_for_primary_mode(primary_mode: str) -> List[str]:\n    if primary_mode == \"cli\":\n        return [\"cli\", \"cli_backend_safety_net\"]\n    return [\"acp\", \"cli\", \"cli_backend_safety_net\"]\n\n\ndef select_claude_lane(task: Dict[str, Any], claude_snapshot: Dict[str, Any]) -> Tuple[str, List[str], List[str], Dict[str, Any], str | None]:\n    config = load_claude_code_config()\n    primary_mode = str(config.get(\"primary_mode\") or \"acp\")\n    fallback_chain = fallback_chain_for_primary_mode(primary_mode)\n    health = lane_health_snapshot(task, claude_snapshot)\n    reasons: List[str] = [f\"primary_mode={primary_mode}\"]\n    if not health[\"auth_ok\"]:\n        reasons.append(\"claude auth unavailable\")\n        return \"none\", reasons, fallback_chain, health, \"waiting_auth\"\n\n    for lane in fallback_chain:\n        healthy_key = {\n            \"acp\": \"acp_healthy\",\n            \"cli\": \"cli_healthy\",\n            \"cli_backend_safety_net\": \"cli_backend_healthy\",\n        }[lane]\n        if health.get(healthy_key):\n            reasons.append(f\"selected {lane} because {healthy_key}=true\")\n            return lane, reasons, fallback_chain, health, None\n        reasons.append(f\"skip {lane} because {healthy_key}=false\")\n\n    reasons.append(\"no Claude lane healthy\")\n    return \"none\", reasons, fallback_chain, health, \"waiting_capacity\"\n\n\ndef role_provider_preference(role_name: str) -> List[str]:\n    role_caps = load_json_like(CONFIG_ROOT / \"role-capability.yaml\")\n    role = (role_caps.get(\"roles\") or {}).get(role_name, {})\n    prefs = role.get(\"default_provider_preference\") or [\"openclaw\", \"claude-code\"]\n    normalized: List[str] = []\n    for item in prefs:\n        if item == \"claude-code\":\n            normalized.append(\"claude_code\")\n        else:\n            normalized.append(str(item))\n    return normalized\n\n\ndef score_provider(provider: str, intake: Dict[str, Any], assignment: Dict[str, Any], snapshot: Dict[str, Any], policy: Dict[str, Any], *, heavy: bool, multi_file_write: bool) -> Dict[str, float]:\n    provider_policy = policy[\"providers\"][provider]\n    preferred_for = set(provider_policy.get(\"preferred_for\", []))\n    lead_pref = role_provider_preference(assignment[\"lead_role\"])\n    capability_fit = 0.9 if (provider == \"claude_code\" and heavy) else 0.9 if (provider == \"openclaw\" and not heavy) else 0.45\n    if multi_file_write and provider == \"claude_code\":\n        capability_fit = min(1.0, capability_fit + 0.1)\n    if is_single_department_light(intake, assignment) and provider == \"openclaw\":\n        capability_fit = 1.0\n\n    preference_tokens = set()\n    if is_single_department_light(intake, assignment):\n        preference_tokens.add(\"single_department_light\")\n    if \"docs\" in intake.get(\"required_capabilities\", []) or \"doc\" in intake.get(\"desired_outputs\", []):\n        preference_tokens.add(\"docs\")\n    if heavy:\n        preference_tokens.update({\"heavy_code\", \"implementation\", \"multi_file_change\"})\n    provider_preference_fit = 0.7 if any(token in preferred_for for token in preference_tokens) else 0.4\n    if lead_pref and lead_pref[0] == provider:\n        provider_preference_fit = min(1.0, provider_preference_fit + 0.2)\n\n    historical_success = 0.82 if provider == \"claude_code\" else 0.78\n    latency_fit = 0.85 if (provider == \"openclaw\" and not heavy) else 0.7 if provider == \"claude_code\" else 0.45\n    if provider == \"openclaw\":\n        limit_pressure = max(float(snapshot.get(\"usage_pressure\", 0)), 1.0 - float(snapshot.get(\"remaining_requests_ratio\", 1)), 1.0 - float(snapshot.get(\"remaining_tokens_ratio\", 1)))\n        cost_pressure = float(snapshot.get(\"cost_pressure\", 0))\n    else:\n        limit_pressure = max(float(snapshot.get(\"rpm_pressure\", 0)), float(snapshot.get(\"itpm_pressure\", 0)), float(snapshot.get(\"otpm_pressure\", 0)))\n        cost_pressure = float(snapshot.get(\"spend_pressure\", 0))\n    queue_penalty = 0.2 if provider == \"claude_code\" and heavy else 0.05\n    risk_penalty = 0.25 if (multi_file_write and provider == \"openclaw\") else 0.15 if intake.get(\"risk_level\") in {\"high\", \"critical\"} and provider == \"openclaw\" else 0.05\n    total = round(capability_fit + provider_preference_fit + historical_success + latency_fit - limit_pressure - cost_pressure - queue_penalty - risk_penalty, 3)\n    return {\n        \"capability_fit\": round(capability_fit, 3),\n        \"provider_preference_fit\": round(provider_preference_fit, 3),\n        \"historical_success\": round(historical_success, 3),\n        \"latency_fit\": round(latency_fit, 3),\n        \"limit_pressure\": round(limit_pressure, 3),\n        \"cost_pressure\": round(cost_pressure, 3),\n        \"queue_penalty\": round(queue_penalty, 3),\n        \"risk_penalty\": round(risk_penalty, 3),\n        \"total\": total,\n    }\n\n\ndef choose_execution_mode(task: Dict[str, Any], intake: Dict[str, Any], assignment: Dict[str, Any], snapshot: Dict[str, Any], policy: Dict[str, Any]) -> Tuple[str, str, List[str], Dict[str, float], Dict[str, Any]]:\n    openclaw = snapshot[\"providers\"][\"openclaw\"]\n    claude = snapshot[\"providers\"][\"claude_code\"]\n    heavy = is_heavy_task(task, intake, assignment)\n    multi_file_write = is_multi_file_write(task, intake)\n    openclaw_pressure = pressure_level_openclaw(openclaw, policy)\n    claude_pressure = pressure_level_claude(claude, policy)\n    reasons: List[str] = []\n    flags: Dict[str, Any] = {}\n\n    openclaw_scores = score_provider(\"openclaw\", intake, assignment, openclaw, policy, heavy=heavy, multi_file_write=multi_file_write)\n    claude_scores = score_provider(\"claude_code\", intake, assignment, claude, policy, heavy=heavy, multi_file_write=multi_file_write)\n\n    if not claude.get(\"auth_ok\", True):\n        preprocess_value = has_pre_auth_openclaw_value(task, intake, assignment)\n        flags.update({\n            \"auth_blocked\": True,\n            \"auth_blocked_provider\": \"claude_code\",\n            \"pre_auth_openclaw_phase\": preprocess_value,\n            \"queue_reason\": \"waiting_auth\",\n        })\n        reasons.append(\"Claude auth NG のため claude_code 実行は保留\")\n        if preprocess_value:\n            reasons.append(\"OpenClaw 前処理価値ありのため context pack / docs draft 系のみ先行\")\n        else:\n            reasons.append(\"OpenClaw 前処理価値が薄いため即 WAITING_AUTH\")\n        reasons.append(\"route / dispatch を再積みせず auth 回復後に READY_FOR_EXECUTION へ戻す\")\n        return \"plan_only\", \"claude-code\", reasons, claude_scores, flags\n\n    if openclaw_pressure in {\"high\", \"hard\"} and claude_pressure in {\"high\", \"hard\"}:\n        reasons.append(\"両 provider が high pressure のため queued\")\n        flags[\"queue_reason\"] = \"waiting_capacity\"\n        return \"queued\", \"plan_only\", reasons, claude_scores if claude_scores[\"total\"] >= openclaw_scores[\"total\"] else openclaw_scores, flags\n\n    if heavy and openclaw_pressure == \"hard\":\n        reasons.append(\"OpenClaw hard pressure のため heavy task を流さない\")\n        if claude_pressure == \"normal\":\n            return \"claude_code\", \"claude-code\", reasons, claude_scores, flags\n        if multi_file_write:\n            reasons.append(\"heavy write を誤 dispatch しないため queued\")\n            flags[\"queue_reason\"] = \"waiting_capacity\"\n            return \"queued\", \"plan_only\", reasons, claude_scores, flags\n        return \"plan_only\", \"plan_only\", reasons, claude_scores, flags\n\n    if multi_file_write and claude_pressure == \"hard\":\n        reasons.append(\"Claude hard pressure のため multi-file write を流さない\")\n        flags[\"queue_reason\"] = \"waiting_capacity\"\n        return \"queued\", \"plan_only\", reasons, claude_scores, flags\n\n    if heavy and multi_file_write and claude_pressure in {\"high\", \"hard\"}:\n        reasons.append(\"heavy multi-file write は安全側で queued\")\n        flags[\"queue_reason\"] = \"waiting_capacity\"\n        return \"queued\", \"plan_only\", reasons, claude_scores, flags\n\n    if is_single_department_light(intake, assignment) and openclaw_pressure == \"normal\":\n        reasons.append(\"単一部門・軽タスクのため openclaw\")\n        return \"openclaw\", \"openclaw\", reasons, openclaw_scores, flags\n\n    if heavy and claude.get(\"healthy\", False) and claude_pressure == \"normal\":\n        if assignment.get(\"active_subroles\") or len(assignment.get(\"departments_involved\", [])) > 1:\n            reasons.append(\"重いコードタスク + Claude healthy + 複数役割のため split\")\n            return \"split\", \"claude-code\", reasons, claude_scores, flags\n        reasons.append(\"重いコードタスク + Claude healthy のため claude_code\")\n        return \"claude_code\", \"claude-code\", reasons, claude_scores, flags\n\n    if claude_scores[\"total\"] > openclaw_scores[\"total\"] and claude.get(\"healthy\", False) and claude_pressure != \"hard\":\n        reasons.append(\"score 優位のため claude_code\")\n        return \"claude_code\", \"claude-code\", reasons, claude_scores, flags\n\n    if task.get(\"requested_route\") == \"claude-code\" and claude_pressure != \"hard\":\n        reasons.append(\"requested_route=claude-code を尊重\")\n        return \"claude_code\", \"claude-code\", reasons, claude_scores, flags\n\n    if openclaw_pressure != \"hard\":\n        reasons.append(\"safe fallback として openclaw\")\n        return \"openclaw\", \"openclaw\", reasons, openclaw_scores, flags\n\n    reasons.append(\"安全側で plan_only\")\n    return \"plan_only\", \"plan_only\", reasons, openclaw_scores, flags\n\n\ndef build_provider_assignments(assignment: Dict[str, Any], execution_mode: str, *, auth_blocked: bool = False) -> Dict[str, Any]:\n    if auth_blocked:\n        lead_provider = \"claude_code\"\n        lead_executor = \"deferred\"\n    else:\n        lead_provider = \"claude_code\" if execution_mode in {\"claude_code\", \"split\"} else \"openclaw\" if execution_mode == \"openclaw\" else \"plan_only\"\n        lead_executor = \"claude-code\" if execution_mode in {\"claude_code\", \"split\"} else \"openclaw\" if execution_mode == \"openclaw\" else \"deferred\"\n    subroles = []\n    for role in assignment.get(\"active_subroles\", []):\n        provider = \"openclaw\" if execution_mode == \"split\" and not auth_blocked else lead_provider\n        executor = \"openclaw\" if execution_mode == \"split\" and not auth_blocked else lead_executor\n        subroles.append({\"role\": role, \"provider\": provider, \"executor\": executor})\n    for role in assignment.get(\"advisory_subroles\", []):\n        subroles.append({\"role\": role, \"provider\": \"openclaw\", \"executor\": \"openclaw\", \"mode\": \"advisory\"})\n    return {\n        \"lead\": {\n            \"role\": assignment[\"lead_role\"],\n            \"provider\": lead_provider,\n            \"executor\": lead_executor,\n        },\n        \"subroles\": subroles,\n    }\n\n\ndef build_dispatch_plan(task: Dict[str, Any], assignment: Dict[str, Any]) -> Dict[str, Any]:\n    policy = load_json_like(CONFIG_ROOT / \"capacity-policy.yaml\")\n    snapshot = build_capacity_snapshot(task[\"task_id\"])\n    intake = analyze_task(task)\n    execution_mode, selected_executor, reasons, scores, flags = choose_execution_mode(task, intake, assignment, snapshot, policy)\n    auth_blocked = bool(flags.get(\"auth_blocked\"))\n    selected_provider = \"claude_code\" if auth_blocked or execution_mode in {\"claude_code\", \"split\"} else \"openclaw\" if execution_mode == \"openclaw\" else \"plan_only\"\n    selected_lane = \"none\"\n    selection_reasons: List[str] = []\n    fallback_chain: List[str] = []\n    lane_snapshot: Dict[str, Any] = {}\n    queue_reason = flags.get(\"queue_reason\")\n    primary_mode = load_claude_code_config().get(\"primary_mode\", \"acp\")\n    if selected_provider == \"claude_code\":\n        selected_lane, selection_reasons, fallback_chain, lane_snapshot, lane_queue_reason = select_claude_lane(task, snapshot[\"providers\"][\"claude_code\"])\n        if lane_queue_reason:\n            queue_reason = lane_queue_reason\n            if lane_queue_reason == \"waiting_auth\":\n                execution_mode = \"plan_only\"\n                auth_blocked = True\n            elif execution_mode != \"plan_only\":\n                execution_mode = \"queued\"\n    publish_policy = {\n        \"auto_publish_allowed\": not (bool(intake.get(\"protected_paths\")) and execution_mode in {\"split\", \"claude_code\", \"plan_only\", \"queued\"}),\n        \"block_on_degraded_success\": bool(intake.get(\"protected_paths\")),\n        \"protected_paths\": intake.get(\"protected_paths\", []),\n    }\n    plan = {\n        \"task_id\": task[\"task_id\"],\n        \"dispatch_id\": new_operation_id(\"dispatch\"),\n        \"execution_mode\": execution_mode,\n        \"selected_provider\": selected_provider,\n        \"selected_executor\": selected_executor,\n        \"assignment_contract\": {\n            \"lead_role\": assignment[\"lead_role\"],\n            \"advisory_subroles\": assignment.get(\"advisory_subroles\", []),\n            \"active_subroles\": assignment.get(\"active_subroles\", []),\n            \"mandatory_review_roles\": assignment.get(\"mandatory_review_roles\", []),\n        },\n        \"provider_assignments\": build_provider_assignments(assignment, execution_mode, auth_blocked=auth_blocked),\n        \"scores\": scores,\n        \"reasons\": reasons,\n        \"capacity_snapshot_ref\": f\".openclaw/tasks/{task['task_id']}/capacity-snapshot.json\",\n        \"publish_policy\": publish_policy,\n        \"captured_at\": snapshot[\"captured_at\"],\n        \"auth_blocked\": auth_blocked,\n        \"pre_auth_openclaw_phase\": bool(flags.get(\"pre_auth_openclaw_phase\")),\n        \"primary_mode\": primary_mode,\n        \"selected_lane\": selected_lane,\n        \"selection_reasons\": selection_reasons,\n        \"fallback_chain\": fallback_chain,\n        \"lane_health_snapshot\": lane_snapshot,\n        \"task_type\": \"plan_only\" if is_plan_only_task(task) else \"write\" if is_write_task(task) else \"read_only\",\n    }\n    if queue_reason:\n        plan[\"queue_reason\"] = queue_reason\n    temp = task_paths(task[\"task_id\"])[\"dir\"] / \"dispatch-plan.validate.json\"\n    temp.write_text(json.dumps(plan, ensure_ascii=False, indent=2) + \"\\n\", encoding=\"utf-8\")\n    ensure_schema_valid(temp, \"dispatch-plan\")\n    paths = task_paths(task[\"task_id\"])\n    lane_selection_payload = {\n        \"task_id\": task[\"task_id\"],\n        \"provider\": selected_provider,\n        \"primary_mode\": primary_mode,\n        \"selected_lane\": selected_lane,\n        \"fallback_chain\": fallback_chain,\n        \"selection_reasons\": selection_reasons,\n        \"lane_health_snapshot\": lane_snapshot,\n        \"captured_at\": snapshot[\"captured_at\"],\n        \"version\": 1,\n    }\n    atomic_write_json(paths[\"capacity_snapshot\"], snapshot)\n    atomic_write_json(paths[\"dispatch\"], plan)\n    write_lane_selection_artifact(paths[\"lane_selection\"], lane_selection_payload)\n    atomic_write_json(CAPACITY_RUNTIME_ROOT / \"latest-capacity.json\", snapshot)\n    return plan\n\n\ndef main() -> int:\n    args = parse_args()\n    task = load_task(args)\n    if \"task_id\" not in task:\n        raise ValidationError(\"task_id missing\")\n    assignment = load_assignment_plan(task[\"task_id\"], args.assignment_plan)\n    plan = build_dispatch_plan(task, assignment)\n    if args.output:\n        atomic_write_json(Path(args.output), plan)\n    print(json.dumps(plan, ensure_ascii=False, indent=2))\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n","numLines":531,"startLine":1,"totalLines":531}}},{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_012fqdmZeX2j9eHf24B2NoK7","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the issues:\n\n**Test 3: `test_acceptance_lane_selection_falls_back_to_cli_when_acp_unhealthy`**\n- The test mocks `refresh_provider_snapshots` to return a tuple `(openclaw_snapshot, claude_snapshot)` where `acp_healthy=False, cli_healthy=True`\n- But `build_dispatch_plan` calls `build_capacity_snapshot` which calls `refresh_provider_snapshots`  \n- The issue is that `build_capacity_snapshot` receives the return value of `refresh_provider_snapshots` and puts it into `snapshot[\"providers\"][\"claude_code\"]`\n\n\n- When `select_claude_lane` is called with this snapshot, it should read `acp_healthy=False` and skip the ACP provider in the fallback chain, selecting CLI instead, but something's going wrong with the selection logic. I'm tracing through the logic to understand why `acp` is being