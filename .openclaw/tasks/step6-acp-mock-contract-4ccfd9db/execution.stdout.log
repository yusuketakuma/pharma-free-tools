  11→SCRIPTS = ROOT / \"scripts\"\n    12→WORKSPACE = ROOT.parent\n    13→sys.path.insert(0, str(SCRIPTS))\n    14→\n    15→import execute_task as execute_task_module  # noqa: E402\n    16→from task_runtime import atomic_write_json, load_dispatch_attempts_artifact, load_json, task_paths  # noqa: E402\n    17→\n    18→\n    19→class LaneRuntimeAcceptanceTest(unittest.TestCase):\n    20→    def make_id(self, name: str) -> str:\n    21→        return f\"lane-runtime-{name}-{uuid.uuid4().hex[:8]}\"\n    22→\n    23→    def dispatch_payload(self, task_id: str, *, selected_lane: str = \"acp\") -> dict:\n    24→        return {\n    25→            \"task_id\": task_id,\n    26→            \"dispatch_id\": f\"dispatch-{task_id}\",\n    27→            \"execution_mode\": \"claude_code\",\n    28→            \"selected_provider\": \"claude_code\",\n    29→            \"selected_executor\": \"claude-code\",\n    30→            \"assignment_contract\": {\n    31→                \"lead_role\": \"engineering\",\n    32→                \"advisory_subroles\": [],\n    33→                \"active_subroles\": [],\n    34→                \"mandatory_review_roles\": [],\n    35→            },\n    36→            \"provider_assignments\": {\n    37→                \"lead\": {\"role\": \"engineering\", \"provider\": \"claude_code\", \"executor\": \"claude-code\"},\n    38→                \"subroles\": [],\n    39→            },\n    40→            \"scores\": {\"total\": 1.0},\n    41→            \"reasons\": [\"test fixture\"],\n    42→            \"capacity_snapshot_ref\": f\".openclaw/tasks/{task_id}/capacity-snapshot.json\",\n    43→            \"publish_policy\": {\"auto_publish_allowed\": True, \"block_on_degraded_success\": False, \"protected_paths\": []},\n    44→            \"captured_at\": \"2026-03-22T13:00:00+09:00\",\n    45→            \"auth_blocked\": False,\n    46→            \"pre_auth_openclaw_phase\": False,\n    47→            \"primary_mode\": \"acp\",\n    48→            \"selected_lane\": selected_lane,\n    49→            \"selection_reasons\": [\"test fixture\"],\n    50→            \"fallback_chain\": [\"acp\", \"cli\", \"cli_backend_safety_net\"],\n    51→            \"lane_health_snapshot\": {\n    52→                \"auth_ok\": True,\n    53→                \"acp_healthy\": True,\n    54→                \"cli_healthy\": True,\n    55→                \"cli_backend_healthy\": True,\n    56→                \"captured_at\": \"2026-03-22T13:00:00+09:00\",\n    57→            },\n    58→            \"task_type\": \"write\",\n    59→        }\n    60→\n    61→    def assignment_payload(self, task_id: str) -> dict:\n    62→        return {\n    63→            \"task_id\": task_id,\n    64→            \"lead_role\": \"engineering\",\n    65→            \"advisory_subroles\": [],\n    66→            \"active_subroles\": [],\n    67→            \"mandatory_review_roles\": [],\n    68→        }\n    69→\n    70→    def task_payload(self, task_id: str, *, mock_mode: str | None = None) -> dict:\n    71→        payload = {\n    72→            \"task_id\": task_id,\n    73→            \"task\": \"Implement lane runtime behavior\",\n    74→            \"requested_paths\": [\".openclaw/scripts/execute_task.py\"],\n    75→            \"constraints\": [],\n    76→            \"verification_commands\": [],\n    77→            \"review_focus\": [\"correctness\"],\n    78→            \"requested_actions\": [\"edit\"],\n    79→            \"requested_route\": \"claude-code\",\n    80→        }\n    81→        if mock_mode:\n    82→            payload[\"mock_mode\"] = mock_mode\n    83→        return payload\n    84→\n    85→    def success_result(self, task_id: str, dispatch_id: str) -> dict:\n    86→        return {\n    87→            \"task_id\": task_id,\n    88→            \"status\": \"success\",\n    89→            \"executor\": \"claude-code\",\n    90→            \"summary\": \"ok\",\n    91→            \"changed_files\": [\".openc