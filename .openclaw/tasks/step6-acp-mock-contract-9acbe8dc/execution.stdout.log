paths(task_id)[\"task\"])]):\n                    self.assertEqual(execute_task_module.main(), 30)\n        state = load_json(task_paths(task_id)[\"state\"])\n        self.assertEqual(state[\"state\"], \"WAITING_MANUAL_REVIEW\")\n\n    def test_dispatch_attempt_loader_migrates_legacy_rows(self) -> None:\n        task_id = self.make_id(\"migrate\")\n        attempts_path = task_paths(task_id)[\"dispatch_attempts\"]\n        attempts_path.parent.mkdir(parents=True, exist_ok=True)\n        attempts_path.write_text(","numLines":200,"startLine":1,"totalLines":224}}},{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01TpyEHo2Mi53vSWJZTA98GZ","type":"message","role":"assistant","content":[{"type":"thinking","thinking":"Now I understand the `test_acceptance_acp_to_cli_backend_safety_net` test. It:\n1. Creates a task with `selected_lane=\"acp\"` and `fallback_chain=[\"acp\", \"cli\", \"cli_backend_safety_net\"]`\n2. Provides 3 side effects: ACP fails, then CLI fails, then cli_backend_safety_net succeeds\n3. The test mocks `run_claude_lane` with a side_effect list\n4. Expects `lane_selection[\"selected_lane\"]` == `\"cli_backend_safety_net\"` and the selection reasons contain `\"auto fallback cli->cli_backend_safety_net\"`\n\n\n5. The test is failing because `main()` returns 30 instead of 0, which means the fallback chain isn't being executed properly—when ACP fails and falls back to CLI, and CLI also fails, it should continue to `cli_backend_safety_net` but it's stopping at the first failure instead.\n\nLet me trace through the execution flow: ACP starts and returns a failure with `failure_stage=\"session_start\"`, triggering an auto-fallback to CLI. CLI then runs but also fails with `failure_stage=\"health_check\"`. At this point, the code is checking the exit code and status mapping to determine what happens next, but it seems like the fallback logic isn't continuing to the safety net backend.\n\nThe issue is that after the first fallback attempt, the co