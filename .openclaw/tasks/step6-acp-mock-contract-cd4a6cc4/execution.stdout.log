executor\": \"claude-code\",\n    30→            \"assignment_contract\": {\n    31→                \"lead_role\": \"engineering\",\n    32→                \"advisory_subroles\": [],\n    33→                \"active_subroles\": [],\n    34→                \"mandatory_review_roles\": [],\n    35→            },\n    36→            \"provider_assignments\": {\n    37→                \"lead\": {\"role\": \"engineering\", \"provider\": \"claude_code\", \"executor\": \"claude-code\"},\n    38→                \"subroles\": [],\n    39→            },\n    40→            \"scores\": {\"total\": 1.0},\n    41→            \"reasons\": [\"test fixture\"],\n    42→            \"capacity_snapshot_ref\": f\".openclaw/tasks/{task_id}/capacity-snapshot.json\",\n    43→            \"publish_policy\": {\"auto_publish_allowed\": True, \"block_on_degraded_success\": False, \"protected_paths\": []},\n    44→            \"captured_at\": \"2026-03-22T13:00:00+09:00\",\n    45→            \"auth_blocked\": False,\n    46→            \"pre_auth_openclaw_phase\": False,\n    47→            \"primary_mode\": \"acp\",\n    48→            \"selected_lane\": selected_lane,\n    49→            \"selection_reasons\": [\"test fixture\"],\n    50→            \"fallback_chain\": [\"acp\", \"cli\", \"cli_backend_safety_net\"],\n    51→            \"lane_health_snapshot\": {\n    52→                \"auth_ok\": True,\n    53→                \"acp_healthy\": True,\n    54→                \"cli_healthy\": True,\n    55→                \"cli_backend_healthy\": True,\n    56→                \"captured_at\": \"2026-03-22T13:00:00+09:00\",\n    57→            },\n    58→            \"task_type\": \"write\",\n    59→        }\n    60→\n    61→    def assignment_payload(self, task_id: str) -> dict:\n    62→        return {\n    63→            \"task_id\": task_id,\n    64→            \"lead_role\": \"engineering\",\n    65→            \"advisory_subroles\": [],\n    66→            \"active_subroles\": [],\n    67→            \"mandatory_review_roles\": [],\n    68→        }\n    69→\n    70→    def task_payload(self, task_id: str, *, mock_mode: str | None = None) -> dict:\n    71→        payload = {\n    72→            \"task_id\": task_id,\n    73→            \"task\": \"Implement lane runtime behavior\",\n    74→            \"requested_paths\": [\".openclaw/scripts/execute_task.py\"],\n    75→            \"constraints\": [],\n    76→            \"verification_commands\": [],\n    77→            \"review_focus\": [\"correctness\"],\n    78→            \"requested_actions\": [\"edit\"],\n    79→            \"requested_route\": \"claude-code\",\n    80→        }\n    81→        if mock_mode:\n    82→            payload[\"mock_mode\"] = mock_mode\n    83→        return payload\n    84→\n    85→    def success_result(self, task_id: str, dispatch_id: str) -> dict:\n    86→        return {\n    87→            \"task_id\": task_id,\n    88→            \"status\": \"success\",\n    89→            \"executor\": \"claude-code\",\n    90→            \"summary\": \"ok\",\n    91→            \"changed_files\": [\".openclaw/scripts/execute_task.py\"],\n    92→            \"verification_results\": [\"fixture\"],\n    93→            \"remaining_risks\": [],\n    94→            \"exit_code\": 0,\n    95→            \"started_at\": \"2026-03-22T13:00:00+09:00\",\n    96→            \"finished_at\": \"2026-03-22T13:00:01+09:00\",\n    97→            \"dispatch_id\": dispatch_id,\n    98→            \"_meta\": {\"lane\": \"acp\", \"publishable\": True},\n    99→        }\n   100→\n   101→    def runtime_error(self, task_id: str, dispatch_id: str, *, result_code: str | None = None, failure_stage: str = \"session_start\", partial_execution: bool = False, side_effects_possible: bool = False) -> dict:\n   102→        payload = {\n   103→            \"task_id\": task_id,\n   104→            \"status\": \"runtime_error\",\n   105→            \"executor\": \"claude-code\",\n   106→            \"summary\": \"runtime error\",\n   107→            \"changed_files\": [\".openclaw/scripts/execute_task.py\"] if partial_execution else [],\n   108→            \"verification_results\": [\"fixture\"],\n   109→            \"remaining_risks\": [\"fixture\"],\n   110→            \"exit_code\": 30,\n   111→            \"started_at\": \"2026-03-22T13:00:00+09:00\",\n   112→            \"finished_at\": \"2026-03-22T13:00:01+09:00\",\n   113→            \"dispatch_id\": dispatch_id,\n   114→            \"_meta\": {\n   115→                \"failure_stage\": failure_stage,\n   116→                \"partial_execution\": partial_execution,\n   117→                \"side_effects_possible\": side_effects_possible,\n   118→                \"publishable\": False,\n   119→            },\n   120→        }\n   121→        if result_code:\n   122→            payload[\"_meta\"][\"result_code\"] = result_code\n   123→        return payload\n   124→\n   125→    def prepare_task(self, task_id: str, dispatch: dict | None = None, *, mock_mode: str | None = None) -> Path:\n   126→        paths = task_paths(task_id)\n   127→        atomic_write_json(paths[\"task\"], self.task_payload(task_id, mock_mode=mock_mode))\n   128→        atomic_write_json(paths[\"assignment\"], self.assignment_payload(task_id))\n   129→        return paths[\"task\"]\n   130→\n   131→    def run_main(self, task_id: str, dispatch: dict, side_effect) -> None:\n   132→        with mock.patch.object(execute_task_module, \"build_dispatch_plan\", return_value=dispatch):\n   133→            with mock.patch.object(execute_task_module, \"run_claude_lane\", side_effect=side_effect):\n   134→                with mock.patch.object(sys, \"argv\", [\"execute_task.py\", \"--task-id\", task_id, \"--task-file\", str(task_paths(task_id)[\"task\"])]):\n   135→                    self.assertEqual(execute_task_module.main(), 0)\n   136→\n   137→    def test_acceptance_acp_success_path(self) -> None:\n   138→        task_id = self.make_id(\"acp-success\")\n   139→        dispatch = self.dispatch_payload(task_id, selected_lane=\"acp\")\n   140→        self.prepare_task(task_id)\n   141→        result = self.success_result(task_id, dispatch[\"dispatch_id\"])\n   142→        self.run_main(task_id, dispatch, [(0, result, dispatch[\"dispatch_id\"], \"attempt-01\")])\n   143→        state = load_json(task_paths(task_id)[\"state\"])\n   144→        self.assertEqual(state[\"state\"], \"REVIEWING\")\n   145→\n   146→    def test_acceptance_acp_to_cli_backend_safety_net(self) -> None:\n   147→        task_id = self.make_id(\"acp-cli-safety\")\n   148→        dispatch = self.dispatch_payload(task_id, selected_lane=\"acp\")\n   149→        task_path = self.prepare_task(task_id)\n   150→        atomic_write_json(task_path, {\n   151→            \"task_id\": task_id,\n   152→            \"task\": \"Review runtime behavior in read-only mode\",\n   153→            \"requested_paths\": [\".openclaw/scripts/execute_task.py\"],\n   154→            \"constraints\": [\"read-only\"],\n   155→            \"verification_commands\": [],\n   156→            \"review_focus\": [\"correctness\"],\n   157→            \"requested_actions\": [],\n   158→            \"requested_route\": \"claude-code\",\n   159→        })\n   160→        side_effect = [\n   161→            (30, self.runtime_error(task_id, dispatch[\"dispatch_id\"], failure_stage=\"session_start\"), dispatch[\"dispatch_id\"], \"attempt-01\"),\n   162→            (30, self.runtime_error(task_id, dispatch[\"dispatch_id\"], failure_stage=\"health_check\"), dispatch[\"dispatch_id\"], \"attempt-02\"),\n   163→            (0, self.success_result(task_id, dispatch[\"dispatch_id\"]), dispatch[\"dispatch_id\"], \"attempt-03\"),\n   164→        ]\n   165→        self.run_main(task_id, dispatch, side_effect)\n   166→        state = load_json(task_paths(task_id)[\"state\"])\n   167→        lane_selection = load_json(task_paths(task_id)[\"lane_selection\"])\n   168→        self.ass