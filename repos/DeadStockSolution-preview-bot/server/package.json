{
  "name": "server",
  "version": "0.0.9",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "openapi:generate": "node ../scripts/generate-openapi.mjs",
    "openapi:check": "node ../scripts/generate-openapi.mjs --check",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:migrate:legacy": "tsx src/db/migrate-legacy.ts",
    "db:apply-performance-indexes": "tsx src/db/apply-performance-scale-indexes.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed-admin": "tsx src/db/seed-admin-account.ts",
    "db:seed-test-pharmacies": "tsx src/db/seed-test-pharmacy-accounts.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:openapi-contract": "vitest run --config vitest.config.ts src/test/openapi-contract.test.ts",
    "test:integration": "vitest run --config vitest.config.ts src/test/upload-route.test.ts src/test/drug-master-route.test.ts src/test/upload-inventory-flow.test.ts",
    "test:perf": "PERF_REGRESSION_ENABLED=true vitest run --config vitest.config.ts src/test/performance-regression.test.ts",
    "test:perf:update": "PERF_REGRESSION_ENABLED=true PERF_BASELINE_UPDATE=true vitest run --config vitest.config.ts src/test/performance-regression.test.ts",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:watch": "vitest --config vitest.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@sentry/node": "^10.42.0",
    "@vercel/postgres": "^0.10.0",
    "adm-zip": "^0.5.16",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "fast-xml-parser": "^5.3.1",
    "fastest-levenshtein": "^1.0.16",
    "helmet": "^8.1.0",
    "iconv-lite": "^0.7.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "read-excel-file": "^6.0.3",
    "undici": "^7.22.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.3.15",
    "@libsql/client": "^0.17.0",
    "@types/adm-zip": "^0.5.7",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^25.3.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.31.9",
    "supertest": "^7.1.4",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
